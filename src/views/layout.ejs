<!DOCTYPE html>
<html lang="en" dir="ltr">
    <%- include("partials/head") %>
    <body>
        <% if (typeof isLoginPage !== 'undefined' && isLoginPage) { %>
            <main class="min-h-screen flex items-center justify-center bg-brand-bg">
                <div
                    class="pointer-events-none absolute -top-24 left-0 h-96 w-96 rounded-full
                        bg-brand-nav/20 blur-3xl"
                ></div>
                <div
                    class="pointer-events-none absolute -bottom-16 right-0 h-80 w-80 rounded-full
                        bg-brand-title/20 blur-3xl"
                ></div>
                <% if (typeof isNotFoundPage !== 'undefined' && isNotFoundPage) { %>
                    <section class="relative z-10 w-full px-4">
                        <%- include("partials/flash") %>
                        <%- body %>
                    </section>
                <% } else { %>
                    <section
                        class="relative z-10 w-full max-w-lg rounded-3xl border
                            border-brand-secondary/60 bg-white/90 p-8 shadow-xl backdrop-blur"
                    >
                        <%- include("partials/flash") %>
                        <div id="flash-container"></div>
                        <%- body %>
                    </section>
                <% } %>
            </main>
        <% } else { %>
            <div class="flex min-h-screen">
                <%- include("partials/sidebar", {
                    navItems: sidebarNavItems,
                    activeRoute: layoutActiveRoute,
                    currentUser: layoutCurrentUser,
                }) %>
                <main class="min-h-screen min-w-0 w-full flex-1">
                    <%- include("partials/topbar", {
                        currentUser: layoutCurrentUser,
                        todayLabel: layoutTodayLabel,
                    }) %>
                    <section
                        class="min-h-[calc(100dvh-5rem)] bg-brand-bg px-4 py-6 sm:px-6 md:px-8
                            lg:px-10"
                    >
                        <%- include("partials/flash") %>
                        <%- body %>
                    </section>
                </main>
            </div>
        <% } %>
        <%- include("partials/shared/helpPanel", {
            pageHelpKey: typeof pageHelpKey !== 'undefined' ? pageHelpKey : ''
        }) %>
        <script src="/js/main.js"></script>
        <script src="/js/helpPanel.js"></script>
    </body>
</html>
