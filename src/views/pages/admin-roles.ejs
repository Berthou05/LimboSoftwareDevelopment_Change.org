<%# Template: pages/rolesAdmin.ejs
   Purpose: Admin panel for role privilege toggles.
   Expected locals: roles, privilegesCatalog.
   Matrix layout: each row is a privilege, each column is a role, each cell toggles assignment.
%>
<div id="flash-container"></div>
<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="font-heading text-xl font-bold">Roles Administration</h2>
    <button
      type="button"
      class="rounded-xl border-2 border-brand-primary bg-brand-primary px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:border-brand-accent hover:bg-brand-accent">
      Create Role
    </button>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-brand-secondary/70 text-sm">
      <thead>
        <tr class="text-left text-brand-text/70">
          <th class="px-3 py-2">Privilege</th>
          <% roles.forEach((role) => { %>
            <th class="px-3 py-2">
              <div class="flex items-center gap-2 group">
              <%= role.name %>
              <%- include('../partials/shared/actionButton', {
                            buttonPopupOpen: 'delete-role-' + role.id,
                            buttonIcon: 'trash',
                            buttonVariant: 'icon-only',
                            buttonClasses: 'opacity-0 group-hover:opacity-100 transition-opacity border-red-200 text-red-500',
                            actionTone: 'danger'
                        }) %>
              </div>
            </th>
            <% }) %>          
        </tr>

      </thead>
      <tbody class="divide-y divide-brand-secondary/60">
        <%# Row loop: one row per privilege from repository catalog. %>
        <% privilegesCatalog.forEach((privilege) => { %>
          <tr>
            <td class="px-3 py-3">
              <p class="font-semibold"><%= privilege.code %></p>
              <p class="text-xs text-brand-text/70"><%= privilege.name %></p>
            </td>
            <%# Cell loop: ON/OFF indicates whether the current role contains this privilege code. %>
            <% roles.forEach((role) => { const enabled = role.privilegeCodes.includes(privilege.code); %>
              <td class="px-3 py-3">
                <form 
                  action="/admin/roles/<%= role.id %>/<%= privilege.code %>/toggle" 
                  method="POST"
                  class="toggle-form"
                  data-role-id="<%= privilege.code %>"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button
                    type="submit"
                    class="toggle-btn inline-flex min-w-20 justify-center rounded-full px-3 py-1 text-xs font-semibold transition <%= enabled ? 'bg-brand-primary text-white' : 'bg-brand-secondary/50 text-brand-text/70 hover:bg-brand-secondary' %>"
                  >
                    <%= enabled ? "ON" : "OFF" %>
                  </button>
                </form>
              </td>
            <% }) %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% roles.forEach((role) => { %>
  <%- include('../partials/shared/actionPopup', {
      dataAction: 'delete-roles',
      popupId: 'delete-role-' + role.id,
      popupTitle: 'Delete Role',
      popupDescription: 'Confirm if you want to remove this role from the system.',
      popupAction: '/admin/roles/' + role.id + '/remove',
      popupMethod: 'POST',
      csrfToken,
      popupFields: [],
      popupSubmitLabel: 'Delete',
      popupSubmitTone: 'danger',
  }) %>
<% }) %>
</section>

<script src="/js/adminRoles.js"></script>
