<%# Template: pages/account.ejs
   Purpose: Signed-in user account settings page.
%>

<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<% const editingAccount = typeof isEditing !== "undefined" && isEditing; %>

<% const accountInputClass = editingAccount
  ? "w-full rounded-xl border border-brand-secondary bg-white px-3 py-2 outline-none ring-brand-primary/30 focus:ring disabled:opacity-100"
  : "w-full rounded-xl border border-transparent bg-white px-3 py-2 outline-none disabled:cursor-default disabled:bg-white disabled:text-brand-text disabled:opacity-100";
%>

<% const initials = account.names
  ? (account.names + ' ' + (account.lastnames || ''))
      .split(' ')
      .map(p => p[0])
      .slice(0, 2)
      .join('')
      .toUpperCase()
  : '?'; %>

<section class="max-w-3xl rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h2 class="font-heading text-xl font-bold">Account Information</h2>

    <% if (editingAccount) { %>
      <div class="flex flex-wrap gap-3">
        <button
          type="submit"
          form="accountForm"
          class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
        >
          Save
        </button>

        <a
          href="/account"
          class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30"
        >
          Cancel
        </a>
      </div>
    <% } else { %>
      <a
        href="/account/<%= account.id %>/edit"
        class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
      >
        Edit
      </a>
    <% } %>
  </div>

  <form id="accountForm" action="/account/<%= account.id %>/edit" method="POST" enctype="multipart/form-data" class="mt-4 grid gap-4 md:grid-cols-[minmax(0,1fr)_12rem]">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <!-- LEFT -->
    <div class="grid gap-4 sm:grid-cols-2 md:col-span-1">

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Names</span>
        <input type="text" name="names" value="<%= account.names %>" required <%= editingAccount ? "" : "disabled" %> class="<%= accountInputClass %>" />
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Last names</span>
        <input type="text" name="lastnames" value="<%= account.lastnames %>" required <%= editingAccount ? "" : "disabled" %> class="<%= accountInputClass %>" />
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Email</span>
        <input type="email" name="email" value="<%= account.email %>" required <%= editingAccount ? "" : "disabled" %> class="<%= accountInputClass %>" />
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Slack username</span>
        <input type="text" name="slackUsername" value="<%= account.slackUsername %>" <%= editingAccount ? "" : "disabled" %> class="<%= accountInputClass %>" />
      </label>

    </div>

    <!-- RIGHT (AVATAR FIXED) -->
    <div class="block text-sm md:justify-self-center">
      <span class="mb-3 block text-brand-text/70">Profile picture</span>

      <input id="accountImageFile" type="file" name="image" accept="image/*" <%= editingAccount ? "" : "disabled" %> class="sr-only" />
      <input id="accountImageValue" type="hidden" name="currentImage" value="<%= account.image %>" />
      <p id="accountImageFilename" class="sr-only">No file selected</p>

      <div class="relative inline-flex flex-col items-start">

        <!-- Avatar container -->
        <div class="relative h-36 w-36 rounded-full border border-brand-secondary overflow-hidden">

          <!-- Fallback -->
          <div class="app-directory-avatar absolute inset-0 flex items-center justify-center !text-brand-primary text-3xl font-bold">
            <%= initials %>
          </div>

          <!-- Image -->
          <img
            id="accountImagePreview"
            src="<%= account.image %>"
            data-default-image="<%= account.defaultImage %>"
            alt="Account preview"
            class="absolute inset-0 h-full w-full object-cover"
            onerror="this.style.display='none'"
          />

        </div>

        <!-- Edit button -->
        <div class="relative -mt-8 ml-3">
          <button
            <% if (editingAccount) { %>
              id="accountImageMenuButton"
              type="button"
              aria-expanded="false"
              aria-controls="accountImageMenu"
            <% } else { %>
              type="button"
              disabled
              aria-hidden="true"
              tabindex="-1"
            <% } %>
            class="inline-flex items-center gap-2 rounded-lg border border-brand-secondary bg-white px-3 py-2 text-sm font-semibold text-brand-text shadow-sm hover:bg-white focus-visible:ring-2 focus-visible:ring-brand-nav/20 <%= editingAccount ? "" : "pointer-events-none invisible" %>"
          >
            Edit
          </button>

          <% if (editingAccount) { %>
            <div id="accountImageMenu" class="absolute left-0 top-full z-20 mt-2 hidden w-52 overflow-hidden rounded-lg border border-brand-secondary bg-white text-sm shadow-sm">
              <button id="accountImageUploadButton" type="button" class="block w-full bg-brand-nav px-4 py-3 text-left font-semibold text-white hover:bg-brand-nav/90">
                Upload a photo...
              </button>
              <button id="accountImageRemoveButton" type="button" class="block w-full px-4 py-3 text-left font-semibold text-brand-text hover:bg-brand-secondary/20">
                Remove photo
              </button>
            </div>
          <% } %>
        </div>

      </div>
    </div>

    <!-- PASSWORD -->
    <div class="text-sm md:col-span-1">
      <p class="font-semibold text-brand-text">Password</p>
      <p class="mt-1 text-brand-text/70">
        Click the button to request a password change.
      </p>
      <a
        href="/reset"
        class="mt-3 inline-flex rounded-xl border border-brand-primary px-3 py-2 text-xs font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white"
      >
        Request Password Change
      </a>
    </div>

  </form>
</section>

<% if (editingAccount) { %>
  <script src="/js/accountImagePreview.js"></script>
<% } %>