<%# Template: pages/account.ejs
   Purpose: Signed-in user account settings page.
   Expected locals: account.
   Data flow: accountImagePreview.js previews the selected image; multer stores the uploaded file.
%>

<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>
<% const editingAccount = typeof isEditing !== "undefined" && isEditing; %>

<section class="max-w-3xl rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h2 class="font-heading text-xl font-bold">Account Information</h2>
    <% if (!editingAccount) { %>
      <a
        href="/account/<%= account.id %>/edit"
        class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
      >
        Edit
      </a>
    <% } %>
  </div>

  <form action="/account/<%= account.id %>/edit" method="POST" enctype="multipart/form-data" class="mt-4 grid gap-4 sm:grid-cols-2">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <label class="block text-sm">
      <span class="mb-1 block text-brand-text/70">Names</span>
      <input
        type="text"
        name="names"
        value="<%= account.names %>"
        required
        <%= editingAccount ? "" : "disabled" %>
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
    </label>

    <label class="block text-sm">
      <span class="mb-1 block text-brand-text/70">Last names</span>
      <input
        type="text"
        name="lastnames"
        value="<%= account.lastnames %>"
        required
        <%= editingAccount ? "" : "disabled" %>
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
    </label>

    <label class="block text-sm sm:col-span-2">
      <span class="mb-1 block text-brand-text/70">Email</span>
      <input
        type="email"
        name="email"
        value="<%= account.email %>"
        required
        <%= editingAccount ? "" : "disabled" %>
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
    </label>

    <label class="block text-sm">
      <span class="mb-1 block text-brand-text/70">Slack username</span>
      <input
        type="text"
        name="slackUsername"
        value="<%= account.slackUsername %>"
        <%= editingAccount ? "" : "disabled" %>
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
    </label>

    <label class="block text-sm">
      <span class="mb-1 block text-brand-text/70">Profile Image</span>
      <input
        id="accountImageFile"
        type="file"
        name="image"
        accept="image/*"
        <%= editingAccount ? "" : "disabled" %>
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
      <input id="accountImageValue" type="hidden" name="currentImage" value="<%= account.image %>" />
      <p id="accountImageFilename" class="mt-1 text-xs text-brand-text/65">No file selected</p>
    </label>

    <div class="flex items-center justify-center rounded-xl border border-brand-secondary bg-brand-bg p-3">
      <img
        id="accountImagePreview"
        src="<%= account.image %>"
        alt="Account preview"
        class="h-20 w-20 rounded-full border border-brand-secondary object-cover"
      />
    </div>

    <div class="rounded-xl border border-brand-secondary bg-brand-bg p-4 text-sm sm:col-span-2">
      <p class="font-semibold text-brand-text">Password</p>
      <p class="mt-1 text-brand-text/70">
        Password changes are not available in this screen.
      </p>
      <a
        href="/recover"
        class="mt-3 inline-flex rounded-xl border border-brand-primary px-3 py-2 text-xs font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white"
      >
        Request Password Change
      </a>
    </div>

    <% if (editingAccount) { %>
      <div class="flex flex-wrap gap-3 sm:col-span-2">
        <button
          type="submit"
          class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
        >
          Save
        </button>
        <a
          href="/account"
          class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30"
        >
          Cancel
        </a>
      </div>
    <% } %>
  </form>
</section>

<% if (editingAccount) { %>
  <script src="/js/accountImagePreview.js"></script>
<% } %>
