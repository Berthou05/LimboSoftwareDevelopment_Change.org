<%# Template: pages/accountsAdmin.ejs
   Purpose: Admin table for account role/status management.
   Expected locals: accounts, totalAccounts, roles, roleFilter, statusFilter, currentDateLabel, currentQuarterLabel.
   Data source: admin.controller applies role/status filters before rendering table rows.
%>

<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <a
      href="/admin/accounts/create"
      class="rounded-xl border-2 border-brand-primary bg-brand-primary px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:border-brand-accent hover:bg-brand-accent"
    >
      Create Account
    </a>

    <%# These links perform server-side filtering via query params (role/status). %>
    <div class="flex flex-wrap gap-2 text-xs font-semibold">
      <a
        href="/admin/accounts?role=employee&status=<%= statusFilter %>"
        data-filter-group="role"
        data-filter-value="employee"
        class="app-breadcrumb <%= roleFilter === 'employee' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>"
      >
        Employee
      </a>
      <a
        href="/admin/accounts?role=lead&status=<%= statusFilter %>"
        data-filter-group="role"
        data-filter-value="lead"
        class="app-breadcrumb <%= roleFilter === 'lead' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>"
      >
        Lead
      </a>
      <a
        href="/admin/accounts?role=<%= roleFilter %>&status=active"
        data-filter-group="status"
        data-filter-value="active"
        class="app-breadcrumb <%= statusFilter === 'active' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>"
      >
        Active
      </a>
      <a
        href="/admin/accounts?role=<%= roleFilter %>&status=disabled"
        data-filter-group="status"
        data-filter-value="disabled"
        class="app-breadcrumb <%= statusFilter === 'disabled' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>"
      >
        Disabled
      </a>
      <a
        href="/admin/accounts?role=all&status=all"
        data-filter-group="all"
        class="app-breadcrumb <%= roleFilter === 'all' && statusFilter === 'all' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>"
      >
        All
      </a>
    </div>
  </div>

  <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
      <h2 class="font-heading text-xl font-bold text-brand-text">Accounts</h2>
      <span class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
        <%= accounts.length %> of <%= totalAccounts %> shown
      </span>
    </div>

    <div class="space-y-2 overflow-x-auto">
      <div class="grid min-w-[860px] grid-cols-[1.7fr_1.7fr_1.3fr_0.9fr_0.9fr_0.9fr] gap-2 rounded-xl border border-brand-secondary bg-brand-bg px-3 py-2 text-xs font-bold uppercase tracking-wide text-brand-text/65">
        <p>Full Name</p>
        <p>Email</p>
        <p>Slack Username</p>
        <p>Role</p>
        <p>Status</p>
        <p>Created at</p>
      </div>

      <% if (!accounts.length) { %>
        <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
          No accounts match current filters.
        </p>
      <% } %>

      <% accounts.forEach((account) => { %>
        <div class="grid min-w-[860px] grid-cols-[1.7fr_1.7fr_1.3fr_0.9fr_0.9fr_0.9fr] items-center gap-2 rounded-xl border border-brand-secondary px-3 py-2 text-sm">
          <p class="font-medium"><%= account.employee?.fullName || "Unknown" %></p>
          <p class="truncate text-brand-text/80"><%= account.email %></p>
          <p class="font-medium text-brand-text/80"><%= account.slackUsername %></p>

          <%# AJAX role update — no page reload, handles all server responses %>
          <div class="min-w-0">
            <select
              name="roleId"
              data-account-id="<%= account.id %>"
              data-csrf="<%= csrfToken %>"
              class="role-select w-full rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold outline-none ring-brand-primary/30 focus:ring"
            >
              <% roles.forEach((role) => { %>
                <option value="<%= role.id %>" <%= role.id === account.roleId ? 'selected' : '' %>>
                  <%= role.name %>
                </option>
              <% }) %>
            </select>
            <%# Inline feedback appears here without reloading the page %>
            <p class="role-feedback mt-1 hidden text-xs font-semibold"></p>
          </div>

          <%# Same inline update pattern for status to reduce admin clicks. %>
          <select
            name="status"
            data-account-id="<%= account.id %>"
            data-csrf="<%= csrfToken %>"
            class="status-select w-full rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold"
          >
            <option value="ACTIVE" <%= account.status === 'ACTIVE' ? 'selected' : '' %>>Active</option>
            <option value="DISABLED" <%= account.status === 'DISABLED' ? 'selected' : '' %>>Disabled</option>
          </select>

          <p class="status-feedback mt-1 hidden text-xs font-semibold"></p>

          <p class="text-xs font-semibold text-brand-text/70">
            <%= account.createdAt ? new Date(account.createdAt).toLocaleDateString("en-US") : "10/12/2024" %>
          </p>
        </div>
      <% }) %>
    </div>
  </section>
</div>

<script>
  (function syncAccountFilterBreadcrumbs() {
    const params = new URLSearchParams(window.location.search);
    const role = String(params.get('role') || 'all').trim().toLowerCase();
    const status = String(params.get('status') || 'all').trim().toLowerCase();

    const setState = (element, active) => {
      element.classList.toggle('app-breadcrumb--active', active);
      element.classList.toggle('app-breadcrumb--interactive', !active);
    };

    document.querySelectorAll('[data-filter-group="role"]').forEach((element) => {
      setState(element, element.getAttribute('data-filter-value') === role);
    });

    document.querySelectorAll('[data-filter-group="status"]').forEach((element) => {
      setState(element, element.getAttribute('data-filter-value') === status);
    });

    document.querySelectorAll('[data-filter-group="all"]').forEach((element) => {
      setState(element, role === 'all' && status === 'all');
    });
  })();
</script>
<script src="/js/adminAccounts.js"></script>
