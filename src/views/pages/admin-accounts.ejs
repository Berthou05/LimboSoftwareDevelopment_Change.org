<%# Template: pages/accountsAdmin.ejs
   Purpose: Admin table for account role/status management.
   Expected locals: accounts, totalAccounts, roles, roleFilter, statusFilter, currentDateLabel, currentQuarterLabel.
   Data source: admin.controller applies role/status filters before rendering table rows.
%>

<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <button
      type="button"
      class="rounded-xl border border-brand-primary px-5 py-2 text-sm font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white"
    >
    Create Account
    </button>

    <%# These links perform server-side filtering via query params (role/status). %>
    <div class="flex flex-wrap gap-2 text-xs font-semibold">
      <a
        href="/admin/accounts?role=employee&status=<%= statusFilter %>"
        class="rounded-full border px-3 py-1 transition <%= roleFilter === 'employee' ? 'border-brand-primary bg-brand-primary text-white' : 'border-brand-secondary text-brand-text/80 hover:bg-brand-secondary/20' %>"
      >
        Employee
      </a>
      <a
        href="/admin/accounts?role=lead&status=<%= statusFilter %>"
        class="rounded-full border px-3 py-1 transition <%= roleFilter === 'lead' ? 'border-brand-primary bg-brand-primary text-white' : 'border-brand-secondary text-brand-text/80 hover:bg-brand-secondary/20' %>"
      >
        Lead
      </a>
      <a
        href="/admin/accounts?role=<%= roleFilter %>&status=active"
        class="rounded-full border px-3 py-1 transition <%= statusFilter === 'active' ? 'border-brand-primary bg-brand-primary text-white' : 'border-brand-secondary text-brand-text/80 hover:bg-brand-secondary/20' %>"
      >
        Active
      </a>
      <a
        href="/admin/accounts?role=<%= roleFilter %>&status=disabled"
        class="rounded-full border px-3 py-1 transition <%= statusFilter === 'disabled' ? 'border-brand-primary bg-brand-primary text-white' : 'border-brand-secondary text-brand-text/80 hover:bg-brand-secondary/20' %>"
      >
        Disabled
      </a>
      <a
        href="/admin/accounts?role=all&status=all"
        class="rounded-full border px-3 py-1 transition <%= roleFilter === 'all' && statusFilter === 'all' ? 'border-brand-primary bg-brand-primary text-white' : 'border-brand-secondary text-brand-text/80 hover:bg-brand-secondary/20' %>"
      >
        All
      </a>
    </div>
  </div>

  <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
      <h2 class="font-heading text-xl font-bold text-brand-text">Accounts</h2>
      <span class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
        <%= accounts.length %> of <%= totalAccounts %> shown
      </span>
    </div>

    <div class="space-y-2 overflow-x-auto">
      <div class="grid min-w-[980px] grid-cols-[1fr_1.7fr_1.7fr_1.3fr_0.9fr_0.9fr_0.9fr] gap-2 rounded-xl border border-brand-secondary bg-brand-bg px-3 py-2 text-xs font-bold uppercase tracking-wide text-brand-text/65">
        <p>Account ID</p>
        <p>Full Name</p>
        <p>Email</p>
        <p>Slack Username</p>
        <p>Role</p>
        <p>Status</p>
        <p>Created at</p>
      </div>

      <% if (!accounts.length) { %>
        <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
          No accounts match current filters.
        </p>
      <% } %>

      <% accounts.forEach((account) => { %>
        <div class="grid min-w-[980px] grid-cols-[1fr_1.7fr_1.7fr_1.3fr_0.9fr_0.9fr_0.9fr] items-center gap-2 rounded-xl border border-brand-secondary px-3 py-2 text-sm">
          <p class="font-semibold text-brand-text/80"><%= String(account.id || "").toUpperCase() %></p>
          <p class="font-medium"><%= account.employee?.fullName || "Unknown" %></p>
          <p class="truncate text-brand-text/80"><%= account.email %></p>
          <p class="font-medium text-brand-text/80"><%= account.slackUsername %></p>

          <%# Select auto-submits to update role quickly without a separate "Save" button. %>
          <form action="/admin/accounts/<%= account.id %>/role" method="POST" class="min-w-0">
            <select
              name="roleId"
              class="w-full rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold outline-none ring-brand-primary/30 focus:ring"
              onchange="this.form.submit()"
            >
              <% roles.forEach((role) => { %>
                <option value="<%= role.id %>" <%= role.id === account.roleId ? 'selected' : '' %>><%= role.name %></option>
              <% }) %>
            </select>
          </form>

          <%# Same inline update pattern for status to reduce admin clicks. %>
          <form action="/admin/accounts/<%= account.id %>/status" method="POST" class="min-w-0">
            <select
              name="status"
              class="w-full rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold outline-none ring-brand-primary/30 focus:ring"
              onchange="this.form.submit()"
            >
              <option value="ACTIVE" <%= account.status === 'ACTIVE' ? 'selected' : '' %>>Active</option>
              <option value="DISABLED" <%= account.status === 'DISABLED' ? 'selected' : '' %>>Disabled</option>
            </select>
          </form>

          <p class="text-xs font-semibold text-brand-text/70">
            <%= account.createdAt ? new Date(account.createdAt).toLocaleDateString("en-US") : "10/12/2024" %>
          </p>
        </div>
      <% }) %>
    </div>
  </section>
</div>