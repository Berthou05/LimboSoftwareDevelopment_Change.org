        <div class="mx-auto max-w-7xl p-6">
            <% const homeAccount = (typeof account !== 'undefined' && account) ? account : {}; %>
            <% const homeEmployeeName =
                (typeof employee !== 'undefined' && employee && employee.names)
                || (typeof user !== 'undefined' && user && user.username)
                || 'Usuario'; %>
            <%# Keep the greeting short on home and fall back to the full name when no separator exists. %>
            <% const homeEmployeeFirstName = homeEmployeeName.split(' ')[0] || homeEmployeeName; %>
            <% const homeAccountImage = homeAccount.image || `https://ui-avatars.com/api/?name=${encodeURIComponent(homeEmployeeName)}&background=fbfbfe&color=1f2937`; %>
            <% const homeReportSubjects = typeof reportSubjects !== 'undefined' ? reportSubjects : { employees: [], teams: [], projects: [] }; %>
            <% const homeLatestReports = typeof latestReports !== 'undefined' ? latestReports : {}; %>
            <% const homeCsrfToken = typeof csrfToken !== 'undefined' ? csrfToken : ''; %>

            <div class="grid gap-4 sm:gap-6 lg:grid-cols-[2fr_1fr]">
                <section class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel sm:p-5 lg:col-span-2">
                    <div class="flex items-center gap-3 sm:gap-4">
                        <div class="h-10 w-10 shrink-0 overflow-hidden rounded-full border border-brand-secondary bg-brand-bg sm:h-12 sm:w-12">
                            <img src="<%= homeAccountImage %>" alt="Profile" class="h-full w-full object-cover">
                        </div>
                        <h1 class="font-heading text-xl font-bold text-brand-text sm:text-2xl lg:text-4xl">
                            Welcome, <%= homeEmployeeFirstName %>
                        </h1>
                    </div>
                </section>

                <section class="space-y-4 sm:space-y-6">
                    <%- include('../partials/reportGenerator/reportGenerator', {
                        layout: 'full',
                        redirectTo: '/home',
                        defaultReportType: 'EMPLOYEE',
                        defaultSubjectId: '',
                        reportSubjects: homeReportSubjects,
                        latestReports: homeLatestReports,
                        quickReport: '',
                        csrfToken: homeCsrfToken
                    }) %>

                    <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel sm:p-5">
                        <h2 class="font-heading text-xl font-bold text-brand-text sm:text-2xl lg:text-3xl">Your Latest Activity</h2>

                        <button
                            type="button"
                            class="mt-4 inline-flex rounded-xl border border-brand-secondary bg-brand-bg px-4 py-2 text-sm font-semibold text-brand-text transition hover:bg-brand-secondary/30"
                        >
                            Add Daily Entry
                        </button>

                        <div class="mt-4 space-y-4">
                            <% if (!(latestActivitySections || []).length) { %>
                                <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
                                    No recent activity.
                                </p>
                            <% } %>

                            <%# Sections are already grouped and sorted in controller. %>
                            <% (latestActivitySections || []).forEach((section) => { %>
                                <p class="inline-flex rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
                                    <%= section.dayLabel %>
                                </p>
                                <% section.items.forEach((item) => { %>
                                    <article class="rounded-xl border border-brand-secondary/70 p-4">
                                        <div class="flex items-start gap-3">
                                            <div class="mt-1 h-5 w-5 rounded-full border border-brand-secondary"></div>
                                            <div class="flex-1">
                                                <h3 class="font-heading text-base font-bold text-brand-text"><%= item.title %></h3>
                                                <p class="mt-2 text-sm text-brand-text/80"><%= item.description || item.content %></p>
                                            </div>
                                        </div>
                                    </article>
                                <% }) %>
                            <% }) %>
                        </div>
                    </article>
                </section>

                <section class="space-y-6">
                    <div class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
                        <h2 class="font-heading text-lg font-semibold text-brand-text">Team Activity</h2>
                    </div>

                    <div class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
                        <h2 class="font-heading text-lg font-semibold text-brand-text">Your Projects</h2>
                    </div>
                </section>
            </div>
        </div>
