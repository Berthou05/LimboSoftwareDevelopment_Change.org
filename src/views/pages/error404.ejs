<section class="mx-auto flex min-h-[60vh] w-full max-w-4xl items-center justify-center px-4 py-12 text-center">
    <div class="w-full max-w-3xl">
        <p class="app-brand-title text-sm font-semibold uppercase tracking-wider">404</p>
        <h1 class="mt-2 font-heading text-4xl font-semibold leading-tight tracking-tight text-brand-text">
            Something's missing.
        </h1>
        <p class="mt-3 text-sm text-brand-text/70">
            Sorry, we can't find that page. You'll find lots to explore on the home page.
        </p>
        <a
            href="<%= typeof isLoginPage !== 'undefined' && isLoginPage ? '/' : '/home' %>"
            class="mt-6 inline-flex rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
        >
            Back to Homepage
        </a>
    </div>
</section>
