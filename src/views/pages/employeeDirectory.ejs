<%- include('../partials/pageHeader', { title: pageTitle, subtitle: pageSubtitle }) %>

<section
    data-employee-directory
    data-search-endpoint="/employees/search"
    data-search-debounce-ms="250"
>
    <form
        action="/employees"
        method="GET"
        class="mb-3 flex flex-wrap items-start gap-2"
        data-employee-directory-form
    >
        <div class="relative w-full max-w-xl">
            <input
                type="text"
                name="q"
                value="<%= query || '' %>"
                placeholder="Search employees..."
                autocomplete="off"
                aria-autocomplete="list"
                aria-controls="employeeDirectorySuggestions"
                aria-expanded="false"
                class="w-full rounded-xl border border-brand-secondary bg-white px-4 py-3 text-sm
                    text-brand-text outline-none ring-brand-primary/30 focus:ring"
                data-employee-directory-input
            />
            <div
                id="employeeDirectorySuggestions"
                role="listbox"
                class="absolute left-0 right-0 top-[calc(100%+0.5rem)] z-20 hidden overflow-hidden
                    rounded-2xl border border-brand-secondary bg-white shadow-panel"
                data-employee-directory-suggestions
            ></div>
        </div>
        <button
            type="submit"
            class="rounded-xl bg-brand-primary px-5 py-3 text-sm font-semibold text-white
                transition hover:bg-brand-accent"
        >
            Search
        </button>
    </form>

    <p
        class="mb-6 hidden text-sm text-brand-text/60"
        data-employee-directory-status
        aria-live="polite"
    ></p>

    <div
        data-employee-directory-results
        data-total-employees="<%= employees?.length || 0 %>"
    >
        <%- include('../partials/employeeDirectory/employeeDirectoryResults', {
            employees,
        }) %>
    </div>
</section>

<script src="/js/employeeDirectorySearch.js"></script>
