<%
  const canDeleteTeam = Boolean(
    team?.lead?.id
    && typeof currentEmployeeId !== 'undefined'
    && currentEmployeeId
    && team.lead.id === currentEmployeeId
  );
  const canEditTeam = canDeleteTeam;
%>

<%- include('../partials/shared/backButton', { fallbackUrl: '/teams' }) %>

<div class="grid gap-4 sm:gap-6 md:grid-cols-[2fr_1fr]">
  <section class="space-y-6">
    <div class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
      <%- include('../partials/teamDirectory/teamDetailsCard', { team, csrfToken, canEditTeam }) %>
    </div>

    <%- include('../partials/teamDirectory/teamProjects', { team }) %>

    <%- include('../partials/teamDirectory/teamActivity', {
      team,
      activityFilter: typeof activityFilter !== 'undefined'
        ? activityFilter
        : { preset: 'month', startDate: '', endDate: '', hasManualRange: false, isFiltered: true },
      activityError: typeof activityError !== 'undefined' ? activityError : '',
      activitySections: typeof activitySections !== 'undefined' ? activitySections : []
    }) %>
  </section>

  <section class="space-y-4">
    <% if(hasPermission('TEAM-06-01') || hasPermission('TEAM-07-01')) {%>
      <%- include('../partials/teamDirectory/joinButton', {
        team,
        isMember: typeof isMember !== 'undefined' ? isMember : false,
        csrfToken
      }) %>
    <% } %>

    <% if(hasPermission('REP-01')) {%>
      <%- include('../partials/reportGenerator/reportGenerator', {
        redirectTo: '/teams/' + (team?.id || ''),
        defaultReportType: typeof defaultReportType !== 'undefined' ? defaultReportType : 'TEAM',
        defaultSubjectId: typeof defaultSubjectId !== 'undefined' ? defaultSubjectId : (team?.id || ''),
        reportSubjects: typeof reportSubjects !== 'undefined' ? reportSubjects : { employees: [], teams: [], projects: [] },
        latestReports: typeof latestReports !== 'undefined' ? latestReports : {},
        quickReport: typeof quickReport !== 'undefined' ? quickReport : '',
      }) %>
    <% } %>

    <%- include('../partials/teamDirectory/teamParticipants', {
      team,
      csrfToken,
      currentEmployeeId: typeof currentEmployeeId !== 'undefined' ? currentEmployeeId : null,
      availableEmployees: typeof availableEmployees !== 'undefined' ? availableEmployees : [],
      canAddTeamMembers: typeof canAddTeamMembers !== 'undefined' ? canAddTeamMembers : false,
      canManageTeamMembers: typeof canManageTeamMembers !== 'undefined' ? canManageTeamMembers : false
    }) %>

    <%- include('../partials/teamDirectory/teamBlockers', {
      team,
      activityFilter: typeof activityFilter !== 'undefined'
        ? activityFilter
        : { preset: 'month', startDate: '', endDate: '', hasManualRange: false, isFiltered: true },
      blockerFilter: typeof blockerFilter !== 'undefined'
        ? blockerFilter
        : { preset: 'month' },
      blockerSummary: typeof blockerSummary !== 'undefined'
        ? blockerSummary
        : { totalCount: 0, hasData: false, items: [] },
      blockerError: typeof blockerError !== 'undefined' ? blockerError : ''
    }) %>
    
  </section>
</div>

<% if (canDeleteTeam) { %>
  <div data-popup="delete-team-<%= team?.id || '' %>" class="fixed inset-0 z-50 hidden bg-brand-text/35 px-4 py-8">
    <div class="mx-auto max-w-lg">
      <div class="rounded-3xl border border-brand-secondary bg-white p-6 shadow-panel">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="font-heading text-2xl font-bold text-brand-text">Delete Team</h3>
            <p class="mt-1 text-sm text-brand-text/60">
              This will disable the team and remove it from active team listings. This action cannot be undone from this screen.
            </p>
          </div>
          <%- include('../partials/shared/actionButton', {
            buttonPopupClose: true,
            buttonIcon: 'close',
            buttonVariant: 'icon-only',
            buttonClasses: 'shrink-0',
            buttonAriaLabel: 'Close popup',
          }) %>
        </div>

        <form
          action="/team/<%= team?.id || '' %>/delete"
          method="POST"
          data-team-delete-form
          data-error-message="The team could not be deleted right now."
          class="mt-5 space-y-4"
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="flex flex-wrap justify-end gap-3 pt-2">
            <button
              type="button"
              data-popup-close
              class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="rounded-xl border border-brand-accent bg-brand-accent px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent/90"
            >
              Delete
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
<% } %>

<script src="/js/teamDetails.js"></script>
<script src="/js/dateRangePicker.js"></script>
<script src="/js/activityFilters.js"></script>
<script src="/js/blockerFilters.js?v=2"></script>
