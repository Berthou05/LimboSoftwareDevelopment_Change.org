<%# Template: pages/teamDirectory.ejs
   Purpose: Team directory/list screen.
   Expected locals: pageTitle, pageSubtitle, myTeams, otherTeams, query.
   Data source: teams.controller filters in backend and re-renders with the same `query`.
%>

<%- include("../partials/pageHeader", { title: pageTitle, subtitle: typeof pageSubtitle !== 'undefined' ? pageSubtitle : '' }) %>

<section
    data-team-directory
    data-search-endpoint="/teams/search"
    data-search-debounce-ms="250"
>
    <form
        action="/teams"
        method="GET"
        class="mb-3 flex flex-wrap items-start gap-2"
        data-team-directory-form
    >
        <div class="relative w-full max-w-xl">
            <input
                type="text"
                name="q"
                value="<%= query || '' %>"
                placeholder="Search teams..."
                autocomplete="off"
                aria-autocomplete="list"
                aria-controls="teamDirectorySuggestions"
                aria-expanded="false"
                class="w-full rounded-xl border border-brand-secondary bg-white px-4 py-2 text-sm
                    text-brand-text outline-none ring-brand-primary/30 focus:ring"
                data-team-directory-input
            />
            <div
                id="teamDirectorySuggestions"
                role="listbox"
                class="absolute left-0 right-0 top-[calc(100%+0.5rem)] z-20 hidden overflow-hidden
                    rounded-2xl border border-brand-secondary bg-white shadow-panel"
                data-team-directory-suggestions
            ></div>
        </div>
        <button
            type="submit"
            class="rounded-xl bg-brand-primary px-5 py-2 text-sm font-semibold text-black
                transition hover:bg-brand-accent"
        >
            Search
        </button>
        <a
            href="/team/new"
            class="ml-auto rounded-xl border border-brand-secondary bg-white px-5 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30"
        >
            Create team
        </a>
    </form>

    <p
        class="mb-6 hidden text-sm text-brand-text/60"
        data-team-directory-status
        aria-live="polite"
    ></p>

    <div
        data-team-directory-results
        data-total-teams="<%= (myTeams?.length || 0) + (otherTeams?.length || 0) %>"
    >
        <%- include('../partials/teamDirectory/teamDirectoryResults', {
            myTeams,
            otherTeams,
            csrfToken,
            currentEmployeeId,
        }) %>
    </div>
</section>

<script src="/js/teamDirectorySearch.js"></script>
<script src="/js/teamDetails.js"></script>
