<%
    const selectedProjectId = typeof selectedActivityProjectId !== 'undefined'
        ? selectedActivityProjectId
        : '';
%>

<%- include('../partials/shared/backButton', { fallbackUrl: '/employees' }) %>

<div class="grid gap-6 md:grid-cols-[2fr_1fr]">
    <section class="space-y-6">
        <div class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel gap-4">
            <div class="flex flex-wrap items-center gap-4 mb-4">
                <div class="relative h-16 w-16 shrink-0">
                    <% const initials = employee.full_name
                        ? employee.full_name.split(' ').map(p => p[0]).slice(0, 2).join('').toUpperCase()
                        : '?'; %>

                    <!-- Fallback -->
                    <div class="app-directory-avatar flex h-16 w-16 items-center justify-center rounded-full text-base font-bold">
                        <%= initials %>
                    </div>

                    <!-- Image -->
                    <img
                        src="<%= employee.image %>"
                        alt="<%= employee.full_name %>"
                        class="absolute inset-0 h-16 w-16 rounded-full border border-brand-secondary object-cover"
                        onerror="this.style.display='none'"
                    />
                </div>
                <div class="flex-1 min-w-0">
                    <h1 class="font-heading text-2xl font-bold text-brand-text sm:text-3xl"><%= employee.full_name %></h1>
                </div>
            </div>

            <div class="flex flex-wrap gap-2 text-xs text-brand-text/70">
                <span class="app-breadcrumb app-breadcrumb--static">
                    Email <%= employee.email || 'No email available' %>
                </span>
                <span class="app-breadcrumb app-breadcrumb--static">
                    Slack <%= employee.slack_username || 'No Slack username available'  %>
                </span>
                <% if (employee.accountCreatedAtLabel) { %>
                    <span class="app-breadcrumb app-breadcrumb--static">
                        Own Profile
                    </span>
                <% } %>
            </div>
                    
        </div>

        <article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div class="flex min-w-0 flex-wrap items-center gap-3">
                    <h2 class="font-heading text-xl font-semibold text-brand-text">Your Activity</h2>
                    <form action="/employees/<%= employee.employee_id %>" method="GET">
                        <input type="hidden" name="activityPreset" value="<%= activityFilter?.preset || '' %>">
                        <label class="inline-block max-w-36 text-sm">
                            <select
                                name="projectId"
                                onchange="this.form.submit()"
                                class="block w-full min-w-0 appearance-none truncate border-0 border-b border-brand-secondary bg-transparent pb-1 pr-4 text-xs font-semibold text-brand-text/60 outline-none ring-0 focus:border-brand-secondary focus:ring-0"
                            >
                                <option value="">All</option>
                                <option value="general" <%= selectedProjectId === 'general' ? 'selected' : '' %>>General Activity</option>
                                <% (projectRows || []).forEach((row) => { %>
                                    <option value="<%= row.project.id %>" <%= selectedProjectId === String(row.project.id) ? 'selected' : '' %>>
                                        <%= row.project.name %>
                                    </option>
                                <% }) %>
                            </select>
                        </label>
                        <noscript>
                            <button type="submit" class="ml-2 text-xs font-semibold text-brand-text/70 transition hover:text-brand-text">
                                Filter
                            </button>
                        </noscript>
                    </form>
                </div>
                <div class="flex flex-wrap items-center justify-end gap-2">
                    <a href="/employees/<%= employee.employee_id %>?activityPreset=today<%= selectedProjectId ? `&projectId=${encodeURIComponent(selectedProjectId)}` : '' %>" class="app-breadcrumb <%= activityFilter?.preset === 'today' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
                        Today
                    </a>
                    <a href="/employees/<%= employee.employee_id %>?activityPreset=week<%= selectedProjectId ? `&projectId=${encodeURIComponent(selectedProjectId)}` : '' %>" class="app-breadcrumb <%= activityFilter?.preset === 'week' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
                        Week
                    </a>
                    <a href="/employees/<%= employee.employee_id %>?activityPreset=month<%= selectedProjectId ? `&projectId=${encodeURIComponent(selectedProjectId)}` : '' %>" class="app-breadcrumb <%= activityFilter?.preset === 'month' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
                        Month
                    </a>
                    <a href="/employees/<%= employee.employee_id %>?activityPreset=quarter<%= selectedProjectId ? `&projectId=${encodeURIComponent(selectedProjectId)}` : '' %>" class="app-breadcrumb <%= activityFilter?.preset === 'quarter' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
                        Quarter
                    </a>
                    <a href="/employees/<%= employee.employee_id %>?activityPreset=all<%= selectedProjectId ? `&projectId=${encodeURIComponent(selectedProjectId)}` : '' %>" class="app-breadcrumb <%= activityFilter?.preset === 'all' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
                        All
                    </a>
                </div>
            </div>

            <% if (activityError) { %>
                <p class="mt-3 rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
                    <%= activityError %>
                </p>
            <% } %>

            <div class="mt-4 space-y-2">
                <% if (!(activityProjects || []).length) { %>
                    <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
                        <%= activityFilter?.isFiltered
                            ? 'No activity found for the selected date range.'
                            : 'No activity yet.' %>
                    </p>
                <% } %>

                <% (activityProjects || []).forEach((project) => { %>
                    <div class="border-b border-brand-secondary/70 py-3 first:pt-0 last:border-b-0 last:pb-0">
                        <div class="flex flex-wrap items-start justify-between gap-3">
                            <div class="min-w-0 flex-1">
                                <p class="text-[10px] font-semibold uppercase tracking-wide text-brand-text/45">Project</p>
                                <p class="truncate text-base font-semibold text-brand-text"><%= project.name %></p>
                            </div>
                            <% if (project.id) { %>
                                <a href="/projects/<%= project.id %>" class="inline-flex rounded-lg border border-brand-secondary px-3 py-1.5 text-xs font-semibold text-brand-text/70 transition hover:bg-brand-secondary/30">
                                    Open
                                </a>
                            <% } %>
                        </div>

                        <div class="mt-3 space-y-1 border-l-2 border-brand-secondary/70 pl-3">
                            <% project.items.forEach((item) => { %>
                                <div class="py-2">
                                    <div class="flex flex-wrap items-center gap-2">
                                        <div class="flex flex-wrap items-center gap-2 text-[11px] text-brand-text/55">
                                            <span><%= item.dateLabel %></span>
                                            <% if (item.timeLabel) { %>
                                                <span class="text-brand-text/40">|</span>
                                                <span><%= item.timeLabel %></span>
                                            <% } %>
                                            <% if (isOwnProfile) { %>
                                                <% const projectPopupId = `activity-project-${item.id}`; %>
                                                <button
                                                    type="button"
                                                    data-popup-open="<%= projectPopupId %>"
                                                    class="rounded-md border border-brand-secondary px-2 py-0.5 text-[9px] font-semibold text-brand-text/60 transition hover:bg-brand-secondary/20"
                                                    aria-label="Change activity project"
                                                >
                                                    Change project
                                                </button>
                                            <% } %>
                                        </div>
                                    </div>
                                    <p class="mt-1 text-sm font-semibold text-brand-text"><%= item.title %></p>
                                    <p class="mt-1 text-sm text-brand-text/70"><%= item.description || 'No description available.' %></p>
                                </div>
                                <% if (isOwnProfile) { %>
                                    <% const projectPopupId = `activity-project-${item.id}`; %>
                                    <%- include('../partials/shared/actionPopup', {
                                        popupId: projectPopupId,
                                        popupTitle: 'Change Activity Project',
                                        popupDescription: 'Select the project this activity belongs to or move it back to general activity.',
                                        popupAction: `/employees/${employee.employee_id}/activities/${item.id}/project`,
                                        popupMethod: 'POST',
                                        popupSubmitLabel: 'Save',
                                        popupErrorMessage: 'Failed to update the activity project.',
                                        csrfToken,
                                        popupFields: [
                                            {
                                                name: 'projectId',
                                                label: 'Project',
                                                type: 'select',
                                                value: item.projectId || '',
                                                options: [
                                                    { value: '', label: 'General Activity' },
                                                    ...(projectRows || []).map((row) => ({
                                                        value: row.project.id,
                                                        label: row.project.name,
                                                    })),
                                                ],
                                            },
                                        ],
                                    }) %>
                                <% } %>
                            <% }) %>
                        </div>
                    </div>
                <% }) %>
            </div>
        </article>

        <%- include('../partials/employeeDetails/employeeCharts') %>
    </section>

    <section class="space-y-4">
        <%# Report generator replaces the date display and quick report button. %>
        <% if(hasPermission('REP-01')) {%>
            <%- include('../partials/reportGenerator/reportGenerator', { redirectTo: '/employees/' + employee.id, defaultReportType, defaultSubjectId, reportSubjects, latestReport, quickReport }) %>
        <% } %>

        <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <h2 class="font-heading text-xl font-semibold text-brand-text">Your Teams</h2>
            <p class="mt-1 text-sm text-brand-text/60">Teams this employee is assigned to</p>
            <div class="mb-1 mt-4 max-h-48 space-y-2 overflow-y-auto">
                <% if (!(teamRows || []).length) { %>
                    <p class="text-sm text-brand-text/70">No teams assigned.</p>
                <% } %>
                <% (teamRows || []).forEach((row) => { %>
                    <div class="group flex items-center gap-2 rounded-lg p-2 transition hover:bg-brand-bg/50">
                        <a href="/teams/<%= row.team_id %>" class="flex min-w-0 flex-1 items-center gap-2">
                            <div class="app-directory-avatar flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[10px] font-bold">
                                <%= row.team.name ? row.team.name.split(' ').map((part) => part[0]).slice(0, 2).join('') : '?' %>
                            </div>
                            <div class="min-w-0 flex-1">
                                <p class="truncate text-xs font-semibold text-brand-text"><%= row.team.name || 'Unknown team' %></p>
                                <p class="truncate text-[10px] text-brand-text/50">
                                    <%= row.roleName %>
                                    <span class="mx-1 text-brand-text/40">|</span>
                                    Since <%= row.startDateLabel %>
                                </p>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>
        </article>

        <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <h2 class="font-heading text-xl font-semibold text-brand-text">Your Projects</h2>
            <p class="mt-1 text-sm text-brand-text/60">Projects this employee is contributing to</p>
            <div class="mb-1 mt-4 max-h-48 space-y-2 overflow-y-auto">
                <% if (!(projectRows || []).length) { %>
                    <p class="text-sm text-brand-text/70">No projects assigned.</p>
                <% } %>
                <% (projectRows || []).forEach((row) => { %>
                    <div class="group flex items-center gap-2 rounded-lg p-2 transition hover:bg-brand-bg/50">
                        <a href="/projects/<%= row.project.id %>" class="flex min-w-0 flex-1 items-center gap-2">
                            <div class="app-directory-avatar flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[10px] font-bold">
                                <%= row.project.name ? row.project.name.split(' ').map((part) => part[0]).slice(0, 2).join('') : '?' %>
                            </div>
                            <div class="min-w-0 flex-1">
                                <p class="truncate text-xs font-semibold text-brand-text"><%= row.project.name || 'Unknown project' %></p>
                                <p class="truncate text-[10px] text-brand-text/50">
                                    <%= row.roleName %>
                                    <span class="mx-1 text-brand-text/40">|</span>
                                    Since <%= row.startDateLabel %>
                                </p>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>
        </article>
    </section>
</div>

<script src="/js/dateRangePicker.js"></script>
