<div class="grid gap-6 md:grid-cols-[2fr_1fr]">
    <section class="space-y-6">
        <div class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
            <div class="flex flex-wrap items-center gap-4">
                <img
                src="<%= employee.image %>"
                alt="<%= employee.full_name %>"
                class="h-16 w-16 shrink-0 rounded-full border border-brand-secondary object-cover"
                />
                <div class="flex-1 min-w-0">
                    <h1 class="font-heading text-2xl font-bold text-brand-text sm:text-3xl"><%= employee.full_name %></h1>
                </div>
                <% if (isOwnProfile) { %>
                    <span class="app-breadcrumb app-breadcrumb--static">Own Profile</span>
                    <% } %>
            </div>
        </div>

        <article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <h2 class="font-heading text-xl font-semibold text-brand-text">Your Activity</h2>
                <div class="flex flex-wrap items-center justify-end gap-2">
                    <a href="/employees/<%= employee.employee_id %>?activityPreset=today" class="app-breadcrumb <%= activityFilter?.preset === 'today' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
                        Today
                    </a>
                    <a href="/employees/<%= employee.employee_id %>?activityPreset=week" class="app-breadcrumb <%= activityFilter?.preset === 'week' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
                        Week
                    </a>
                    <a href="/employees/<%= employee.employee_id %>?activityPreset=month" class="app-breadcrumb <%= activityFilter?.preset === 'month' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
                        Month
                    </a>
                    <a href="/employees/<%= employee.employee_id %>?activityPreset=quarter" class="app-breadcrumb <%= activityFilter?.preset === 'quarter' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
                        Quarter
                    </a>
                    <a href="/employees/<%= employee.employee_id %>?activityPreset=all" class="app-breadcrumb <%= activityFilter?.preset === 'all' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
                        All
                    </a>
                </div>
            </div>

            <% if (activityError) { %>
                <p class="mt-3 rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
                    <%= activityError %>
                </p>
            <% } %>

            <div class="mt-5 space-y-4">
                <% if (!(activitySections || []).length) { %>
                    <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
                        <%= activityFilter?.isFiltered
                            ? 'No activity found for the selected date range.'
                            : 'No activity yet.' %>
                    </p>
                <% } %>

                <%# Controller already groups by day and preformats each item time. %>
                <% (activitySections || []).forEach((section) => { %>
                    <p class="app-breadcrumb app-breadcrumb--static">
                        <%= section.dayLabel %>
                    </p>
                    <% section.items.forEach((item) => { %>
                        <article class="rounded-xl border border-brand-secondary/70 p-4">
                            <div class="flex items-start gap-3">
                                <div class="mt-1 h-5 w-5 rounded-full border border-brand-secondary"></div>
                                <div class="flex-1">
                                    <div class="flex flex-wrap items-center justify-between gap-2">
                                        <h3 class="font-heading text-base font-bold text-brand-text"><%= item.title %></h3>
                                        <span class="text-xs text-brand-text/60"><%= item.activityTimeLabel %></span>
                                    </div>
                                    <p class="mt-2 text-sm text-brand-text/80"><%= item.description || item.content %></p>
                                </div>
                            </div>
                        </article>
                    <% }) %>
                <% }) %>
            </div>
        </article>
    </section>

    <section class="space-y-4">
        <%# Report generator replaces the date display and quick report button. %>
        <%- include('../partials/reportGenerator/reportGenerator', { redirectTo: '/employees/' + employee.id, defaultReportType, defaultSubjectId, reportSubjects, latestReports, quickReport }) %>

        <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <h2 class="font-heading text-xl font-semibold text-brand-text">Your Teams</h2>
            <p class="mt-1 text-sm text-brand-text/60">Teams this employee is assigned to</p>
            <div class="mb-1 mt-4 max-h-48 space-y-2 overflow-y-auto">
                <% if (!(teamRows || []).length) { %>
                    <p class="text-sm text-brand-text/70">No teams assigned.</p>
                <% } %>
                <% (teamRows || []).forEach((row) => { %>
                    <div class="group flex items-center gap-2 rounded-lg p-2 transition hover:bg-brand-bg/50">
                        <a href="/teams/<%= row.team_id %>" class="flex min-w-0 flex-1 items-center gap-2">
                            <div class="app-directory-avatar flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[10px] font-bold">
                                <%= row.team.name ? row.team.name.split(' ').map((part) => part[0]).slice(0, 2).join('') : '?' %>
                            </div>
                            <div class="min-w-0 flex-1">
                                <p class="truncate text-xs font-semibold text-brand-text"><%= row.team.name || 'Unknown team' %></p>
                                <p class="truncate text-[10px] text-brand-text/50">
                                    <%= row.roleName %>
                                    <span class="mx-1 text-brand-text/40">|</span>
                                    Since <%= row.startDateLabel %>
                                </p>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>
        </article>

        <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <h2 class="font-heading text-xl font-semibold text-brand-text">Your Projects</h2>
            <p class="mt-1 text-sm text-brand-text/60">Projects this employee is contributing to</p>
            <div class="mb-1 mt-4 max-h-48 space-y-2 overflow-y-auto">
                <% if (!(projectRows || []).length) { %>
                    <p class="text-sm text-brand-text/70">No projects assigned.</p>
                <% } %>
                <% (projectRows || []).forEach((row) => { %>
                    <div class="group flex items-center gap-2 rounded-lg p-2 transition hover:bg-brand-bg/50">
                        <a href="/projects/<%= row.project.id %>" class="flex min-w-0 flex-1 items-center gap-2">
                            <div class="app-directory-avatar flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[10px] font-bold">
                                <%= row.project.name ? row.project.name.split(' ').map((part) => part[0]).slice(0, 2).join('') : '?' %>
                            </div>
                            <div class="min-w-0 flex-1">
                                <p class="truncate text-xs font-semibold text-brand-text"><%= row.project.name || 'Unknown project' %></p>
                                <p class="truncate text-[10px] text-brand-text/50">
                                    <%= row.roleName %>
                                    <span class="mx-1 text-brand-text/40">|</span>
                                    Since <%= row.startDateLabel %>
                                </p>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>
        </article>
    </section>
</div>

<script src="/js/dateRangePicker.js"></script>
