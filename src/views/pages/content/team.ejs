<div class="grid gap-6 lg:grid-cols-[2fr_1fr]">
  <%- include('../../partials/teamDirectory/teamDetailsCard', { team }) %>
  <%- include('../../partials/teamDirectory/teamprojects', { team }) %>

  <section class="space-y-4">
    <%- include('../../partials/teamDirectory/joinButton', {
      team,
      isMember: typeof isMember !== 'undefined' ? isMember : false,
      csrfToken
    }) %>
    <%# include('../../partials/reportGenerator', { team, isMember }) %>
    <%- include('../../partials/teamDirectory/teamParticipants', { team }) %>
    <%- include('../../partials/teamDirectory/teamActivity', {
      activitySections: typeof activitySections !== 'undefined' ? activitySections : []
    }) %>
    <a href="/teams" class="inline-flex rounded-xl border border-brand-secondary px-3 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30">
      Back to teams
    </a>
  </section>
</div>
