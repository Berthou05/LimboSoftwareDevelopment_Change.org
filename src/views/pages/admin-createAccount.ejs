<section class="w-full rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h2 class="font-heading text-xl font-bold">Create Account</h2>

    <div class="flex flex-wrap gap-3">
      <button
        type="submit"
        form="accountForm"
        class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
      >
        Create Account
      </button>

      <a
        href="/admin/accounts"
        class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30"
      >
        Cancel
      </a>
    </div>
  </div>

  <form
    id="accountForm"
    action="/admin/accounts/create"
    method="POST"
    enctype="multipart/form-data"
    class="mt-5 grid gap-4 md:grid-cols-[minmax(0,1fr)_12rem]"
  >
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <!-- LEFT SIDE -->
    <div class="grid gap-4 sm:grid-cols-2">

      <!-- Names -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Names</span>
        <input
          type="text"
          name="names"
          value="<%= formData.names %>"
          placeholder="Alexis"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
        />
      </label>

      <!-- Last Names -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Last names</span>
        <input
          type="text"
          name="lastnames"
          value="<%= formData.lastnames %>"
          placeholder="Berthou"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
        />
      </label>

      <!-- Email -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Email</span>
        <input
          type="email"
          name="email"
          value="<%= formData.email %>"
          placeholder="new.account@unitas.dev"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
        />
      </label>

      <!-- Slack -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Slack username</span>
        <input
          type="text"
          name="slackUsername"
          value="<%= formData.slackUsername %>"
          placeholder="@newmember"
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
        />
      </label>

      <!-- Password -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Password</span>

        <div class="relative">
          <input
            id="createAccountPassword"
            type="password"
            name="password"
            required
            minlength="6"
            placeholder="At least 6 characters"
            class="w-full rounded-xl border border-brand-secondary px-3 py-2 pr-10 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
          />

          <button
            type="button"
            data-password-toggle="createAccountPassword"
            aria-label="Show password"
            class="absolute right-3 top-1/2 -translate-y-1/2 text-brand-text/55 hover:text-brand-text"
          >
            <svg data-password-eye class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12s-3.75 6.75-9.75 6.75S2.25 12 2.25 12Z" />
              <circle cx="12" cy="12" r="2.25" />
            </svg>
            <svg data-password-eye-off class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3l18 18" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.58 10.58a2.25 2.25 0 0 0 2.84 2.84" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.88 5.48A8.96 8.96 0 0 1 12 5.25c6 0 9.75 6.75 9.75 6.75a16.65 16.65 0 0 1-2.22 2.99" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.34 6.88C3.76 8.63 2.25 12 2.25 12s3.75 6.75 9.75 6.75c1.63 0 3.08-.5 4.32-1.22" />
            </svg>
          </button>
        </div>

        <div class="mt-2 flex items-center gap-2">
          <button
            id="generateAccountPasswordBtn"
            type="button"
            class="rounded-lg border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/80 hover:bg-brand-secondary/20"
          >
            Auto-generate
          </button>

          <span id="generateAccountPasswordHint" class="text-xs text-brand-text/70"></span>
        </div>
      </label>

      <!-- Confirm Password -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Confirm password</span>
        <input
          type="password"
          name="confirmPassword"
          required
          minlength="6"
          placeholder="Repeat password"
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
        />
      </label>

      <!-- Role -->
      <label class="block text-sm sm:col-span-2">
        <span class="mb-1 block font-semibold text-brand-text">Role</span>
        <select
          name="roleId"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        >
          <% roles.forEach((role) => { %>
            <option value="<%= role.id %>" <%= formData.roleId === role.id ? "selected" : "" %>>
              <%= role.name %>
            </option>
          <% }) %>
        </select>
      </label>

    </div>

    <!-- RIGHT SIDE -->
    <div class="text-sm md:justify-self-center">
      <span class="mb-3 block font-semibold text-brand-text">Profile picture</span>

      <input id="accountImageFile" type="file" name="image" accept="image/*" class="sr-only" />
      <input id="accountImageValue" type="hidden" name="currentImage" value="<%= formData.image %>" />

      <div class="relative flex flex-col items-start">
        <img
          id="accountImagePreview"
          src="<%= formData.image || '/images/accounts/default-avatar.png' %>"
          class="h-36 w-36 rounded-full border border-brand-secondary object-cover"
        />

        <div class="-mt-8 ml-3">
          <button
            id="accountImageMenuButton"
            type="button"
            class="rounded-lg border border-brand-secondary bg-white px-3 py-2 text-sm font-semibold text-brand-text shadow-sm hover:bg-brand-secondary/20"
          >
            Edit
          </button>
        </div>
      </div>
    </div>

  </form>
</section>

<script>
  function generateSecurePassword() {
    const lowercase = 'abcdefghijklmnopqrstuvwxyz';
    const uppercase = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const numbers = '0123456789';
    const specials = '!@#$%^&*()_+-=[]{}|;:,.<>?';

    let password = '';
    password += uppercase[Math.floor(Math.random() * uppercase.length)];
    password += lowercase[Math.floor(Math.random() * lowercase.length)];
    password += numbers[Math.floor(Math.random() * numbers.length)];
    password += specials[Math.floor(Math.random() * specials.length)];

    const allChars = lowercase + uppercase + numbers + specials;
    while (password.length < 8) {
      password += allChars[Math.floor(Math.random() * allChars.length)];
    }

    password = password.split('').sort(() => Math.random() - 0.5).join('');

    return password;
  }

  document.getElementById('generateAccountPasswordBtn').addEventListener('click', function() {
    const password = generateSecurePassword();
    const passwordInput = document.getElementById('createAccountPassword');
    const confirmPasswordInput = document.querySelector('input[name="confirmPassword"]');
    const hint = document.getElementById('generateAccountPasswordHint');

    passwordInput.value = password;
    confirmPasswordInput.value = password;

    passwordInput.classList.add('bg-yellow-50');
    confirmPasswordInput.classList.add('bg-yellow-50');

    if (hint) {
      hint.textContent = 'Password generated and copied to both fields.';
    }
  });

  document.getElementById('createAccountPassword').addEventListener('input', function() {
    this.classList.remove('bg-yellow-50');
  });

  document.querySelector('input[name="confirmPassword"]').addEventListener('input', function() {
    this.classList.remove('bg-yellow-50');
  });
</script>
<script src="/js/passwordVisibility.js"></script>
