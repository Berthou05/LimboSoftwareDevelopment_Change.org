<%# Template: pages/createAccount.ejs
   Purpose: Admin create-account page.
   Expected locals: roles, formData.
%>

<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<section class="w-full rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h2 class="font-heading text-xl font-bold">Create Account</h2>
    <div class="flex flex-wrap gap-3">
      <button
        type="submit"
        form="accountForm"
        class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
      >
        Create Account
      </button>
      <a
        href="/admin/accounts"
        class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30"
      >
        Cancel
      </a>
    </div>
  </div>

  <form id="accountForm" action="/admin/accounts/create" method="POST" enctype="multipart/form-data" class="mt-4 grid gap-4 md:grid-cols-[minmax(0,1fr)_12rem]">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="grid gap-4 sm:grid-cols-2 md:col-span-1">
      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Names</span>
        <input
          type="text"
          name="names"
          value="<%= formData.names %>"
          placeholder="Alexis"
          required
          class="w-full rounded-xl border border-brand-secondary bg-white px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Last names</span>
        <input
          type="text"
          name="lastnames"
          value="<%= formData.lastnames %>"
          placeholder="Berthou"
          required
          class="w-full rounded-xl border border-brand-secondary bg-white px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Email</span>
        <input
          type="email"
          name="email"
          value="<%= formData.email %>"
          placeholder="new.account@unitas.dev"
          required
          class="w-full rounded-xl border border-brand-secondary bg-white px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Slack username</span>
        <input
          type="text"
          name="slackUsername"
          value="<%= formData.slackUsername %>"
          placeholder="@newmember"
          class="w-full rounded-xl border border-brand-secondary bg-white px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Password</span>
        <input
          id="createAccountPassword"
          type="password"
          name="password"
          required
          minlength="6"
          placeholder="At least 6 characters"
          class="w-full rounded-xl border border-brand-secondary bg-white px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
        <div class="mt-2 flex items-center gap-2">
          <button
            id="generateAccountPasswordBtn"
            type="button"
            class="rounded-lg border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20"
          >
            Auto-generate
          </button>
          <span id="generateAccountPasswordHint" class="text-xs font-medium text-brand-text/70"></span>
        </div>
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Confirm password</span>
        <input
          type="password"
          name="confirmPassword"
          required
          minlength="6"
          placeholder="Repeat password"
          class="w-full rounded-xl border border-brand-secondary bg-white px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
      </label>

      <label class="block text-sm sm:col-span-2">
        <span class="mb-1 block text-brand-text/70">Role</span>
        <select
          name="roleId"
          required
          class="w-full rounded-xl border border-brand-secondary bg-white px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        >
          <% roles.forEach((role) => { %>
            <option value="<%= role.id %>" <%= formData.roleId === role.id ? "selected" : "" %>><%= role.name %></option>
          <% }) %>
        </select>
      </label>
    </div>

    <div class="block text-sm md:justify-self-center">
      <span class="mb-3 block text-brand-text/70">Profile picture</span>
      <input
        id="accountImageFile"
        type="file"
        name="image"
        accept="image/*"
        class="sr-only"
      />
      <input id="accountImageValue" type="hidden" name="currentImage" value="<%= formData.image %>" />
      <p id="accountImageFilename" class="sr-only">No file selected</p>

      <div class="relative inline-flex flex-col items-start">
        <img
          id="accountImagePreview"
          src="<%= formData.image || '/images/accounts/2026-04-13T18-43-46.235Z-avatar.png' %>"
          alt="Account preview"
          class="h-36 w-36 rounded-full border border-brand-secondary object-cover"
          onerror="this.src='/images/accounts/2026-04-13T18-43-46.235Z-avatar.png'"
        />
        <div class="relative -mt-8 ml-3">
          <button
            id="accountImageMenuButton"
            type="button"
            aria-expanded="false"
            aria-controls="accountImageMenu"
            class="inline-flex items-center gap-2 rounded-lg border border-brand-secondary bg-white px-3 py-2 text-sm font-semibold text-brand-text shadow-sm hover:bg-white active:bg-white focus:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-nav/20"
          >
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 13.5V16h2.5L14 8.5 11.5 6 4 13.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
              <path d="m12.5 5 1-1a1.4 1.4 0 0 1 2 2l-1 1" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            </svg>
            Edit
          </button>

          <div
            id="accountImageMenu"
            class="absolute left-0 top-full z-20 mt-2 hidden w-52 overflow-hidden rounded-lg border border-brand-secondary bg-white text-sm shadow-sm"
          >
            <button
              id="accountImageUploadButton"
              type="button"
              class="block w-full bg-brand-nav px-4 py-3 text-left font-semibold text-white transition hover:bg-brand-nav/90"
            >
              Upload a photo...
            </button>
            <button
              id="accountImageRemoveButton"
              type="button"
              class="block w-full px-4 py-3 text-left font-semibold text-brand-text transition hover:bg-brand-secondary/20"
            >
              Remove photo
            </button>
          </div>
        </div>
      </div>
    </div>
  </form>
</section>

  <aside class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <h2 class="font-heading text-lg font-bold text-brand-text">Before You Create</h2>
    <ul class="mt-3 space-y-2 text-sm text-brand-text/75">
      <li>Use a unique email for each account.</li>
      <li>New accounts are created with Active status by default.</li>
      <li>If no image is uploaded, the default account avatar is used.</li>
    </ul>
  </aside>
</div>

<script>
  function generateSecurePassword() {
    const lowercase = 'abcdefghijklmnopqrstuvwxyz';
    const uppercase = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const numbers = '0123456789';
    const specials = '!@#$%^&*()_+-=[]{}|;:,.<>?';

    // Ensure at least one of each required character
    let password = '';
    password += uppercase[Math.floor(Math.random() * uppercase.length)];
    password += lowercase[Math.floor(Math.random() * lowercase.length)];
    password += numbers[Math.floor(Math.random() * numbers.length)];
    password += specials[Math.floor(Math.random() * specials.length)];

    // Fill the rest to make at least 8 characters
    const allChars = lowercase + uppercase + numbers + specials;
    while (password.length < 8) {
      password += allChars[Math.floor(Math.random() * allChars.length)];
    }

    // Shuffle the password
    password = password.split('').sort(() => Math.random() - 0.5).join('');

    return password;
  }

  document.getElementById('generateAccountPasswordBtn').addEventListener('click', function() {
    const password = generateSecurePassword();
    const passwordInput = document.getElementById('createAccountPassword');
    const confirmPasswordInput = document.querySelector('input[name="confirmPassword"]');

    passwordInput.value = password;
    confirmPasswordInput.value = password;

    // Add light background color to indicate auto-generated
    passwordInput.classList.add('bg-yellow-50');
    confirmPasswordInput.classList.add('bg-yellow-50');

    // Update hint
    const hint = document.getElementById('generateAccountPasswordHint');
    if (hint) {
      hint.textContent = 'Password generated and copied to both fields.';
    }
  });

  // Remove background color when user types
  document.getElementById('createAccountPassword').addEventListener('input', function() {
    this.classList.remove('bg-yellow-50');
  });

  document.querySelector('input[name="confirmPassword"]').addEventListener('input', function() {
    this.classList.remove('bg-yellow-50');
  });
</script>
