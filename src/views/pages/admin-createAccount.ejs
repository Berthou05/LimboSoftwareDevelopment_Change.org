<section class="w-full rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h2 class="font-heading text-xl font-bold">Create Account</h2>

    <div class="flex flex-wrap gap-3">
      <button
        type="submit"
        form="accountForm"
        class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-black transition hover:bg-brand-accent"
      >
        Create Account
      </button>

      <a
        href="/admin/accounts"
        class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30"
      >
        Cancel
      </a>
    </div>
  </div>

  <form
    id="accountForm"
    action="/admin/accounts/create"
    method="POST"
    enctype="multipart/form-data"
    class="mt-5 grid gap-4 md:grid-cols-[minmax(0,1fr)_12rem]"
  >
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <!-- LEFT SIDE -->
    <div class="grid gap-4 sm:grid-cols-2">

      <!-- Names -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Names</span>
        <input
          type="text"
          name="names"
          value="<%= formData.names %>"
          placeholder="Alexis"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
        />
      </label>

      <!-- Last Names -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Last names</span>
        <input
          type="text"
          name="lastnames"
          value="<%= formData.lastnames %>"
          placeholder="Berthou"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
        />
      </label>

      <!-- Email -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Email</span>
        <input
          type="email"
          name="email"
          value="<%= formData.email %>"
          placeholder="new.account@unitas.dev"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
        />
      </label>

      <!-- Slack -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Slack username</span>
        <input
          type="text"
          name="slackUsername"
          value="<%= formData.slackUsername %>"
          placeholder="@newmember"
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
        />
      </label>

      <!-- Password -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Password</span>

        <div class="relative">
          <input
            id="createAccountPassword"
            type="password"
            name="password"
            required
            minlength="6"
            placeholder="At least 6 characters"
            class="w-full rounded-xl border border-brand-secondary px-3 py-2 pr-10 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
          />

          <button
            type="button"
            data-password-toggle="createAccountPassword"
            aria-label="Show password"
            class="absolute right-3 top-1/2 -translate-y-1/2 text-brand-text/55 hover:text-brand-text"
          >
            <!-- Eye open (password hidden) -->
            <svg data-eye-open class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
            <!-- Eye closed (password visible) -->
            <svg data-eye-closed class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
            </svg>
          </button>
        </div>

        <div class="mt-2 flex items-center gap-2">
          <button
            id="generateAccountPasswordBtn"
            type="button"
            class="rounded-lg border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/80 hover:bg-brand-secondary/20"
          >
            Auto-generate
          </button>

          <span id="generateAccountPasswordHint" class="text-xs text-brand-text/70"></span>
        </div>
      </label>

      <!-- Confirm Password -->
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text">Confirm password</span>

        <div class="relative">
          <input
            id="createAccountConfirmPassword"
            type="password"
            name="confirmPassword"
            required
            minlength="6"
            placeholder="Repeat password"
            class="w-full rounded-xl border border-brand-secondary px-3 py-2 pr-10 outline-none placeholder:text-brand-text/30 ring-brand-primary/30 focus:ring"
          />

          <button
            type="button"
            data-password-toggle="createAccountConfirmPassword"
            class="absolute right-3 top-1/2 -translate-y-1/2 text-brand-text/55 hover:text-brand-text"
          >
            <svg data-eye-open class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
            <svg data-eye-closed class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
            </svg>
          </button>
        </div>
      </label>


      <!-- Role -->
      <label class="block text-sm sm:col-span-2">
        <span class="mb-1 block font-semibold text-brand-text">Role</span>
        <select
          name="roleId"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        >
          <% roles.forEach((role) => { %>
            <option value="<%= role.id %>" <%= formData.roleId === role.id ? "selected" : "" %>>
              <%= role.name %>
            </option>
          <% }) %>
        </select>
      </label>

    </div>

    <!-- RIGHT SIDE -->
    <div class="text-sm md:justify-self-center">
      <span class="mb-3 block font-semibold text-brand-text">Profile picture</span>

      <input id="accountImageFile" type="file" name="image" accept="image/*" class="sr-only" />
      <input id="accountImageValue" type="hidden" name="currentImage" value="<%= formData.image %>" />

      <div class="relative flex flex-col items-start">
        <div class="relative h-36 w-36">
          <!-- Fallback (initials) -->
          <div
            id="accountImageFallback"
            class="app-directory-avatar flex h-36 w-36 items-center justify-center rounded-full border border-brand-secondary bg-blue-100 text-2xl font-bold"
          >
            <!-- JS fills this -->
          </div>

          <!-- Image -->
          <img
            id="accountImagePreview"
            src="<%= formData.image || '' %>"
            class="absolute inset-0 h-36 w-36 rounded-full object-cover <%= formData.image ? '' : 'hidden' %>"
          />
        </div>

        <div class="-mt-8 ml-3 z-10">
          <button
            id="accountImageMenuButton"
            type="button"
            aria-expanded="false"
            class="rounded-lg border border-brand-secondary bg-white px-3 py-2 text-sm font-semibold text-brand-text shadow-sm hover:bg-brand-secondary/20"
          >
            Edit
          </button>
        </div>

        <!-- MENU -->
        <div
          id="accountImageMenu"
          class="hidden absolute top-28 left-3 z-10 w-44 rounded-xl border border-brand-secondary bg-white shadow-lg"
        >
          <button
            id="accountImageUploadButton"
            type="button"
            class="block w-full px-4 py-2 text-left text-sm hover:bg-brand-secondary/20"
          >
            Upload image
          </button>

          <button
            id="accountImageRemoveButton"
            type="button"
            class="block w-full px-4 py-2 text-left text-sm text-red-600 hover:bg-red-50"
          >
            Remove image
          </button>
        </div>
      </div>
    </div>

  </form>
</section>

<script src="/js/createAccount.js"></script>
