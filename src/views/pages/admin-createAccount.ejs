<%# Template: pages/createAccount.ejs
   Purpose: Admin create-account page.
   Expected locals: roles, formData.
%>

<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<div class="grid gap-6 md:grid-cols-[minmax(0,1fr)_320px]">
  <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <form action="/admin/accounts/create" method="POST" class="grid gap-4 sm:grid-cols-2">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label class="block text-sm sm:col-span-1">
        <span class="mb-1 block text-brand-text/70">Name(s)</span>
        <input
          type="text"
          name="names"
          value="<%= formData.names %>"
          placeholder="Alexis"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
      </label>

      <label class="block text-sm sm:col-span-1">
        <span class="mb-1 block text-brand-text/70">Last names</span>
        <input
          type="text"
          name="lastnames"
          value="<%= formData.lastnames %>"
          placeholder="Berthou"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
      </label>

      <label class="block text-sm sm:col-span-2">
        <span class="mb-1 block text-brand-text/70">Email</span>
        <input
          type="email"
          name="email"
          value="<%= formData.email %>"
          placeholder="new.account@unitas.dev"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Password</span>
        <input
          id="createAccountPassword"
          type="password"
          name="password"
          required
          minlength="6"
          placeholder="At least 6 characters"
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
        <div class="mt-2 flex items-center gap-2">
          <button
            id="generateAccountPasswordBtn"
            type="button"
            class="rounded-lg border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20"
          >
            Auto-generate
          </button>
          <span id="generateAccountPasswordHint" class="text-xs font-medium text-brand-text/70"></span>
        </div>
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Confirm password</span>
        <input
          type="password"
          name="confirmPassword"
          required
          minlength="6"
          placeholder="Repeat password"
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
      </label>

      <label class="block text-sm">
        <span class="mb-1 block text-brand-text/70">Slack username</span>
        <input
          type="text"
          name="slackUsername"
          value="<%= formData.slackUsername %>"
          placeholder="@newmember"
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
      </label>

      <label class="block text-sm sm:col-span-1">
        <span class="mb-1 block text-brand-text/70">Role</span>
        <select
          name="roleId"
          required
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        >
          <% roles.forEach((role) => { %>
            <option value="<%= role.id %>" <%= formData.roleId === role.id ? "selected" : "" %>><%= role.name %></option>
          <% }) %>
        </select>
      </label>

      <label class="block text-sm sm:col-span-2">
        <span class="mb-1 block text-brand-text/70">Profile image (optional)</span>
        <input
          id="accountImageFile"
          type="file"
          accept="image/*"
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
        />
        <input id="accountImageValue" type="hidden" name="image" value="<%= formData.image %>" />
        <p id="accountImageFilename" class="mt-1 text-xs text-brand-text/65">No file selected</p>
      </label>

      <div class="flex items-center justify-center rounded-xl border border-brand-secondary bg-brand-bg p-3 sm:col-span-2">
        <img
          id="accountImagePreview"
          src="<%= formData.image || '/images/accounts/2026-04-13T18-43-46.235Z-avatar.png' %>"
          alt="Account preview"
          class="h-20 w-20 rounded-full border border-brand-secondary object-cover"
          onerror="this.src='/images/accounts/2026-04-13T18-43-46.235Z-avatar.png'"
        />
      </div>

      <div class="flex flex-wrap items-center gap-3 sm:col-span-2">
        <button
          type="submit"
          class="rounded-xl bg-brand-primary px-5 py-2 text-sm font-semibold text-brand-text transition hover:bg-brand-accent"
        >
          Create Account
        </button>
        <a
          href="/admin/accounts"
          class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20"
        >
          Cancel
        </a>
      </div>
    </form>
  </section>

  <aside class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <h2 class="font-heading text-lg font-bold text-brand-text">Before You Create</h2>
    <ul class="mt-3 space-y-2 text-sm text-brand-text/75">
      <li>Use a unique email for each account.</li>
      <li>New accounts are created with Active status by default.</li>
      <li>If no image is uploaded, the default account avatar is used.</li>
    </ul>
  </aside>
</div>

<script>
  function generateSecurePassword() {
    const lowercase = 'abcdefghijklmnopqrstuvwxyz';
    const uppercase = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const numbers = '0123456789';
    const specials = '!@#$%^&*()_+-=[]{}|;:,.<>?';

    // Ensure at least one of each required character
    let password = '';
    password += uppercase[Math.floor(Math.random() * uppercase.length)];
    password += lowercase[Math.floor(Math.random() * lowercase.length)];
    password += numbers[Math.floor(Math.random() * numbers.length)];
    password += specials[Math.floor(Math.random() * specials.length)];

    // Fill the rest to make at least 8 characters
    const allChars = lowercase + uppercase + numbers + specials;
    while (password.length < 8) {
      password += allChars[Math.floor(Math.random() * allChars.length)];
    }

    // Shuffle the password
    password = password.split('').sort(() => Math.random() - 0.5).join('');

    return password;
  }

  document.getElementById('generateAccountPasswordBtn').addEventListener('click', function() {
    const password = generateSecurePassword();
    const passwordInput = document.getElementById('createAccountPassword');
    const confirmPasswordInput = document.querySelector('input[name="confirmPassword"]');

    passwordInput.value = password;
    confirmPasswordInput.value = password;

    // Add light background color to indicate auto-generated
    passwordInput.classList.add('bg-yellow-50');
    confirmPasswordInput.classList.add('bg-yellow-50');

    // Update hint
    const hint = document.getElementById('generateAccountPasswordHint');
    if (hint) {
      hint.textContent = 'Password generated and copied to both fields.';
    }
  });

  // Remove background color when user types
  document.getElementById('createAccountPassword').addEventListener('input', function() {
    this.classList.remove('bg-yellow-50');
  });

  document.querySelector('input[name="confirmPassword"]').addEventListener('input', function() {
    this.classList.remove('bg-yellow-50');
  });
</script>
