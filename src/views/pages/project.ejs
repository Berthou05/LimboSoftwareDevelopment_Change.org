<div class="grid gap-6 md:grid-cols-[2fr_1fr]">
  <section class="space-y-6">
    <div class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
      <%- include('../partials/projectDirectory/projectDetailsCard', { project }) %>
    </div>

    <%- include('../partials/projectDirectory/projectActivity', {
      project,
      activityFilter: typeof activityFilter !== 'undefined'
        ? activityFilter
        : { preset: 'month', startDate: '', endDate: '', hasManualRange: false, isFiltered: true },
      activityError: typeof activityError !== 'undefined' ? activityError : '',
      activitySections: typeof activitySections !== 'undefined' ? activitySections : []
    }) %>

    <%- include('../partials/projectDirectory/projectAchievements', {
      project
    }) %>

    <%- include('../partials/projectDirectory/projectGoals', {
      project
    }) %>

    <%- include('../partials/projectDirectory/projectLatestReports', {
      project
    }) %>
  </section>

  <section class="space-y-4">
    <%- include('../partials/projectDirectory/joinButton', {
      project,
      projectMembership: typeof projectMembership !== 'undefined'
        ? projectMembership
        : { isMember: false, canToggle: false, buttonLabel: 'Join Project' },
      csrfToken
    }) %>

    <%- include('../partials/reportGenerator/reportGenerator', {
      redirectTo: '/projects/' + (project?.id || project?.project_id || ''),
      defaultReportType: typeof defaultReportType !== 'undefined' ? defaultReportType : 'PROJECT',
      defaultSubjectId: typeof defaultSubjectId !== 'undefined' ? defaultSubjectId : (project?.id || project?.project_id || ''),
      reportSubjects: typeof reportSubjects !== 'undefined' ? reportSubjects : { employees: [], teams: [], projects: [] },
      latestReports: typeof latestReports !== 'undefined' ? latestReports : {},
      quickReport: typeof quickReport !== 'undefined' ? quickReport : '',
    }) %>

    <%- include('../partials/projectDirectory/projectHighlights', {
      project
    }) %>

    <%- include('../partials/projectDirectory/projectTeams', {
      project,
      csrfToken,
      availableTeams: typeof availableTeams !== 'undefined' ? availableTeams : []
    }) %>

    <%- include('../partials/projectDirectory/projectMembers', {
      project,
      csrfToken,
      currentEmployeeId: typeof currentEmployeeId !== 'undefined' ? currentEmployeeId : null,
      availableEmployees: typeof availableEmployees !== 'undefined' ? availableEmployees : []
    }) %>

    <a href="/projects" class="inline-flex rounded-xl border border-brand-secondary px-3 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30">
      Back to projects
    </a>
  </section>
</div>

<script src="/js/teamDetails.js"></script>
<script src="/js/dateRangePicker.js"></script>
