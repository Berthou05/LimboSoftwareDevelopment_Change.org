<%
  const canDeleteProject = Boolean(
    project?.employee_responsible_id
    && typeof currentEmployeeId !== 'undefined'
    && currentEmployeeId
    && project.employee_responsible_id === currentEmployeeId
  );
%>

<%- include('../partials/shared/backButton', { fallbackUrl: '/projects' }) %>

<div class="grid gap-6 md:grid-cols-[2fr_1fr]">
  <section class="space-y-6">
    <div class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
      <%- include('../partials/projectDirectory/projectDetailsCard', { project, csrfToken }) %>
    </div>

    <%- include('../partials/projectDirectory/projectActivity', {
      project,
      activityFilter: typeof activityFilter !== 'undefined'
        ? activityFilter
        : { preset: 'month', startDate: '', endDate: '', hasManualRange: false, isFiltered: true },
      activityError: typeof activityError !== 'undefined' ? activityError : '',
      activitySections: typeof activitySections !== 'undefined' ? activitySections : []
    }) %>

    <%- include('../partials/projectDirectory/projectAchievements', {
      project,
      csrfToken
    }) %>

    <%- include('../partials/projectDirectory/projectGoals', {
      project,
      csrfToken
    }) %>

  </section>

  <section class="space-y-4">
    <%- include('../partials/projectDirectory/joinButton', {
      project,
      projectMembership: typeof projectMembership !== 'undefined'
        ? projectMembership
        : { isMember: false, canToggle: false, buttonLabel: 'Join Project' },
      csrfToken
    }) %>

    <%- include('../partials/reportGenerator/reportGenerator', {
      redirectTo: '/projects/' + (project?.id || project?.project_id || ''),
      defaultReportType: typeof defaultReportType !== 'undefined' ? defaultReportType : 'PROJECT',
      defaultSubjectId: typeof defaultSubjectId !== 'undefined' ? defaultSubjectId : (project?.id || project?.project_id || ''),
      reportSubjects: typeof reportSubjects !== 'undefined' ? reportSubjects : { employees: [], teams: [], projects: [] },
      latestReports: typeof latestReports !== 'undefined' ? latestReports : {},
      quickReport: typeof quickReport !== 'undefined' ? quickReport : '',
    }) %>

    <%- include('../partials/projectDirectory/projectHighlights', {
      project,
      csrfToken
    }) %>

    <%- include('../partials/projectDirectory/projectTeams', {
      project,
      csrfToken,
      availableTeams: typeof availableTeams !== 'undefined' ? availableTeams : []
    }) %>

    <%- include('../partials/projectDirectory/projectMembers', {
      project,
      csrfToken,
      currentEmployeeId: typeof currentEmployeeId !== 'undefined' ? currentEmployeeId : null,
      availableEmployees: typeof availableEmployees !== 'undefined' ? availableEmployees : [],
      canAddProjectMembers: typeof canAddProjectMembers !== 'undefined' ? canAddProjectMembers : false,
      canManageProjectMembers: typeof canManageProjectMembers !== 'undefined' ? canManageProjectMembers : false
    }) %>

    <% if (canDeleteProject) { %>
      <div class="flex justify-end">
        <button
          type="button"
          data-popup-open="delete-project-<%= project?.id || project?.project_id || '' %>"
          class="panel-action-button panel-action-button--danger"
          aria-label="Delete project"
        >
          Delete project
        </button>
      </div>
    <% } %>
  </section>
</div>

<% if (canDeleteProject) { %>
  <div data-popup="delete-project-<%= project?.id || project?.project_id || '' %>" class="fixed inset-0 z-50 hidden bg-brand-text/35 px-4 py-8">
    <div class="mx-auto max-w-lg">
      <div class="rounded-3xl border border-brand-secondary bg-white p-6 shadow-panel">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="font-heading text-2xl font-bold text-brand-text">Delete Project</h3>
            <p class="mt-1 text-sm text-brand-text/60">
              This will disable the project and remove it from active project listings. This action cannot be undone from this screen.
            </p>
          </div>
          <%- include('../partials/shared/actionButton', {
            buttonPopupClose: true,
            buttonIcon: 'close',
            buttonVariant: 'icon-only',
            buttonClasses: 'shrink-0',
            buttonAriaLabel: 'Close popup',
          }) %>
        </div>

        <form
          action="/projects/<%= project?.id || project?.project_id || '' %>/delete"
          method="POST"
          data-project-delete-form
          data-error-message="The project could not be deleted right now."
          class="mt-5 space-y-4"
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="flex flex-wrap justify-end gap-3 pt-2">
            <button
              type="button"
              data-popup-close
              class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="rounded-xl border border-brand-accent bg-brand-accent px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent/90"
            >
              Delete
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
<% } %>

<script src="/js/teamDetails.js"></script>
<script src="/js/dateRangePicker.js"></script>
<script src="/js/activityFilters.js"></script>
