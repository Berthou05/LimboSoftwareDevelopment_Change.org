<%
    const safeReports = Array.isArray(reports) ? reports : [];
    const safeSubjects = typeof subjects !== 'undefined' && Array.isArray(subjects) ? subjects : [];
    const safeFilters = filters || {};
    const activeType = safeFilters.type || 'ALL';
    const subjectFilter = safeFilters.subject || '';
    const startDateFilter = safeFilters.startDate || '';
    const endDateFilter = safeFilters.endDate || '';
    const reportTypeStyles = {
        EMPLOYEE: 'bg-[#e8fff4] text-[#087a55]',
        PROJECT: 'bg-[#eef8fd] text-[#25627f]',
        TEAM: 'bg-violet-100 text-violet-700',
    };

    const formatHistoryDate = function formatHistoryDate(value, options) {
        if (!value) {
            return 'Unknown date';
        }

        const date = new Date(value);

        if (Number.isNaN(date.getTime())) {
            return 'Unknown date';
        }

        return date.toLocaleDateString('en-US', options || {
            month: 'short',
            day: 'numeric',
            year: 'numeric',
        });
    };

    const formatReportType = function formatReportType(value) {
        const type = String(value || '').toLowerCase();

        return type ? type.charAt(0).toUpperCase() + type.slice(1) : 'Unknown';
    };
%>

<%- include('../partials/pageHeader', {
    title: pageTitle,
    subtitle: pageSubtitle,
}) %>

<div class="space-y-6">
    <section class="rounded-2xl bg-white p-5 shadow-panel">
        <div class="mb-4 flex flex-wrap items-center gap-2">
            <form action="/reports" method="GET" data-report-history-filter data-date-range-optional class="flex flex-wrap items-center gap-2 text-xs font-semibold">
                <select
                    name="type"
                    data-report-history-type
                    class="report-type w-40 rounded-full border border-brand-secondary bg-white px-3 py-1 text-xs font-semibold text-brand-text/80 outline-none ring-brand-primary/30 focus:ring"
                >
                    <option value="ALL" <%= activeType === 'ALL' ? 'selected' : '' %>>All</option>
                    <option value="EMPLOYEE" <%= activeType === 'EMPLOYEE' ? 'selected' : '' %>>Employee</option>
                    <option value="PROJECT" <%= activeType === 'PROJECT' ? 'selected' : '' %>>Project</option>
                    <option value="TEAM" <%= activeType === 'TEAM' ? 'selected' : '' %>>Team</option>
                </select>

                <select
                    name="subject"
                    data-report-history-subject
                    class="w-44 rounded-full border border-brand-secondary bg-white px-3 py-1 text-xs font-semibold text-brand-text/80 outline-none ring-brand-primary/30 focus:ring"
                >
                    <option value="">All subjects</option>
                    <% safeSubjects.forEach((subject) => { %>
                        <option value="<%= subject.name %>" data-report-type="<%= subject.type %>" <%= subjectFilter === subject.name ? 'selected' : '' %>>
                            <%= subject.name %>
                        </option>
                    <% }) %>
                </select>

                <div class="relative">
                    <button
                        type="button"
                        data-date-trigger
                        class="rounded-full border border-brand-secondary bg-white px-3 py-1 text-xs font-semibold text-brand-text/80 outline-none transition hover:bg-brand-secondary/20"
                    >
                        <span data-start-display><%= startDateFilter || 'Select Date Range' %></span>
                    </button>

                    <input data-start-value type="hidden" name="startDate" value="<%= startDateFilter %>" />
                    <input data-end-value type="hidden" name="endDate" value="<%= endDateFilter %>" />

                    <div data-date-popover class="absolute left-0 z-40 mt-2 hidden w-[min(44rem,95vw)] rounded-2xl bg-white p-4 shadow-panel">
                        <div class="flex items-center justify-between gap-2">
                            <button type="button" data-calendar-nav="prev" class="rounded-lg border border-brand-secondary px-2 py-1 text-sm font-bold text-brand-text/70 transition hover:bg-brand-secondary/20">&lt;</button>
                            <div class="grid flex-1 grid-cols-2 gap-2 text-center">
                                <p data-calendar-label="left" class="font-heading text-sm font-bold text-brand-text"></p>
                                <p data-calendar-label="right" class="font-heading text-sm font-bold text-brand-text"></p>
                            </div>
                            <button type="button" data-calendar-nav="next" class="rounded-lg border border-brand-secondary px-2 py-1 text-sm font-bold text-brand-text/70 transition hover:bg-brand-secondary/20">&gt;</button>
                        </div>
                        <div class="mt-3 grid gap-3 md:grid-cols-2">
                            <div data-calendar-month="left" class="p-2"></div>
                            <div data-calendar-month="right" class="p-2"></div>
                        </div>
                        <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-brand-secondary pt-3">
                            <div data-date-shortcuts class="flex flex-wrap gap-2"></div>
                            <div class="flex flex-wrap gap-2">
                                <button type="button" data-date-clear class="app-cta-button app-cta-button--neutral px-4 py-1.5 text-sm">Clear dates</button>
                                <button type="button" data-date-apply class="app-cta-button app-cta-button--nav px-4 py-1.5 text-sm">Apply</button>
                            </div>
                        </div>
                    </div>
                </div>

                <a
                    href="/reports"
                    class="app-breadcrumb app-breadcrumb--interactive"
                >
                    Clear
                </a>
            </form>
            <span class="ml-auto rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
                <%= safeReports.length %> reports shown
            </span>
        </div>

        <div class="space-y-2 overflow-x-auto">
            <div class="grid min-w-[860px] grid-cols-[0.9fr_1.8fr_1.3fr_1fr_0.7fr] gap-2 rounded-xl border border-brand-secondary bg-brand-bg px-3 py-2 text-xs font-bold uppercase tracking-wide text-brand-text/65">
                <p>Type</p>
                <p>Subject</p>
                <p>Report Period</p>
                <p>Generated</p>
                <p class="text-right">Action</p>
            </div>

            <% if (!safeReports.length) { %>
                <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
                    No reports match the selected filters.
                </p>
            <% } %>

            <% safeReports.forEach((report) => { %>
                <% const reportType = String(report.type || '').toUpperCase(); %>
                <div class="grid min-w-[860px] grid-cols-[0.9fr_1.8fr_1.3fr_1fr_0.7fr] items-center gap-2 rounded-xl border border-brand-secondary px-3 py-2 text-sm">
                    <div>
                        <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= reportTypeStyles[reportType] || 'bg-white text-brand-text/70' %>">
                            <%= formatReportType(report.type) %>
                        </span>
                    </div>
                    <p class="truncate font-medium text-brand-text">
                        <%= report.subjectLabel %>
                    </p>
                    <p class="text-xs font-semibold text-brand-text/70">
                        <%= formatHistoryDate(report.periodStart) %> - <%= formatHistoryDate(report.periodEnd) %>
                    </p>
                    <p class="text-xs font-semibold text-brand-text/70">
                        <%= formatHistoryDate(report.createdAt) %>
                    </p>
                    <div class="text-right">
                        <a
                            href="<%= report.url %>"
                            class="app-link-button app-link-button--nav py-1 text-xs"
                        >
                            View
                        </a>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>
</div>

<script src="/js/dateRangePicker.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.querySelector('[data-report-history-filter]');
        const typeSelect = document.querySelector('[data-report-history-type]');
        const subjectSelect = document.querySelector('[data-report-history-subject]');
        const dateApplyButton = document.querySelector('[data-date-apply]');
        const dateClearButton = document.querySelector('[data-date-clear]');
        const startInput = document.querySelector('[data-start-value]');
        const endInput = document.querySelector('[data-end-value]');
        const dateLabel = document.querySelector('[data-start-display]');

        if (!form || !typeSelect || !subjectSelect) {
            return;
        }

        const submitFilters = function submitFilters() {
            form.requestSubmit();
        };

        const syncSubjects = function syncSubjects() {
            const selectedType = typeSelect.value;

            subjectSelect.querySelectorAll('option[data-report-type]').forEach((option) => {
                const matchesType = selectedType === 'ALL' || option.dataset.reportType === selectedType;

                option.hidden = !matchesType;

                if (!matchesType && option.selected) {
                    subjectSelect.value = '';
                }
            });
        };

        typeSelect.addEventListener('change', () => {
            syncSubjects();
            submitFilters();
        });

        subjectSelect.addEventListener('change', submitFilters);

        if (dateApplyButton) {
            dateApplyButton.addEventListener('click', () => {
                setTimeout(submitFilters, 0);
            });
        }

        if (dateClearButton) {
            dateClearButton.addEventListener('click', () => {
                if (startInput) {
                    startInput.value = '';
                }

                if (endInput) {
                    endInput.value = '';
                }

                if (dateLabel) {
                    dateLabel.textContent = 'Select Date Range';
                }

                submitFilters();
            });
        }

        syncSubjects();
    });
</script>
