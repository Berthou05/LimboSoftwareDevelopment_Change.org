<%
    const safeEmployeeReports = Array.isArray(employeeReports) ? employeeReports : [];
    const safeProjectReports = Array.isArray(projectReports) ? projectReports : [];
    const safeTeamReports = Array.isArray(teamReports) ? teamReports : [];
    const totalReports = safeEmployeeReports.length + safeProjectReports.length + safeTeamReports.length;

    const formatHistoryDate = function formatHistoryDate(value, options) {
        if (!value) {
            return 'Unknown date';
        }

        const date = new Date(value);

        if (Number.isNaN(date.getTime())) {
            return 'Unknown date';
        }

        return date.toLocaleDateString('en-US', options || {
            month: 'short',
            day: 'numeric',
            year: 'numeric',
        });
    };

    const formatHistoryPeriod = function formatHistoryPeriod(report) {
        return `${formatHistoryDate(report.periodStart, {
            month: 'short',
            day: 'numeric',
            year: 'numeric',
        })} - ${formatHistoryDate(report.periodEnd, {
            month: 'short',
            day: 'numeric',
            year: 'numeric',
        })}`;
    };

    const reportSections = [
        {
            id: 'employee-reports',
            title: 'Employee Reports',
            description: 'Your latest employee reports.',
            emptyMessage: 'No employee reports generated yet.',
            reports: safeEmployeeReports,
        },
        {
            id: 'project-reports',
            title: 'Project Reports',
            description: 'Your latest project reports.',
            emptyMessage: 'No project reports generated yet.',
            reports: safeProjectReports,
        },
        {
            id: 'team-reports',
            title: 'Team Reports',
            description: 'Your latest team reports.',
            emptyMessage: 'No team reports generated yet.',
            reports: safeTeamReports,
        },
    ];
%>

<%- include('../partials/pageHeader', {
    title: pageTitle,
    subtitle: pageSubtitle,
}) %>

<section class="mx-auto max-w-6xl space-y-8">
    <% reportSections.forEach((section) => { %>
        <section id="<%= section.id %>" class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
            <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
                <div>
                    <h2 class="font-heading text-xl font-bold text-brand-text"><%= section.title %></h2>
                    <p class="mt-1 text-sm text-brand-text/60"><%= section.description %></p>
                </div>
                <span class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
                    <%= section.reports.length %> of <%= totalReports %> shown
                </span>
            </div>

            <div class="space-y-2 overflow-x-auto">
                <div class="grid min-w-[760px] grid-cols-[1.7fr_1fr_1.5fr_0.8fr] gap-2 rounded-xl border border-brand-secondary bg-brand-bg px-3 py-2 text-xs font-bold uppercase tracking-wide text-brand-text/65">
                    <p>Subject</p>
                    <p>Generated at</p>
                    <p>Reporting period</p>
                    <p>Open</p>
                </div>

                <% if (!section.reports.length) { %>
                    <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
                        <%= section.emptyMessage %>
                    </p>
                <% } %>

                <% section.reports.forEach((report) => { %>
                    <div class="grid min-w-[760px] grid-cols-[1.7fr_1fr_1.5fr_0.8fr] items-center gap-2 rounded-xl border border-brand-secondary px-3 py-2 text-sm">
                        <div class="min-w-0">
                            <p class="truncate font-medium text-brand-text"><%= report.subjectLabel %></p>
                            <p class="text-xs uppercase tracking-wide text-brand-text/50">
                                <%= String(report.type || '').toLowerCase() %> report
                            </p>
                        </div>
                        <p class="text-brand-text/80"><%= formatHistoryDate(report.createdAt) %></p>
                        <p class="text-brand-text/80"><%= formatHistoryPeriod(report) %></p>
                        <div>
                            <a
                                href="<%= report.url %>"
                                class="inline-flex rounded-lg border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text transition hover:bg-brand-secondary/15"
                            >
                                View
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>
    <% }) %>
</section>
