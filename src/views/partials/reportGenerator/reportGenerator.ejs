<%# Template: partials/reportGenerator.ejs
   Purpose: Reusable report generation form with enhanced calendar picker.
   Expected locals: redirectTo, defaultReportType, defaultSubjectId, reportSubjects, latestReports (optional), quickReport (optional), layout (optional: 'full' or 'compact').
   JS integration: Uses data-report-generator="enhanced" for calendar behavior in dateRangePicker.js.
%>

<%
  const typeLabel = { EMPLOYEE: 'Employee', TEAM: 'Team', PROJECT: 'Project' };
  const currentType = defaultReportType || 'EMPLOYEE';
  const currentTypeLabel = typeLabel[currentType] || 'Report';
  const isFullLayout = (typeof layout !== 'undefined' && layout === 'full');
  
  // Build catalog for full layout search
  const subjectCatalog = {
    EMPLOYEE: reportSubjects.employees || [],
    TEAM: reportSubjects.teams || [],
    PROJECT: reportSubjects.projects || [],
  };
  
  // Get subjects for compact layout
  let currentSubjects = [];
  if (currentType === 'EMPLOYEE') {
    currentSubjects = reportSubjects.employees || [];
  } else if (currentType === 'TEAM') {
    currentSubjects = reportSubjects.teams || [];
  } else if (currentType === 'PROJECT') {
    currentSubjects = reportSubjects.projects || [];
  }
  
  const showSubjectSelector = currentSubjects.length > 1;
  const singleSubjectId = currentSubjects.length === 1 ? currentSubjects[0].id : null;
  
  // Calculate default dates - current quarter for full layout / EMPLOYEE, last week for TEAM/PROJECT
  const now = new Date();
  let defaultPeriodStart, defaultPeriodEnd;
  
  if (typeof quickReport !== 'undefined' && quickReport.periodStart) {
    defaultPeriodStart = quickReport.periodStart;
    defaultPeriodEnd = quickReport.periodEnd;
  } else {
    const quarter = Math.floor(now.getMonth() / 3);
    const quarterStart = new Date(now.getFullYear(), quarter * 3, 1);
    const quarterEnd = new Date(now.getFullYear(), (quarter + 1) * 3, 0);
    defaultPeriodStart = quarterStart.toISOString().split('T')[0];
    defaultPeriodEnd = quarterEnd.toISOString().split('T')[0];
  }
  
  const resolvedSubjectId = defaultSubjectId || singleSubjectId || '';
  const resolvedSubject = currentSubjects.find((subject) => {
    return String(subject.id || '') === String(resolvedSubjectId || '');
  }) || null;
  const resolvedSubjectLabel = resolvedSubject
    ? (resolvedSubject.label || resolvedSubject.name || currentTypeLabel)
    : currentTypeLabel;
  const normalizedLatestReports = (
    typeof latestReports === 'object'
    && latestReports !== null
  ) ? latestReports : {};
  //TODO: Review code
  const latestReport = normalizedLatestReports[currentType] || (
    resolvedSubjectId
      ? {
          subjectLabel: resolvedSubjectLabel,
          createdAt: now,
          periodStart: defaultPeriodStart,
          periodEnd: defaultPeriodEnd,
        }
      : null
  );
  
  const currentYear = now.getFullYear();
%>

<div class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel" data-report-generator-card>
  <% if (isFullLayout) { %>
    <%# ===================== FULL LAYOUT (Home page - Primary action module) ===================== %>
    <div class="mb-5">
      <h2 class="font-heading text-2xl font-bold text-brand-text">Generate Report</h2>
      <p class="mt-1 text-sm text-brand-text/60">Create reports for employees, teams, or projects</p>
    </div>

    <form action="/reports/generate" method="POST" class="space-y-5" data-report-generator="enhanced" data-current-year="<%= currentYear %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="redirectTo" value="<%= redirectTo || '/reports' %>" />

      <%# Row 1: Content type and Search %>
      <div class="grid gap-4 md:grid-cols-2">
        <label class="block">
          <span class="mb-2 block text-sm font-semibold text-brand-text/70">Content Type</span>
          <select
            name="contentType"
            class="report-type w-full rounded-xl border border-brand-secondary px-4 py-3 text-sm font-medium outline-none ring-brand-primary/30 focus:ring"
            data-default="<%= currentType %>"
          >
            <option value="EMPLOYEE">Employee</option>
            <option value="TEAM">Team</option>
            <option value="PROJECT">Project</option>
          </select>
        </label>

        <label class="relative block">
          <span class="mb-2 block text-sm font-semibold text-brand-text/70">Search Subject</span>
          <div class="flex items-center rounded-xl border border-brand-secondary bg-white px-4">
            <svg class="h-4 w-4 shrink-0 text-brand-text/50" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.5"></circle>
              <path d="M13.5 13.5L18 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
            </svg>
            <input
              type="search"
              placeholder="Search..."
              class="report-search w-full border-none bg-transparent px-3 py-3 text-sm outline-none"
              autocomplete="off"
            />
            <input type="hidden" name="subjectId" class="report-subject-id" value="" required />
          </div>
          <div class="report-search-results absolute z-30 mt-1 hidden w-full rounded-xl border border-brand-secondary bg-white p-1 shadow-panel"></div>
        </label>
      </div>

      <%# Embed subject catalog as JSON for client-side search %>
      <script type="application/json" class="report-subject-catalog"><%-JSON.stringify(subjectCatalog)%></script>

      <%# Row 2: Quick Range + Date Range %>
      <div class="space-y-3">
        <div>
          <div class="mb-2 flex items-center justify-between gap-3">
            <span class="block text-sm font-semibold text-brand-text/70">Quick Range</span>
            <span class="text-xs text-brand-text/50">Changes by report type</span>
          </div>
          <div data-range-presets class="flex flex-wrap gap-2"></div>
        </div>

        <div class="relative">
          <span class="mb-2 block text-sm font-semibold text-brand-text/70">Date Range</span>
          <div data-date-trigger class="grid cursor-pointer gap-3 sm:grid-cols-2">
            <div class="px-4 py-3">
              <p class="text-xs font-semibold uppercase tracking-wide text-brand-text/50">Start Date</p>
              <input data-start-display type="text" readonly class="mt-1 w-full appearance-none border-none bg-transparent p-0 text-base font-bold text-brand-text outline-none cursor-pointer" value="" />
            </div>
            <div class="px-4 py-3">
              <p class="text-xs font-semibold uppercase tracking-wide text-brand-text/50">End Date</p>
              <input data-end-display type="text" readonly class="mt-1 w-full appearance-none border-none bg-transparent p-0 text-base font-bold text-brand-text outline-none cursor-pointer" value="" />
            </div>
          </div>

          <input data-start-value type="hidden" name="periodStart" value="<%= defaultPeriodStart %>" required />
          <input data-end-value type="hidden" name="periodEnd" value="<%= defaultPeriodEnd %>" required />

          <div data-date-popover class="absolute left-0 z-40 mt-2 hidden w-[min(44rem,95vw)] rounded-2xl bg-white p-4 shadow-panel">
            <div class="flex items-center justify-between gap-2">
              <button type="button" data-calendar-nav="prev" class="rounded-lg border border-brand-secondary px-2 py-1 text-sm font-bold text-brand-text/70 transition hover:bg-brand-secondary/20">&lt;</button>
              <div class="grid flex-1 grid-cols-2 gap-2 text-center">
                <p data-calendar-label="left" class="font-heading text-sm font-bold text-brand-text"></p>
                <p data-calendar-label="right" class="font-heading text-sm font-bold text-brand-text"></p>
              </div>
              <button type="button" data-calendar-nav="next" class="rounded-lg border border-brand-secondary px-2 py-1 text-sm font-bold text-brand-text/70 transition hover:bg-brand-secondary/20">&gt;</button>
            </div>
            <div class="mt-3 grid gap-3 md:grid-cols-2">
              <div data-calendar-month="left" class="p-2"></div>
              <div data-calendar-month="right" class="p-2"></div>
            </div>
            <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-brand-secondary pt-3">
              <div data-date-shortcuts class="flex flex-wrap gap-2"></div>
              <button type="button" data-date-apply class="rounded-xl border border-brand-primary bg-brand-primary px-4 py-1.5 text-sm font-semibold text-white transition hover:bg-brand-accent">Apply</button>
            </div>
          </div>
        </div>
      </div>

      <%# Row 3: Submit Button %>
      <button type="submit" class="w-full rounded-xl border-2 border-brand-primary bg-brand-primary px-6 py-3 text-base font-bold text-white shadow-sm transition hover:bg-brand-accent hover:border-brand-accent">
        Generate Report
      </button>
    </form>

    <% if (latestReport) { %>
      <div class="mt-5 border-t border-brand-secondary pt-5">
        <p class="text-xs font-semibold uppercase tracking-wide text-brand-text/50">Last Generated Report</p>
        <div class="mt-3 flex items-center justify-between rounded-xl border border-brand-secondary bg-brand-bg/30 p-4">
          <div>
            <p class="font-semibold text-brand-text"><%= latestReport.subjectLabel %></p>
            <p class="mt-1 text-sm text-brand-text/60">
              <span data-latest-report-created-at><%= new Date(latestReport.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
              &middot;
              <span data-latest-report-period><%= new Date(latestReport.periodStart).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %> - <%= new Date(latestReport.periodEnd).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
            </p>
          </div>
          <a href="/reports/view/<%= String(currentType || 'EMPLOYEE').toLowerCase() %>?redirectTo=<%= encodeURIComponent(redirectTo || '/home') %>" class="rounded-lg border border-brand-secondary px-3 py-1.5 text-sm font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white">View</a>
        </div>
      </div>
    <% } %>
  <% } else { %>
    <%# ===================== COMPACT LAYOUT (Detail pages with stacked dates + button) ===================== %>
    <p class="text-xs font-semibold uppercase tracking-wide text-brand-text/60">Report Generator</p>

    <form action="/reports/generate" method="POST" class="mt-4" data-report-generator="enhanced" data-current-year="<%= currentYear %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="redirectTo" value="<%= redirectTo || '/reports' %>" />
      <input type="hidden" name="contentType" value="<%= currentType %>" />
      
      <% if (defaultSubjectId) { %>
        <%# On detail pages, always use the page's subject %>
        <input type="hidden" name="subjectId" value="<%= defaultSubjectId %>" />
      <% } else if (!showSubjectSelector && singleSubjectId) { %>
        <input type="hidden" name="subjectId" value="<%= singleSubjectId %>" />
      <% } %>
      
      <div class="space-y-4">
        <% if (!defaultSubjectId && showSubjectSelector) { %>
          <label class="block text-sm">
            <span class="mb-2 block font-semibold text-brand-text/70">Select <%= currentTypeLabel.toLowerCase() %>:</span>
            <select
              name="subjectId"
              required
              class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
            >
              <option value="">Select <%= currentTypeLabel.toLowerCase() %></option>
              <% currentSubjects.forEach((subject) => { %>
                <option value="<%= subject.id %>" <%= subject.id === defaultSubjectId ? 'selected' : '' %>><%= subject.label || subject.name %></option>
              <% }); %>
            </select>
          </label>
        <% } %>

        <div class="space-y-3">
          <div>
            <div class="mb-2 flex items-center justify-between gap-3">
              <span class="block font-semibold text-brand-text/70">Quick Range</span>
              <span class="text-xs text-brand-text/50">Changes by report type</span>
            </div>
            <div data-range-presets class="flex flex-wrap gap-2"></div>
          </div>

          <div class="relative block text-sm">
            <span class="mb-2 block font-semibold text-brand-text/70">Date Range</span>
            <div data-date-trigger class="grid cursor-pointer gap-2 sm:grid-cols-2">
              <div class="rounded-xl border border-brand-secondary bg-white px-3 py-2">
                <p class="text-xs font-semibold text-brand-text/60">Start Date</p>
                <input data-start-display type="text" readonly class="mt-1 w-full appearance-none border-none bg-transparent p-0 text-sm font-semibold outline-none cursor-pointer" value="" />
              </div>
              <div class="rounded-xl border border-brand-secondary bg-white px-3 py-2">
                <p class="text-xs font-semibold text-brand-text/60">End Date</p>
                <input data-end-display type="text" readonly class="mt-1 w-full appearance-none border-none bg-transparent p-0 text-sm font-semibold outline-none cursor-pointer" value="" />
              </div>
            </div>

            <input data-start-value type="hidden" name="periodStart" value="<%= defaultPeriodStart %>" required />
            <input data-end-value type="hidden" name="periodEnd" value="<%= defaultPeriodEnd %>" required />

            <div data-date-popover class="absolute right-0 z-40 mt-2 hidden w-[min(44rem,95vw)] rounded-2xl bg-white p-4 shadow-panel">
              <div class="flex items-center justify-between gap-2">
                <button type="button" data-calendar-nav="prev" class="rounded-lg border border-brand-secondary px-2 py-1 text-sm font-bold text-brand-text/70 transition hover:bg-brand-secondary/20">&lt;</button>
                <div class="grid flex-1 grid-cols-2 gap-2 text-center">
                  <p data-calendar-label="left" class="font-heading text-sm font-bold text-brand-text"></p>
                  <p data-calendar-label="right" class="font-heading text-sm font-bold text-brand-text"></p>
                </div>
                <button type="button" data-calendar-nav="next" class="rounded-lg border border-brand-secondary px-2 py-1 text-sm font-bold text-brand-text/70 transition hover:bg-brand-secondary/20">&gt;</button>
              </div>
              <div class="mt-3 grid gap-3 md:grid-cols-2">
                <div data-calendar-month="left" class="p-2"></div>
                <div data-calendar-month="right" class="p-2"></div>
              </div>
              <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-brand-secondary pt-3">
                <div data-date-shortcuts class="flex flex-wrap gap-2"></div>
                <button type="button" data-date-apply class="rounded-xl border border-brand-primary bg-brand-primary px-4 py-1.5 text-sm font-semibold text-white transition hover:bg-brand-accent">Apply</button>
              </div>
            </div>
          </div>
        </div>

        <button type="submit" class="w-full rounded-xl border border-brand-primary bg-brand-primary px-5 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent">
          Generate Report
        </button>
      </div>
    </form>

    <% if (latestReport) { %>
      <div class="mt-4 border-t border-brand-secondary pt-4">
        <p class="text-xs font-semibold uppercase tracking-wide text-brand-text/60">Last Generated Report</p>
        <div class="mt-2 flex items-center justify-between rounded-lg border border-brand-secondary p-3">
          <div>
            <p class="text-sm font-semibold text-brand-text"><%= latestReport.subjectLabel %></p>
            <p class="mt-1 text-xs text-brand-text/50">
              <span data-latest-report-created-at><%= new Date(latestReport.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
              &middot;
              <span data-latest-report-period><%= new Date(latestReport.periodStart).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %> - <%= new Date(latestReport.periodEnd).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
            </p>
          </div>
          <a href="/reports/view/<%= String(currentType || 'EMPLOYEE').toLowerCase() %>?redirectTo=<%= encodeURIComponent(redirectTo || '/home') %>" class="text-xs font-semibold text-brand-primary hover:text-brand-accent">View</a>
        </div>
      </div>
    <% } %>
  <% } %>
</div>

