<%
    const topbarSearchQuery = typeof globalSearchQuery !== 'undefined' ? globalSearchQuery : '';
%>

<form
    action="/search"
    method="GET"
    class="hidden flex-1 items-center gap-2 rounded-xl border border-brand-secondary bg-white px-3 py-2 shadow-sm sm:flex sm:max-w-lg"
    data-global-search
    data-search-endpoint="/search"
    data-search-debounce-ms="250"
>
    <div class="relative min-w-0 flex-1">
        <input
            type="text"
            name="q"
            value="<%= topbarSearchQuery %>"
            placeholder="Search for activities, employees, teams, or projects"
            autocomplete="off"
            aria-autocomplete="list"
            aria-controls="globalSearchSuggestions"
            aria-expanded="false"
            class="w-full min-w-0 border-none bg-transparent text-sm outline-none ring-0
                focus:outline-none focus:ring-0 focus:ring-transparent"
            data-global-search-input
        />
        <div
            id="globalSearchSuggestions"
            role="listbox"
            class="absolute z-30 hidden overflow-hidden
                rounded-2xl border border-brand-secondary bg-white shadow-panel"
            style="left: -0.75rem; right: 0; top: calc(100% + 0.75rem);"
            data-global-search-suggestions
        ></div>
    </div>

    <button type="submit" class="rounded-xl bg-brand-primary px-5 py-2 text-sm font-semibold text-black">
        Search
    </button>

    <p class="sr-only" data-global-search-status aria-live="polite"></p>
</form>
