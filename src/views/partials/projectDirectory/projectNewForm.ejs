<%
  const formState = projectForm || { name: '', description: '', startDate: '', endDate: '' };
  const validationErrors = formErrors || [];
%>

<section class="max-w-3xl space-y-6">
  <% if (formSuccess) { %>
    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
      <%= formSuccess %>
    </div>
  <% } %>

  <% if (formError) { %>
    <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      <%= formError %>
    </div>
  <% } %>

  <% if (validationErrors.length) { %>
    <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
      <% validationErrors.forEach((message) => { %>
        <p><%= message %></p>
      <% }) %>
    </div>
  <% } %>

  <form action="/projects" method="POST" class="rounded-2xl border border-brand-secondary bg-white p-6 shadow-panel">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="grid gap-5">
      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text/70">Project name</span>
        <input
          type="text"
          name="name"
          value="<%= formState.name %>"
          required
          maxlength="120"
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
          placeholder="AI Assisted Classification"
        />
      </label>

      <label class="block text-sm">
        <span class="mb-1 block font-semibold text-brand-text/70">Description</span>
        <textarea
          name="description"
          rows="4"
          class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
          placeholder="Describe the scope and purpose of the project."
        ><%= formState.description %></textarea>
      </label>

      <div class="grid gap-5 md:grid-cols-2">
        <label class="block text-sm">
          <span class="mb-1 block font-semibold text-brand-text/70">Start date</span>
          <input
            type="date"
            name="startDate"
            value="<%= formState.startDate %>"
            required
            class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
          />
        </label>

        <label class="block text-sm">
          <span class="mb-1 block font-semibold text-brand-text/70">End date</span>
          <input
            type="date"
            name="endDate"
            value="<%= formState.endDate %>"
            class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
          />
        </label>
      </div>
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
      <button type="submit" class="rounded-xl bg-brand-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-accent">
        Create project
      </button>
      <a href="/projects" class="rounded-xl border border-brand-secondary px-5 py-3 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30">
        Cancel
      </a>
    </div>
  </form>
</section>
