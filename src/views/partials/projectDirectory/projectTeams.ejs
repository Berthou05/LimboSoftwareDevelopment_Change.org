<article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
    <h2 class="font-heading text-xl font-bold text-brand-text">Teams Involved</h2>
    <div class="mt-4 space-y-2">
        <% const teamsDetailed = project?.teamsDetailed || []; %>
        <% if (!teamsDetailed.length) { %>
            <p class="text-sm text-brand-text/70">No teams are currently assigned to this project.</p>
        <% } %>
        <% teamsDetailed.forEach((team) => { %>
            <a href="/teams/<%= team.id %>" class="block rounded-lg border border-brand-secondary p-3 transition hover:bg-brand-bg/50">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                        <p class="truncate text-sm font-semibold text-brand-text"><%= team.name %></p>
                        <p class="mt-1 text-xs text-brand-text/60 line-clamp-2"><%= team.description || 'No team description available.' %></p>
                    </div>
                    <span class="shrink-0 text-xs font-semibold text-brand-text/50">View</span>
                </div>
                <div class="mt-3 flex flex-wrap gap-2">
                    <span class="inline-flex rounded-full border border-brand-secondary px-2 py-0.5 text-[10px] font-semibold text-brand-text/60">
                        <%= team.role || 'CONTRIBUTOR' %>
                    </span>
                    <span class="inline-flex rounded-full border border-brand-secondary px-2 py-0.5 text-[10px] font-semibold text-brand-text/60">
                        <%= team.status || 'Unknown' %>
                    </span>
                    <span class="inline-flex rounded-full border border-brand-secondary px-2 py-0.5 text-[10px] font-semibold text-brand-text/60">
                        Joined: <%= team.joinedAtLabel || 'Date unavailable' %>
                    </span>
                </div>
            </a>
        <% }) %>
    </div>
</article>
