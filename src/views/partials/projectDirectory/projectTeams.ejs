<section class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
    <div class="js-inline-picker">
        <div class="mb-3 flex items-center justify-between gap-3">
            <h2 class="font-heading text-xl font-semibold text-brand-text">Teams Involved</h2>
            <button type="button" class="js-picker-toggle panel-action-button panel-action-button--small">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
                Add
            </button>
        </div>

        <div class="mb-4 mt-3 max-h-48 space-y-2 overflow-y-auto">
            <% const teamsDetailed = project?.teamsDetailed || []; %>
            <% if (!teamsDetailed.length) { %>
                <p class="text-sm text-brand-text/70">No teams assigned.</p>
            <% } %>
            <% teamsDetailed.forEach((team) => { %>
                <div class="group flex items-center gap-2 rounded-lg p-2 transition hover:bg-brand-bg/50">
                    <a href="/teams/<%= team.id %>" class="flex min-w-0 flex-1 items-center gap-2">
                        <div class="app-directory-avatar flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[10px] font-bold">
                            <%= team.name ? team.name.split(' ').map((part) => part[0]).slice(0, 2).join('') : '?' %>
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="truncate text-xs font-semibold text-brand-text"><%= team.name || 'Unknown team' %></p>
                            <p class="truncate text-[10px] text-brand-text/50">
                                <%= team.memberCount %> <%= team.memberCount === 1 ? 'member' : 'members' %>
                                <span class="mx-1 text-brand-text/40">|</span>
                                Since <%= team.joinedAtLabel || 'Date unavailable' %>
                            </p>
                        </div>
                    </a>
                    <form class="js-inline-submit ml-2" action="/projects/<%= project.id || project.project_id %>/teams/<%= team.id %>/remove" method="POST" data-error-message="Failed to remove team.">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="rounded border border-red-200 px-2 py-1 text-xs text-red-500 opacity-0 transition group-hover:opacity-100" title="Remove from project">
                            Remove
                        </button>
                    </form>
                </div>
            <% }) %>
        </div>

        <div class="js-picker-panel hidden mt-2">
            <form class="js-picker-form relative" action="/projects/<%= project.id || project.project_id %>/teams" method="POST" autocomplete="off" data-error-message="Failed to add team.">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label class="mb-2 block text-sm font-semibold text-brand-text">Add team to project:</label>
                <div class="flex items-center rounded-xl border border-brand-secondary bg-white px-3">
                    <svg class="h-4 w-4 shrink-0 text-brand-text/50" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.5"></circle>
                        <path d="M13.5 13.5L18 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                    </svg>
                    <input name="addTeamSearch" type="search" placeholder="Search for a team..." class="js-picker-search w-full border-none bg-transparent px-3 py-2 text-sm outline-none" autocomplete="off" data-validation-message="Select a specific team from the suggestions." />
                    <input type="hidden" name="teamId" class="js-picker-id" required />
                </div>
                <div class="js-picker-results absolute z-30 mt-1 hidden w-full rounded-xl border border-brand-secondary bg-white p-1 shadow-panel"></div>
                <button type="submit" class="panel-action-button mt-2 w-full">Add to Project</button>
            </form>
            <script type="application/json" class="js-picker-catalog"><%- JSON.stringify((availableTeams || []).map((team) => ({ id: team.id, label: team.name }))) %></script>
        </div>
    </div>
</section>
