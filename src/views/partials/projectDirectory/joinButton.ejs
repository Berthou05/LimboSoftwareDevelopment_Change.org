<div class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
    <form action="/projects/<%= project?.id || project?.project_id %>/<%= projectMembership?.isMember ? 'leave' : 'join' %>" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button
            type="submit"
            <%= projectMembership?.canToggle ? '' : 'disabled' %>
            class="app-cta-button w-full <%= projectMembership?.canToggle
                ? (projectMembership?.isMember
                    ? 'app-cta-button--neutral'
                    : 'app-cta-button--highlight')
                : 'cursor-not-allowed border-brand-secondary bg-brand-bg/60 text-brand-text/50' %>"
        >
            <%= projectMembership?.buttonLabel || 'Join Project' %>
        </button>
    </form>
</div>
