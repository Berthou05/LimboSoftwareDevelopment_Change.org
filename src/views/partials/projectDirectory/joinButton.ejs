<div class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
    <% if (projectMembership?.isMember) { %>
        <form action="/projects/<%= project?.id || project?.project_id %>/leave" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button
                type="submit"
                <%= projectMembership?.canToggle ? '' : 'disabled' %>
                class="app-cta-button app-cta-button--neutral w-full <%= projectMembership?.canToggle ? '' : 'cursor-not-allowed border-brand-secondary bg-brand-bg/60 text-brand-text/50' %>"
            >
                <%= projectMembership?.buttonLabel || 'Leave Project' %>
            </button>
        </form>
    <% } else if (projectMembership?.canToggle) { %>
        <button
            type="button"
            data-popup-open="join-project-<%= project?.id || project?.project_id %>"
            class="app-cta-button app-cta-button--highlight w-full"
        >
            <%= projectMembership?.buttonLabel || 'Join Project' %>
        </button>
    <% } else { %>
        <button
            type="button"
            disabled
            class="app-cta-button w-full cursor-not-allowed border-brand-secondary bg-brand-bg/60 text-brand-text/50"
        >
            <%= projectMembership?.buttonLabel || 'Join Project' %>
        </button>
    <% } %>
</div>

<% if (!projectMembership?.isMember && projectMembership?.canToggle) { %>
    <%- include('../shared/actionPopup', {
        popupId: 'join-project-' + (project?.id || project?.project_id),
        popupTitle: 'Join Project',
        popupDescription: 'Select the role to use when joining this project.',
        popupAction: '/projects/' + (project?.id || project?.project_id) + '/join',
        popupMethod: 'POST',
        popupSubmitLabel: 'Join',
        popupErrorMessage: 'Failed to join project.',
        csrfToken,
        popupFields: [
            {
                name: 'role',
                label: 'Role',
                type: 'text',
                value: '',
                placeholder: 'e.g. Backend Lead, QA Reviewer, UX Support',
            },
        ],
    }) %>
<% } %>
