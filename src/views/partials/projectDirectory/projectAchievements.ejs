<article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <div class="flex items-start justify-between gap-3">
        <div>
            <h2 class="font-heading text-xl font-semibold text-brand-text">Achievements</h2>
            <p class="mt-1 text-sm text-brand-text/60">Key achievements delivered by this project</p>
        </div>
        <% if(hasPermission('PROJ-13')) {%>
            <%- include('../shared/actionButton', {
                buttonPopupOpen: 'project-add-achievement',
                buttonIcon: 'plus',
                buttonLabel: 'Add',
                buttonVariant: 'small',
                buttonAriaLabel: 'Add achievement',
            }) %>
        <% } %>
    </div>

    <% const achievementsDetailed = project?.achievementsDetailed || []; %>
    <div class="mt-5 space-y-3">
        <% if (!achievementsDetailed.length) { %>
            <p class="text-sm text-brand-text/70">No achievements registered for this project.</p>
        <% } %>
        <% achievementsDetailed.forEach((achievement) => { %>
            <div class="rounded-xl border border-brand-secondary p-4">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <div class="min-w-0 flex-1">
                        <h3 class="font-semibold text-brand-text"><%= achievement.title %></h3>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-brand-text/50"><%= achievement.achievementDateLabel || 'Date unavailable' %></span>
                        <% if(hasPermission('PROJ-14')) {%>
                            <%- include('../shared/actionButton', {
                                buttonPopupOpen: 'edit-achievement-' + achievement.id,
                                buttonIcon: 'edit',
                                buttonLabel: 'Edit',
                                buttonVariant: 'small',
                                buttonAriaLabel: 'Edit achievement',
                            }) %>
                        <% } %>
                        <% if(hasPermission('PROJ-15')) {%>
                            <%- include('../shared/actionButton', {
                                buttonPopupOpen: 'delete-achievement-' + achievement.id,
                                buttonIcon: 'trash',
                                buttonLabel: 'Delete',
                                buttonVariant: 'small',
                                buttonAriaLabel: 'Delete achievement',
                            }) %>
                        <% } %>
                    </div>
                </div>
                <p class="mt-2 text-sm text-brand-text/70"><%= achievement.description %></p>
                <p class="mt-2 text-xs text-brand-text/50">By: <%= achievement.authorName || 'Unknown' %></p>
                <% if (achievement.evidenceLink) { %>
                    <a href="<%= achievement.evidenceLink %>" target="_blank" rel="noreferrer" class="mt-3 inline-flex rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold text-brand-text/70 transition hover:bg-brand-secondary/30">
                        Evidence
                    </a>
                <% } %>
            </div>

            <%- include('../shared/actionPopup', {
                popupId: 'edit-achievement-' + achievement.id,
                popupTitle: 'Edit Achievement',
                popupDescription: 'Update the achievement details shown in this card.',
                popupAction: '/projects/' + (project?.id || project?.project_id || '') + '/achievements/' + achievement.id + '/edit',
                popupMethod: 'POST',
                csrfToken,
                popupFields: [
                    { name: 'title', label: 'Title', value: achievement.title || '', placeholder: 'Achievement title' },
                    { name: 'description', label: 'Description', type: 'textarea', rows: 4, value: achievement.description || '', placeholder: 'Describe the achievement.' },
                    { name: 'achievementDate', label: 'Achievement date', type: 'date', value: achievement.achievementDate || '' },
                    { name: 'evidenceLink', label: 'Evidence link', value: achievement.evidenceLink || '', placeholder: 'https://...' },
                ],
            }) %>

            <%- include('../shared/actionPopup', {
                popupId: 'delete-achievement-' + achievement.id,
                popupTitle: 'Delete Achievement',
                popupDescription: 'Confirm if you want to remove this achievement from the project.',
                popupAction: '/projects/' + (project?.id || project?.project_id || '') + '/achievements/' + achievement.id + '/remove',
                popupMethod: 'POST',
                csrfToken,
                popupFields: [],
                popupSubmitLabel: 'Delete',
                popupSubmitTone: 'danger',
            }) %>
        <% }) %>
    </div>
</article>

<%- include('../shared/actionPopup', {
    popupId: 'project-add-achievement',
    popupTitle: 'Add Achievement',
    popupDescription: 'Register a new achievement for this project.',
    popupAction: '/projects/' + (project?.id || project?.project_id || '') + '/achievements',
    popupMethod: 'POST',
    csrfToken,
    popupFields: [
        { name: 'title', label: 'Title', value: '', placeholder: 'Delivered MVP' },
        { name: 'description', label: 'Description', type: 'textarea', rows: 4, value: '', placeholder: 'Describe the outcome delivered by the team.' },
        { name: 'achievementDate', label: 'Achievement date', type: 'date', value: '' },
        { name: 'evidenceLink', label: 'Evidence link', value: '', placeholder: 'https://...' },
    ],
}) %>

