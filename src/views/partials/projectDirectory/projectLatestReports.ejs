<article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <h2 class="font-heading text-2xl font-bold text-brand-text">Latest Reports</h2>
    <p class="mt-1 text-sm text-brand-text/60">Reports you have generated for this project</p>

    <% const latestReportsDetailed = project?.latestReportsDetailed || []; %>
    <div class="mt-5 space-y-3">
        <% if (!latestReportsDetailed.length) { %>
            <p class="text-sm text-brand-text/70">You have not generated reports for this project yet.</p>
        <% } %>
        <% latestReportsDetailed.forEach((report) => { %>
            <div class="rounded-xl border border-brand-secondary p-4">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <h3 class="font-semibold text-brand-text">Report <%= report.id %></h3>
                    <span class="text-xs text-brand-text/50"><%= report.createdAtLabel || 'Date unavailable' %></span>
                </div>
                <p class="mt-2 text-xs text-brand-text/50">
                    Period: <%= report.periodStartLabel || 'Unknown' %> - <%= report.periodEndLabel || 'Unknown' %>
                </p>
                <p class="mt-2 text-sm text-brand-text/70"><%= report.preview %></p>
                <p class="mt-3 text-[11px] text-brand-text/50">Model: <%= report.modelLabel %></p>
            </div>
        <% }) %>
    </div>
</article>
