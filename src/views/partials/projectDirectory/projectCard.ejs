<%
    const cardClasses = project.isMember
        ? 'app-directory-card--active'
        : 'border border-brand-secondary';
    const placeholderInitial = (project.name || 'T').trim().charAt(0).toUpperCase();
%>

<article class="rounded-2xl bg-white p-4 shadow-panel <%= cardClasses %>">
    <div class="flex items-start justify-between gap-3">
        <div>
            <h3 class="font-heading text-lg font-bold text-brand-text"><%= project.name %></h3>
            <p class="text-sm text-brand-text/70">Lead: <%= project.leadName %></p>
        </div>
        <% if (project.canArchive) { %>
            <div class="shrink-0">
                <%- include('../shared/actionButton', {
                    buttonPopupOpen: 'delete-project-directory-' + project.id,
                    buttonIcon: 'trash',
                    buttonLabel: 'Delete',
                    buttonVariant: 'small',
                    buttonAriaLabel: 'Delete project',
                }) %>
            </div>
        <% } %>
    </div>
    <p class="mt-3 text-sm text-brand-text/80">
        <%= project.description || 'No description available.' %>
    </p>
    <a
        href="/projects/<%= project.id %>"
        class="app-link-button app-link-button--nav mt-4"
    >
        Open project
    </a>
</article>

<% if (project.canArchive) { %>
    <div data-popup="delete-project-directory-<%= project.id %>" class="fixed inset-0 z-50 hidden bg-brand-text/35 px-4 py-8">
        <div class="mx-auto max-w-lg">
            <div class="rounded-3xl border border-brand-secondary bg-white p-6 shadow-panel">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h3 class="font-heading text-2xl font-bold text-brand-text">Delete Project</h3>
                        <p class="mt-1 text-sm text-brand-text/60">
                            Confirm if you want to remove this project from the active project list.
                        </p>
                    </div>
                    <%- include('../shared/actionButton', {
                        buttonPopupClose: true,
                        buttonIcon: 'close',
                        buttonVariant: 'icon-only',
                        buttonClasses: 'shrink-0',
                        buttonAriaLabel: 'Close popup',
                    }) %>
                </div>

                <form
                    action="/projects/<%= project.id %>/delete"
                    method="POST"
                    data-project-directory-delete-form
                    data-error-message="The project could not be deleted right now."
                    class="mt-5 space-y-4"
                >
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="flex flex-wrap justify-end gap-3 pt-2">
                        <button
                            type="button"
                            data-popup-close
                            class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20"
                        >
                            Cancel
                        </button>
                        <button
                            type="submit"
                            class="rounded-xl border border-red-500 bg-red-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-600"
                        >
                            Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
<% } %>
