<%
    const cardClasses = project.isMember
        ? 'app-directory-card--active'
        : 'border border-brand-secondary';
    const placeholderInitial = (project.name || 'T').trim().charAt(0).toUpperCase();
%>

<article class="rounded-2xl bg-white p-4 shadow-panel <%= cardClasses %>">
    <div class="flex items-center gap-3">
        <% if (project.image) { %>
            <img
                src="<%= project.image %>"
                alt="<%= project.name %>"
                class="h-14 w-14 rounded-xl object-cover"
            />
        <% } else { %>
            <div
                class="app-directory-avatar flex h-14 w-14 items-center justify-center rounded-xl bg-brand-bg
                    text-lg font-bold"
            >
                <%= placeholderInitial %>
            </div>
        <% } %>
        <div>
            <h3 class="font-heading text-lg font-bold text-brand-text"><%= project.name %></h3>
            <p class="text-sm text-brand-text/70">Lead: <%= project.leadName %></p>
        </div>
    </div>
    <p class="mt-3 text-sm text-brand-text/80">
        <%= project.description || 'No description available.' %>
    </p>
    <a
        href="/projects/<%= project.id %>"
        class="app-link-button app-link-button--nav mt-4"
    >
        Open project
    </a>
</article>
