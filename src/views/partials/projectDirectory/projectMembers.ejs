<article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
    <div class="flex items-center justify-between gap-3">
        <h2 class="font-heading text-xl font-bold text-brand-text">Project Members</h2>
        <button
            type="button"
            data-popup-open="project-add-member"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-brand-secondary text-lg font-semibold text-brand-text/70 transition hover:bg-brand-secondary/20"
            aria-label="Add project member"
        >
            +
        </button>
    </div>
    <div class="mt-4 max-h-64 space-y-2 overflow-y-auto">
        <% const membersDetailed = project?.membersDetailed || []; %>
        <% if (!membersDetailed.length) { %>
            <p class="text-sm text-brand-text/70">No active collaborators are assigned to this project.</p>
        <% } %>
        <% membersDetailed.forEach((member) => { %>
            <a href="/employees/<%= member.id %>" class="flex items-center gap-2 rounded-lg p-2 transition hover:bg-brand-bg/50">
                <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-primary/10 text-[10px] font-bold text-brand-primary">
                    <%= member.fullName ? member.fullName.split(' ').map((part) => part[0]).slice(0, 2).join('') : '?' %>
                </div>
                <div class="min-w-0 flex-1">
                    <p class="truncate text-xs font-semibold text-brand-text"><%= member.fullName || 'Unknown' %></p>
                    <p class="truncate text-[10px] text-brand-text/50"><%= member.description || 'Collaborator' %></p>
                    <p class="truncate text-[10px] text-brand-text/40">Joined: <%= member.startedAtLabel || 'Date unavailable' %></p>
                </div>
            </a>
        <% }) %>
    </div>
</article>

<%- include('./actionPopup', {
    popupId: 'project-add-member',
    popupTitle: 'Add Project Member',
    popupDescription: 'Assign a collaborator directly to this project.',
    popupFields: [
        { name: 'memberName', label: 'Employee', value: '', placeholder: 'Camila Hurtado' },
        { name: 'description', label: 'Collaboration description', type: 'textarea', rows: 3, value: '', placeholder: 'Describe how this collaborator contributes.' },
        { name: 'startedAt', label: 'Start date', type: 'date', value: '' },
    ],
}) %>
