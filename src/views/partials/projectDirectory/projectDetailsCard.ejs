<%
    const projectImage = project?.image || null;
    const leadName = project?.lead?.fullName || project?.lead_name || 'Unknown';
%>

<div class="space-y-4">
    <div class="flex items-start justify-between gap-4">
        <div class="flex flex-wrap items-center gap-4">
            <% if (projectImage) { %>
                <img src="<%= projectImage %>" alt="<%= project?.name || 'Project' %>" class="h-16 w-16 shrink-0 rounded-full border border-brand-secondary object-cover" />
            <% } else { %>
                <div class="app-directory-avatar flex h-16 w-16 shrink-0 items-center justify-center rounded-full border border-brand-secondary bg-brand-bg text-xl font-bold">
                    <%= (project?.name || 'P').trim().charAt(0).toUpperCase() %>
                </div>
            <% } %>
            <div class="min-w-0 flex-1">
                <h1 class="font-heading text-2xl font-bold text-brand-text sm:text-3xl"><%= project?.name || 'Project' %></h1>
                <p class="text-sm text-brand-text/70"><%= project?.description || 'No project description has been added yet.' %></p>
            </div>
        </div>
        <%- include('../shared/actionButton', {
            buttonPopupOpen: 'project-edit-info',
            buttonIcon: 'edit',
            buttonLabel: 'Edit',
            buttonVariant: 'small',
            buttonClasses: 'shrink-0',
            buttonAriaLabel: 'Edit project information',
        }) %>
    </div>
    <div class="flex flex-wrap gap-2 text-xs text-brand-text/70">
        <span class="app-breadcrumb app-breadcrumb--static">
            <%= project?.status || 'Unknown' %>
        </span>
        <span class="app-breadcrumb app-breadcrumb--static">
            Lead: <%= leadName %>
        </span>
        <span class="app-breadcrumb app-breadcrumb--static">
            Start: <%= project?.startDateLabel || 'N/A' %>
        </span>
        <span class="app-breadcrumb app-breadcrumb--static">
            End: <%= project?.endDateLabel || 'In progress' %>
        </span>
    </div>
</div>

<%- include('./actionPopup', {
    popupId: 'project-edit-info',
    popupTitle: 'Edit Project Information',
    popupDescription: 'Update the main information displayed in the project description card.',
    popupFields: [
        { name: 'name', label: 'Project name', value: project?.name || '', placeholder: 'AI Assisted Classification' },
        { name: 'description', label: 'Description', type: 'textarea', rows: 4, value: project?.description || '', placeholder: 'Describe the scope and purpose of the project.' },
        { name: 'status', label: 'Status', type: 'select', value: project?.status || 'IN PROGRESS', options: [
            { value: 'PLANNED', label: 'PLANNED' },
            { value: 'IN PROGRESS', label: 'IN PROGRESS' },
            { value: 'ON HOLD', label: 'ON HOLD' },
            { value: 'COMPLETED', label: 'COMPLETED' },
            { value: 'CANCELLED', label: 'CANCELLED' },
        ] },
        { name: 'startDate', label: 'Start date', type: 'date', value: project?.start_date || '' },
        { name: 'endDate', label: 'End date', type: 'date', value: project?.end_date || '' },
    ],
}) %>
