<%# Leave/Join Team %>
<div class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
    <form action="/teams/<%= team.id %>/toggle-membership" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button
            type="submit"
            class="app-cta-button w-full <%= isMember ? 'app-cta-button--neutral' : 'app-cta-button--highlight' %>"
        >
            <%= isMember ? 'Leave Team' : 'Join Team' %>
        </button>
    </form>
</div>
