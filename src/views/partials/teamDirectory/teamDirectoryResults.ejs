<% if (myTeams?.length) { %>
    <h2 class="mb-3 font-heading text-xl font-semibold text-brand-text">My Teams</h2>
    <div class="mb-8 grid gap-4 lg:grid-cols-2">
        <% for (const team of myTeams) { %>
            <%- include('./teamCard', { team, csrfToken }) %>
        <% } %>
    </div>
<% } %>

<% if (otherTeams?.length) { %>
    <h2 class="mb-3 font-heading text-xl font-semibold text-brand-text">Other Teams</h2>
    <div class="grid gap-4 lg:grid-cols-2">
        <% for (const team of otherTeams) { %>
            <%- include('./teamCard', { team, csrfToken }) %>
        <% } %>
    </div>
<% } %>

<% if (!myTeams?.length && !otherTeams?.length) { %>
    <p class="text-sm text-brand-text/60">No teams found.</p>
<% } %>
