<%
    const teamInitials = (team?.name || 'T')
        .trim()
        .split(/\s+/)
        .filter(Boolean)
        .slice(0, 2)
        .map((part) => part[0].toUpperCase())
        .join('') || 'T';
%>

<div class="flex flex-wrap items-center gap-4">
    <% if (team?.image) { %>
        <img src="<%= team.image %>" alt="<%= team.name %>" class="h-16 w-16 shrink-0 rounded-full border border-brand-secondary object-cover" />
    <% } else { %>
        <div class="app-directory-avatar flex h-16 w-16 shrink-0 items-center justify-center rounded-full border border-brand-secondary bg-brand-bg text-xl font-bold">
            <%= teamInitials %>
        </div>
    <% } %>
    <div class="flex-1 min-w-0">
        <h1 class="font-heading text-2xl font-bold text-brand-text sm:text-3xl"><%= team.name %></h1>
        <p class="text-sm text-brand-text/70"><%= team.description %></p>
    </div>
    <p class="mt-3 text-sm text-brand-text/80">Created by: <%= team.lead?.fullName || 'Unknown' %></p>
    <p class="app-breadcrumb app-breadcrumb--static mt-4">
    Team Information
    </p>
</div>
