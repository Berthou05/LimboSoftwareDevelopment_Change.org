<%
    const teamInitials = (team?.name || 'T')
        .trim()
        .split(/\s+/)
        .filter(Boolean)
        .slice(0, 2)
        .map((part) => part[0].toUpperCase())
        .join('') || 'T';
%>

<div class="space-y-4">
    <div class="flex items-start justify-between gap-4">
        <div class="flex min-w-0 flex-1 flex-wrap items-center gap-4">
            <% if (team?.image) { %>
                <img src="<%= team.image %>" alt="<%= team.name %>" class="h-16 w-16 shrink-0 rounded-full border border-brand-secondary object-cover" />
            <% } else { %>
                <div class="app-directory-avatar flex h-16 w-16 shrink-0 items-center justify-center rounded-full border border-brand-secondary bg-brand-bg text-xl font-bold">
                    <%= teamInitials %>
                </div>
            <% } %>
            <div class="flex-1 min-w-0">
                <h1 class="font-heading text-2xl font-bold text-brand-text sm:text-3xl"><%= team.name %></h1>
                <p class="text-sm text-brand-text/70"><%= team.description %></p>
            </div>
        </div>
        <% if (canEditTeam) { %>
            <div class="flex items-center gap-3">
                <%- include('../shared/actionButton', {
                    buttonPopupOpen: 'team-edit-info',
                    buttonIcon: 'edit',
                    buttonLabel: 'Edit',
                    buttonVariant: 'small',
                    buttonClasses: 'shrink-0',
                    buttonAriaLabel: 'Edit team information',
                }) %>
            </div>
        <% } %>
    </div>
    <div class="flex flex-wrap gap-2 text-xs text-brand-text/70">
        <span class="app-breadcrumb app-breadcrumb--static">
            Created by: <%= team.lead?.fullName || 'Unknown' %>
        </span>
        <span class="app-breadcrumb app-breadcrumb--static">
            Team Information
        </span>
    </div>
</div>

<% if (canEditTeam) { %>
    <div data-popup="team-edit-info" class="fixed inset-0 z-50 hidden bg-brand-text/35 px-4 py-8">
        <div class="mx-auto max-w-lg">
            <div class="rounded-3xl border border-brand-secondary bg-white p-6 shadow-panel">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h3 class="font-heading text-2xl font-bold text-brand-text">Edit Team Information</h3>
                        <p class="mt-1 text-sm text-brand-text/60">
                            Update the main information displayed in the team description card.
                        </p>
                    </div>
                    <%- include('../shared/actionButton', {
                        buttonPopupClose: true,
                        buttonIcon: 'close',
                        buttonVariant: 'icon-only',
                        buttonClasses: 'shrink-0',
                        buttonAriaLabel: 'Close popup',
                    }) %>
                </div>

                <form
                    action="/teams/<%= team?.id || '' %>/update"
                    method="POST"
                    enctype="multipart/form-data"
                    class="mt-5 space-y-4"
                >
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="currentImage" value="<%= team?.imagePath || '' %>">

                    <%# Keep the form as a normal multipart submit so image replacement works with the existing multer setup. %>
                    <label class="block text-sm">
                        <span class="mb-2 block font-semibold text-brand-text/70">Team name</span>
                        <input
                            type="text"
                            name="name"
                            value="<%= team?.name || '' %>"
                            class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
                            placeholder="Platform Engineering"
                        />
                    </label>

                    <label class="block text-sm">
                        <span class="mb-2 block font-semibold text-brand-text/70">Description</span>
                        <textarea
                            name="description"
                            rows="4"
                            class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
                            placeholder="Describe the purpose and focus of the team."
                        ><%= team?.description || '' %></textarea>
                    </label>

                    <label class="block text-sm">
                        <span class="mb-2 block font-semibold text-brand-text/70">Team image</span>
                        <input
                            type="file"
                            name="image"
                            accept=".png,.jpg,.jpeg,image/png,image/jpeg"
                            class="w-full rounded-xl border border-brand-secondary px-3 py-2 text-sm outline-none ring-brand-primary/30 focus:ring"
                        />
                    </label>

                    <div class="flex flex-wrap justify-end gap-3 pt-2">
                        <button
                            type="button"
                            data-popup-close
                            class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20"
                        >
                            Cancel
                        </button>
                        <button
                            type="submit"
                            class="rounded-xl border border-brand-primary bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
                        >
                            Save
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
<% } %>
