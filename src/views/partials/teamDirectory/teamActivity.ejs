<%# Team Activity - Compact sidebar view %>
<div class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
    <% const teamPath = `/teams/${team?.id || ''}`; %>
    <div class="flex items-center justify-between gap-2">
        <h2 class="font-heading text-xl font-bold text-brand-text">Activity</h2>
    </div>

    <div class="mt-3 flex flex-wrap items-center gap-2">
        <a href="<%= `${teamPath}?activityPreset=today` %>" class="app-breadcrumb <%= activityFilter?.preset === 'today' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
            Today
        </a>
        <a href="<%= `${teamPath}?activityPreset=week` %>" class="app-breadcrumb <%= activityFilter?.preset === 'week' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
            Week
        </a>
        <a href="<%= `${teamPath}?activityPreset=month` %>" class="app-breadcrumb <%= activityFilter?.preset === 'month' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
            Month
        </a>
        <a href="<%= `${teamPath}?activityPreset=quarter` %>" class="app-breadcrumb <%= activityFilter?.preset === 'quarter' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
            Quarter
        </a>
        <a href="<%= `${teamPath}?activityPreset=all` %>" class="app-breadcrumb <%= activityFilter?.preset === 'all' ? 'app-breadcrumb--active' : 'app-breadcrumb--interactive' %>">
            All
        </a>
    </div>

    <% if (activityError) { %>
        <p class="mt-3 rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
            <%= activityError %>
        </p>
    <% } %>
    
    <div class="mt-4 max-h-72 overflow-y-auto space-y-1">
        <% if (!(activitySections || []).length) { %>
            <p class="py-4 text-center text-sm text-brand-text/50">
                <%= activityFilter?.isFiltered
                    ? 'No activity found for the selected date range.'
                    : 'No activity yet.' %>
            </p>
        <% } %>
        <% (activitySections || []).forEach((section, sectionIndex) => { %>
            <p class="sticky top-0 bg-white py-1 text-[10px] font-semibold uppercase tracking-wider text-brand-text/40"><%= section.dayLabel %></p>
            <% section.items.forEach((item) => { %>
                <div class="flex items-start gap-2 rounded-lg px-2 py-2 transition hover:bg-brand-bg/50" data-activity-section="<%= sectionIndex %>">
                    <div class="app-directory-avatar flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-[9px] font-bold">
                        <%= item.authorInitials || '?' %>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-[10px] text-brand-text/50"><%= item.authorName || 'Unknown' %></p>
                        <p class="text-xs font-medium text-brand-text truncate"><%= item.title %></p>
                        <p class="text-[10px] text-brand-text/50 truncate"><%= item.description || '' %></p>
                    </div>
                    <span class="shrink-0 text-[10px] text-brand-text/40"><%= item.activityTimeLabel || '' %></span>
                </div>
            <% }) %>
        <% }) %>
    </div>
</div>
