<%# Team Projects - Simplified cards with one latest key-information item per project %>
<article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <h2 class="font-heading text-2xl font-bold text-brand-text">Team Projects</h2>
    <p class="mt-1 text-sm text-brand-text/60">Projects this team is working on</p>

    <% if (!team.projectsDetailed.length) { %>
        <p class="mt-5 text-sm text-brand-text/70">No projects assigned.</p>
    <% } %>

    <% if (team.projectsDetailed.length) { %>
        <div class="mt-5 space-y-3">
            <% team.projectsDetailed.forEach((project) => { %>
                <div class="border-b border-brand-secondary/70 py-3 last:border-b-0">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                        <div class="min-w-0 flex-1">
                            <p class="text-[10px] font-semibold uppercase tracking-wide text-brand-text/45">Project</p>
                            <p class="text-wrap text-base font-semibold text-brand-text"><%= project.name %></p>
                            <p class="mt-1 text-wrap text-sm text-brand-text/65"><%= project.description || 'No description available.' %></p>
                        </div>
                        <a href="/projects/<%= project.id %>" class="inline-flex rounded-lg border border-brand-secondary px-3 py-1.5 text-xs font-semibold text-brand-text/70 transition hover:bg-brand-secondary/30">
                            Open
                        </a>
                    </div>

                    <div class="mt-3 flex flex-wrap items-center gap-2">
                        <span class="inline-flex rounded-full border px-2 py-1 text-[11px] font-semibold <%= project.statusTone %>">
                            <%= project.projectStatus %>
                        </span>
                        <span class="inline-flex rounded-full border px-2 py-1 text-[11px] font-semibold <%= project.priorityTone %>">
                            <%= project.priorityLabel %> priority
                        </span>
                        <span class="inline-flex rounded-full border border-brand-secondary px-2 py-1 text-[11px] font-semibold text-brand-text/65">
                            <%= project.goalsCount %> goals
                        </span>
                        <span class="inline-flex rounded-full border border-brand-secondary px-2 py-1 text-[11px] font-semibold text-brand-text/65">
                            <%= project.achievementsCount %> achievements
                        </span>
                        <span class="inline-flex rounded-full border border-brand-secondary px-2 py-1 text-[11px] font-semibold text-brand-text/65">
                            <%= project.highlightsCount %> highlights
                        </span>
                    </div>

                    <div class="mt-3">
                        <% if (!project.latestKeyInformationItems.length) { %>
                            <p class="text-sm text-brand-text/65">No key information available yet.</p>
                        <% } %>
                        <% if (project.latestKeyInformationItems.length) { %>
                            <details class="group">
                                <summary class="flex cursor-pointer items-center justify-between rounded-lg border border-brand-secondary/70 px-3 py-2 text-[11px] font-semibold uppercase tracking-wide text-brand-text/60 transition hover:bg-brand-bg">
                                    <span>Latest Key Information</span>
                                    <svg class="h-4 w-4 text-brand-text/50 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </summary>

                                <div class="mt-2 space-y-2 border-l-2 border-brand-secondary/70 pl-3">
                                    <% project.latestKeyInformationItems.forEach((item) => { %>
                                        <div>
                                            <div class="flex flex-wrap items-center gap-2">
                                                <span class="inline-flex rounded-full border px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide <%= item.tone %>">
                                                    <%= item.type %>
                                                </span>
                                                <span class="text-[11px] text-brand-text/55"><%= item.dateLabel %></span>
                                            </div>
                                            <p class="mt-1 text-sm font-semibold text-brand-text"><%= item.title %></p>
                                            <p class="mt-1 text-sm text-brand-text/70"><%= item.body %></p>
                                        </div>
                                    <% }) %>
                                </div>
                            </details>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</article>
