<%
    const cardClasses = team.isMember
        ? 'border-2 border-brand-primary'
        : 'border border-brand-secondary';
    const placeholderInitial = (team.name || 'T').trim().charAt(0).toUpperCase();
%>

<article class="rounded-2xl bg-white p-4 shadow-panel <%= cardClasses %>">
    <div class="flex items-center gap-3">
        <% if (team.image) { %>
            <img
                src="<%= team.image %>"
                alt="<%= team.name %>"
                class="h-14 w-14 rounded-xl object-cover"
            />
        <% } else { %>
            <div
                class="flex h-14 w-14 items-center justify-center rounded-xl bg-brand-bg
                    text-lg font-bold text-brand-primary"
            >
                <%= placeholderInitial %>
            </div>
        <% } %>
        <div>
            <h3 class="font-heading text-lg font-bold text-brand-text"><%= team.name %></h3>
            <p class="text-sm text-brand-text/70">Lead: <%= team.leadName %></p>
        </div>
    </div>
    <p class="mt-3 text-sm text-brand-text/80">
        <%= team.description || 'No description available.' %>
    </p>
    <a
        href="/teams/<%= team.id %>"
        class="mt-4 inline-flex rounded-xl border border-brand-primary px-3 py-2 text-sm
            font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white"
    >
        Open team
    </a>
</article>
