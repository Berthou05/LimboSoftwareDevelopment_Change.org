<%
    const cardClasses = team.isMember
        ? 'app-directory-card--active'
        : 'border border-brand-secondary';
    const canDeleteTeam = Boolean(
        team?.leadId
        && typeof currentEmployeeId !== 'undefined'
        && currentEmployeeId
        && team.leadId === currentEmployeeId
    );
    const placeholderInitials = team.initials || 'T';
%>

<article class="rounded-2xl bg-white p-4 shadow-panel <%= cardClasses %>">
    <div class="flex items-start justify-between gap-3">
        <div class="flex items-center gap-3">
            <div class="relative h-12 w-12">
                <% const initials = team.name
                    ? team.name.split(' ').map(p => p[0]).slice(0, 2).join('').toUpperCase()
                    : '?'; %>

                <!-- Fallback (initials) -->
                <div class="app-directory-avatar flex h-12 w-12 items-center justify-center rounded-full text-sm font-bold">
                    <%= initials %>
                </div>

                <!-- Image -->
                <% if (team.image) { %>
                    <img
                    src="<%= team.image %>"
                    alt="<%= team.name %>"
                    class="absolute inset-0 h-12 w-12 rounded-full object-cover"
                    onerror="this.style.display='none'"
                    />
                <% } %>
            </div>
            <div>
                <h3 class="font-heading text-lg font-bold text-brand-text"><%= team.name %></h3>
                <p class="text-sm text-brand-text/70">Lead: <%= team.leadName %></p>
            </div>
        </div>
        <% if (canDeleteTeam) { %>
            <% if(hasPermission('TEAM-03')) {%>
                <%- include('../shared/actionButton', {
                    buttonPopupOpen: 'delete-team-' + team.id,
                    buttonIcon: 'trash',
                    buttonLabel: 'Delete',
                    buttonVariant: 'small',
                    buttonClasses: 'panel-action-button--delete-hover',
                    buttonAriaLabel: 'Delete team',
                    actionTone: 'danger'
                }) %>
            <% } %>
        <% } %>
    </div>
    <p class="mt-3 text-sm text-brand-text/80">
        <%= team.description || 'No description available.' %>
    </p>
    <a
        href="/teams/<%= team.id %>"
        class="app-link-button app-link-button--nav mt-4"
    >
        Open team
    </a>
</article>

<% if (canDeleteTeam) { %>
    <div data-popup="delete-team-<%= team.id %>" class="fixed inset-0 z-50 hidden bg-brand-text/35 px-4 py-8">
        <div class="mx-auto max-w-lg">
            <div class="rounded-3xl border border-brand-secondary bg-white p-6 shadow-panel">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h3 class="font-heading text-2xl font-bold text-brand-text">Delete Team</h3>
                        <p class="mt-1 text-sm text-brand-text/60">
                            This will disable the team and remove it from active team listings. This action cannot be undone from this screen.
                        </p>
                    </div>
                    <%- include('../shared/actionButton', {
                        buttonPopupClose: true,
                        buttonIcon: 'close',
                        buttonVariant: 'icon-only',
                        buttonClasses: 'shrink-0',
                        buttonAriaLabel: 'Close popup',
                        actionTone: 'danger'
                    }) %>
                </div>

                <form
                    action="/team/<%= team.id %>/delete"
                    method="POST"
                    data-team-delete-form
                    data-error-message="The team could not be deleted right now."
                    class="mt-5 space-y-4"
                >
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="flex flex-wrap justify-end gap-3 pt-2">
                        <button
                            type="button"
                            data-popup-close
                            class="rounded-xl border border-brand-secondary px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20"
                        >
                            Cancel
                        </button>
                        <button
                            type="submit"
                            class="rounded-xl border border-red-500 bg-red-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-600"
                        >
                            Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
<% } %>
