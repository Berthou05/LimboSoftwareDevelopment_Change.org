<header class="sticky top-0 z-20 border-b border-brand-secondary/60 bg-brand-bg/90 px-4 py-3 backdrop-blur sm:px-6 sm:py-4 lg:px-10">
  <div class="flex flex-wrap items-center justify-between gap-2 sm:gap-4">

    <!-- Mobile menu -->
    <button
      id="mobileMenuToggle"
      type="button"
      class="app-nav-toggle flex h-9 w-9 items-center justify-center rounded-lg border border-brand-secondary sm:h-10 sm:w-10 lg:hidden"
      aria-label="Open menu"
    >
      <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Search -->
    <%- include("./searchbar") %>

    <!-- Right section -->
    <div class="flex items-center gap-2 sm:gap-3">
      
      <a href="/manuals" class="app-nav-toggle inline-flex items-center justify-center p-1 rounded-full border <%= currentPath === '/manuals' ? 'border-brand-nav bg-brand-nav/10 text-brand-nav' : 'border-brand-secondary' %>" aria-label="Open user manuals" title="User manuals">        
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
        </svg>
      </a>

      <div class="relative" data-account-menu>

        <!-- Avatar button -->
        <button
          type="button"
          class="relative flex h-10 w-10 cursor-pointer items-center justify-center overflow-hidden rounded-full border border-brand-secondary p-0 font-bold"
          data-account-menu-toggle
          aria-label="Open account menu"
          aria-expanded="false"
        >
          <% const initials = currentUser?.fullName
            ? currentUser.fullName.split(' ').map(p => p[0]).slice(0, 2).join('').toUpperCase()
            : '?'; %>

          <!-- Fallback -->
          <div class="app-directory-avatar flex h-full w-full items-center justify-center text-brand-nav">
            <span class="text-xs font-bold">
              <%= initials %>
            </span>
          </div>

          <!-- Image -->
          <img
            src="<%= currentUser?.image %>"
            alt="<%= currentUser?.name || 'User' %>"
            class="absolute inset-0 h-full w-full object-cover"
            onerror="this.style.display='none'"
          />
        </button>

        <!-- Dropdown -->
        <div
          class="absolute right-0 z-40 mt-2 hidden min-w-52 rounded-xl border border-brand-secondary bg-white p-2 shadow-panel"
          data-account-menu-panel
        >
          <div class="mb-2 border-b border-brand-secondary/70 px-2 pb-2">
            <p class="text-sm font-semibold text-brand-text">
              <%= currentUser?.name || "User" %>
            </p>
            <p class="text-xs text-brand-text/70">
              <%= currentUser?.roleName || "Employee" %>
            </p>
          </div>

          <a
            href="/account"
            class="block rounded-lg px-2 py-2 text-sm font-medium text-brand-text/90 transition hover:bg-brand-secondary/30"
          >
            Edit Account
          </a>

          <form action="/logout" method="POST" class="mt-1">
          <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" >
          <% } %>
            <input
              type="submit"
              class="app-cta-button app-cta-button--nav w-full rounded-lg px-2 py-2 text-left"
              value="Sign out"
            />
          </form>
        </div>

      </div>
    </div>

  </div>
</header>