<header class="sticky top-0 z-20 border-b border-brand-secondary/60 bg-brand-bg/90 px-4 py-3 backdrop-blur sm:px-6 sm:py-4 lg:px-10">
  <div class="flex flex-wrap items-center justify-between gap-2 sm:gap-4">
    
    <button
      id="mobileMenuToggle"
      type="button"
      class="app-nav-toggle flex h-9 w-9 items-center justify-center rounded-lg border border-brand-secondary sm:h-10 sm:w-10 lg:hidden"
      aria-label="Open menu"
    >
      <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <%- include("./searchbar") %>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href="/manuals"
        class="app-nav-toggle flex h-10 w-10 items-center justify-center rounded-lg border <%= currentPath === '/manuals' ? 'border-brand-nav bg-brand-nav/10 text-brand-nav' : 'border-brand-secondary' %>"
        aria-label="Open user manuals"
        title="User manuals"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v11.494m-7-9.82h14M5.5 19h13a1.5 1.5 0 001.5-1.5v-11A1.5 1.5 0 0018.5 5h-13A1.5 1.5 0 004 6.5v11A1.5 1.5 0 005.5 19z" />
        </svg>
      </a>

      <div class="relative" data-account-menu>
        <button
          type="button"
          class="app-avatar-button flex h-10 w-10 cursor-pointer items-center justify-center overflow-hidden rounded-full border border-brand-secondary p-0 font-heading font-bold"
          data-account-menu-toggle
          aria-label="Open account menu"
          aria-expanded="false"
        >
          <img
            src="<%= currentUser?.image %>"
            alt="<%= currentUser?.name || "User" %>"
            class="h-full w-full object-cover"
            onerror="this.src='/images/accounts/2026-04-13T18-43-46.235Z-avatar.png'"
          />
        </button>

        <div
          class="absolute right-0 z-40 mt-2 hidden min-w-52 rounded-xl border border-brand-secondary bg-white p-2 shadow-panel"
          data-account-menu-panel
        >
          <div class="mb-2 border-b border-brand-secondary/70 px-2 pb-2">
            <p class="text-sm font-semibold text-brand-text"><%= currentUser?.name || "User" %></p>
            <p class="text-xs text-brand-text/70"><%= currentUser?.roleName || "Employee" %></p>
          </div>

          <a
            href="/account"
            class="block rounded-lg px-2 py-2 text-sm font-medium text-brand-text/90 transition hover:bg-brand-secondary/30"
          >
            Edit Account
          </a>

          <form action="/logout" method="POST" class="mt-1">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" >
            <input
              type="submit"
              class="app-cta-button app-cta-button--nav w-full rounded-lg px-2 py-2 text-left"
              value="Sign out"
            />
          </form>
        </div>
      </div>
    </div>
  </div>
</header>
