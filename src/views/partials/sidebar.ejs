<aside id="sidebar" class="app-sidebar group/sidebar sticky top-0 h-screen w-72 shrink-0 transition-all duration-300 data-[collapsed]:w-20 data-[collapsed]:px-2" data-mobile-open="false">
  <div class="app-sidebar-panel flex h-full flex-col border-r border-brand-secondary/60 bg-white px-4 py-6 max-lg:fixed max-lg:left-0 max-lg:top-0 max-lg:z-50 max-lg:w-72 max-lg:shadow-panel">
    <div class="flex items-center justify-between px-3 group-data-[collapsed]/sidebar:justify-center group-data-[collapsed]/sidebar:px-0">
      <div class="group-data-[collapsed]/sidebar:hidden">
        <p class="app-brand-title font-heading text-2xl font-extrabold">Unitas</p>
        <p class="mt-1 text-sm text-brand-text/70">Workflow Reporting</p>
      </div>

      <div class="flex items-center gap-2">
        <button
          id="sidebarToggle"
          type="button"
          class="app-nav-toggle hidden h-8 w-8 items-center justify-center rounded-lg border border-brand-secondary lg:flex"
          title="Toggle sidebar"
        >
          <svg class="h-4 w-4 transition-transform group-data-[collapsed]/sidebar:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
          </svg>
        </button>
      </div>
    </div>

    <nav class="mt-8 flex-1 space-y-1 overflow-y-auto pr-1 group-data-[collapsed]/sidebar:pr-0">
      <% navItems.forEach((item) => { %>
        <a
          href="<%= item.href %>"
          class="app-nav-link <%= item.isActive ? 'app-nav-link--active' : 'app-nav-link--inactive' %>"
          title="<%= item.label %>"
        >
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="<%= item.icon %>" />
          </svg>
          <span class="group-data-[collapsed]/sidebar:hidden"><%= item.label %></span>
        </a>
      <% }) %>
    </nav>
  </div>
</aside>
