<%
  const resolvedHelpKey = typeof pageHelpKey !== 'undefined' ? pageHelpKey : '';
%>

<% if (resolvedHelpKey) { %>
  <button
    type="button"
    data-help-open="<%= resolvedHelpKey %>"
    class="fixed bottom-6 right-6 z-40 rounded-full border border-brand-primary bg-brand-primary px-4 py-3 text-sm font-semibold text-black shadow-panel transition hover:bg-brand-accent"
    aria-controls="app-help-panel"
    aria-expanded="false"
  >
    Help
  </button>
<% } %>

<div
  id="app-help-panel"
  data-help-panel
  data-help-key="<%= resolvedHelpKey %>"
  class="fixed inset-0 z-50 hidden"
  aria-hidden="true"
>
  <div data-help-close class="absolute inset-0 bg-brand-text/35"></div>

  <aside class="ml-auto flex h-full w-full max-w-xl flex-col border-l border-brand-secondary bg-white shadow-panel">
    <div class="flex items-start justify-between gap-4 border-b border-brand-secondary px-6 py-5">
      <div class="min-w-0">
        <p class="text-xs font-semibold uppercase tracking-wide text-brand-text/50">Help</p>
        <h2 data-help-title class="mt-1 font-heading text-2xl font-bold text-brand-text">Loading...</h2>
        <p data-help-summary class="mt-2 text-sm text-brand-text/70"></p>
      </div>

      <button
        type="button"
        data-help-close
        class="rounded-xl border border-brand-secondary px-3 py-2 text-sm font-semibold text-brand-text/70 transition hover:bg-brand-secondary/20"
      >
        Close
      </button>
    </div>

    <div class="min-h-0 flex-1 space-y-6 overflow-y-auto px-6 py-5">
      <div data-help-status class="hidden rounded-xl border border-brand-secondary bg-brand-bg/50 px-4 py-3 text-sm text-brand-text/70"></div>

      <section>
        <h3 class="font-heading text-lg font-semibold text-brand-text">When To Use It</h3>
        <p data-help-when class="mt-2 text-sm leading-6 text-brand-text/80"></p>
      </section>

      <section>
        <h3 class="font-heading text-lg font-semibold text-brand-text">Steps</h3>
        <ol data-help-steps class="mt-3 list-decimal space-y-2 pl-5 text-sm leading-6 text-brand-text/80"></ol>
      </section>

      <section>
        <h3 class="font-heading text-lg font-semibold text-brand-text">Rules</h3>
        <ul data-help-rules class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-brand-text/80"></ul>
      </section>

      <section>
        <h3 class="font-heading text-lg font-semibold text-brand-text">Related</h3>
        <div data-help-related class="mt-3 flex flex-wrap gap-2"></div>
      </section>
    </div>
  </aside>
</div>
