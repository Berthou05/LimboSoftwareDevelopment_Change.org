<%
    const employeeId = employee.id || employee.employee_id || '';
    const employeeName = employee.fullName || employee.full_name || 'Unknown employee';
    const employeeSlack = employee.slackUsername || employee.slack_username || '';
    const employeeEmail = employee.email || '';
    const employeeImage = employee.image || '/images/accounts/2026-04-13T18-43-46.235Z-avatar.png';
    const cardClasses = employee.isSelf
        ? 'app-directory-card--active'
        : 'border border-brand-secondary';
%>

<article class="rounded-2xl bg-white p-4 shadow-panel <%= cardClasses %>">
    <div class="flex items-center gap-3">
        <img
            src="<%= employeeImage %>"
            alt="<%= employeeName %>"
            class="h-12 w-12 rounded-full border border-brand-secondary object-cover"
            onerror="this.src='/images/accounts/2026-04-13T18-43-46.235Z-avatar.png'"
        />
        <div class="min-w-0">
            <h3 class="truncate font-heading text-lg font-bold text-brand-text">
                <%= employeeName %>
            </h3>
            <% if (employee.isSelf) { %>
                <p class="text-xs font-semibold text-brand-primary">My profile</p>
            <% } %>
        </div>
    </div>

    <% if (employeeSlack) { %>
        <p class="mt-3 text-sm text-brand-text/80">
            <%= employeeSlack %>
        </p>
    <% } %>

    <% if (employeeEmail) { %>
        <p class="mt-1 text-sm text-brand-text/80">
            <%= employeeEmail %>
        </p>
    <% } %>

    <a
        href="/employees/<%= employeeId %>"
        class="app-link-button app-link-button--nav mt-4"
    >
        Open profile
    </a>
</article>
