<% if (!selectedGuide) { %>
    <section>
        <p class="text-sm text-brand-text/70">No manual entry is available for this section yet.</p>
    </section>
<% } else { %>
    <article class="space-y-6">
        <div class="border-b border-brand-secondary/60 pb-5">
            <div class="space-y-3">
                <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wide text-brand-text/60">
                    <span><%= selectedSection.title %></span>
                    <% if (selectedChild) { %>
                        <span class="text-brand-text/40">/</span>
                        <span><%= selectedEntry.title %></span>
                    <% } %>
                </div>
                <div>
                    <p class="text-sm font-semibold text-brand-nav"><%= selectedGuide.helpKey %></p>
                    <h2 class="mt-1 font-heading text-3xl font-semibold text-brand-text"><%= selectedGuide.title %></h2>
                </div>
            </div>
        </div>

        <section class="grid gap-5 pb-6 lg:grid-cols-[minmax(0,1fr),16rem]">
            <div>
                <p class="text-sm font-semibold text-brand-text">Overview</p>
                <p class="mt-2 max-w-3xl text-sm leading-6 text-brand-text/70"><%= selectedGuide.summary %></p>
            </div>

            <div>
                <p class="text-sm font-semibold text-brand-text">Guide details</p>
                <div class="mt-2 flex flex-wrap gap-2">
                    <span class="rounded-full border border-brand-secondary/60 px-3 py-1 text-xs font-semibold text-brand-text/70">
                        <%= selectedGuide.type %>
                    </span>
                    <span class="rounded-full border border-brand-secondary/60 px-3 py-1 text-xs font-semibold <%= selectedGuide.status === 'draft' ? 'text-amber-700 bg-amber-50 border-amber-200' : 'text-brand-text/70' %>">
                        <%= selectedGuide.status %>
                    </span>
                </div>
                <p class="mt-4 text-sm font-semibold text-brand-text">Applies to</p>
                <div class="mt-2 flex flex-wrap gap-2">
                <% (selectedGuide.appliesTo || []).forEach((item) => { %>
                    <span class="rounded-full border border-brand-secondary/60 px-3 py-1 text-xs font-semibold text-brand-text/70">
                        <%= item %>
                    </span>
                <% }) %>
                </div>
            </div>
        </section>

        <% if (Array.isArray(selectedGuide.sections) && selectedGuide.sections.length) { %>
            <section>
                <div class="flex items-center justify-between gap-3">
                    <p class="text-sm font-semibold text-brand-text"><%= selectedGuide.type === 'reference' ? 'Reference' : 'Guide sections' %></p>
                    <p class="text-sm text-brand-text/60"><%= selectedGuide.sections.length %> sections</p>
                </div>
                <div class="mt-4 space-y-5">
                <% selectedGuide.sections.forEach((section) => { %>
                    <section class="rounded-2xl border border-brand-secondary/70 bg-white p-5">
                        <h3 class="text-lg font-semibold text-brand-text"><%= section.title %></h3>
                        <% if (section.body) { %>
                            <p class="mt-2 text-sm leading-6 text-brand-text/70"><%= section.body %></p>
                        <% } %>

                        <% if (Array.isArray(section.items) && section.items.length) { %>
                            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-brand-text/75">
                                <% section.items.forEach((item) => { %>
                                    <li><%= item %></li>
                                <% }) %>
                            </ul>
                        <% } %>

                        <% if (Array.isArray(section.rules) && section.rules.length) { %>
                            <ul class="mt-3 space-y-2 text-sm text-brand-text/75">
                                <% section.rules.forEach((rule) => { %>
                                    <li class="rounded-xl border border-brand-secondary/60 bg-brand-secondary/10 px-3 py-2"><%= rule %></li>
                                <% }) %>
                            </ul>
                        <% } %>

                        <% if (Array.isArray(section.fields) && section.fields.length) { %>
                            <div class="mt-3 overflow-x-auto">
                                <table class="min-w-full text-left text-sm">
                                    <thead class="text-xs uppercase tracking-wide text-brand-text/50">
                                        <tr>
                                            <th class="border-b border-brand-secondary/60 py-2 pr-4">Field</th>
                                            <th class="border-b border-brand-secondary/60 py-2">Details</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% section.fields.forEach((field) => { %>
                                            <tr>
                                                <td class="border-b border-brand-secondary/40 py-2 pr-4 font-semibold text-brand-text"><%= field.name %></td>
                                                <td class="border-b border-brand-secondary/40 py-2 text-brand-text/70"><%= field.description %></td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    </section>
                <% }) %>
                </div>
            </section>
        <% } %>

        <% if (Array.isArray(selectedGuide.steps) && selectedGuide.steps.length) { %>
        <section>
            <div class="flex items-center justify-between gap-3">
                <p class="text-sm font-semibold text-brand-text">Guide steps</p>
                <p class="text-sm text-brand-text/60"><%= selectedGuide.steps.length %> steps</p>
            </div>
            <div class="mt-4 space-y-6">
            <% selectedGuide.steps.forEach((step, index) => { %>
                <section class="<%= index > 0 ? 'pt-6' : '' %>">
                    <p class="text-xs font-semibold uppercase tracking-wide text-brand-nav">Step <%= index + 1 %></p>
                    <h3 class="mt-2 text-lg font-semibold text-brand-text"><%= step.title %></h3>
                    <p class="mt-2 text-sm text-brand-text/70"><%= step.body %></p>

                    <% if (step.image && step.image.src) { %>
                    <div class="mt-4 max-w-xl mx-auto rounded-xl bg-brand-secondary/10 px-4 py-3">
                        <img
                            src="<%= step.image.src %>"
                            alt="<%= step.image.alt || step.title %>"
                            class="mx-auto w-full rounded-lg border border-brand-secondary/60"
                        />
                        <% if (step.image.caption) { %>
                            <p class="mt-2 text-sm text-brand-text/70"><%= step.image.caption %></p>
                        <% } %>
                    </div>
                    <% } %>
                </section>
            <% }) %>
            </div>
        </section>
        <% } %>

        <div class="flex flex-wrap justify-between gap-3 border-t border-brand-secondary/60 pt-4">
            <% if (previousEntry) { %>
                <a href="/manuals?section=<%= encodeURIComponent(previousEntry.sectionKey) %>&entry=<%= encodeURIComponent(previousEntry.entryKey) %><%= previousEntry.entryKey !== previousEntry.key ? `&child=${encodeURIComponent(previousEntry.key)}` : '' %>" class="rounded-xl border border-brand-secondary bg-white px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30">
                    Previous: <%= previousEntry.title %>
                </a>
            <% } else { %>
                <span class="rounded-xl border border-brand-secondary/60 px-4 py-2 text-sm text-brand-text/50">Beginning of guide set</span>
            <% } %>

            <% if (nextEntry) { %>
                <a href="/manuals?section=<%= encodeURIComponent(nextEntry.sectionKey) %>&entry=<%= encodeURIComponent(nextEntry.entryKey) %><%= nextEntry.entryKey !== nextEntry.key ? `&child=${encodeURIComponent(nextEntry.key)}` : '' %>" class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-black transition hover:bg-brand-accent">
                    Next: <%= nextEntry.title %>
                </a>
            <% } %>
        </div>
    </article>
<% } %>
