<% if (!selectedEntry) { %>
    <section>
        <p class="text-sm text-brand-text/70">No manual entry is available for this section yet.</p>
    </section>
<% } else { %>
    <article class="space-y-6">
        <div class="border-b border-brand-secondary/60 pb-5">
            <div>
                <p class="text-sm font-semibold text-brand-nav"><%= selectedEntry.helpKey %></p>
                <h2 class="mt-1 font-heading text-3xl font-semibold text-brand-text"><%= selectedEntry.title %></h2>
            </div>
        </div>

        <section class="space-y-3">
            <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                    <p class="text-sm font-semibold text-brand-text">Overview</p>
                    <p class="mt-2 max-w-3xl text-sm text-brand-text/70"><%= selectedEntry.summary %></p>
                </div>

                <div class="flex flex-wrap gap-2">
                <% selectedEntry.appliesTo.forEach((item) => { %>
                    <span class="rounded-full border border-brand-secondary/60 px-3 py-1 text-xs font-semibold text-brand-text/70">
                        <%= item %>
                    </span>
                <% }) %>
                </div>
            </div>
        </section>

        <section>
            <div class="flex items-center justify-between gap-3">
                <p class="text-sm font-semibold text-brand-text">Guide steps</p>
                <p class="text-sm text-brand-text/60"><%= selectedEntry.steps.length %> steps</p>
            </div>
            <div class="mt-4 space-y-6">
            <% selectedEntry.steps.forEach((step, index) => { %>
                <section class="<%= index > 0 ? 'border-t border-brand-secondary/60 pt-6' : '' %>">
                    <p class="text-xs font-semibold uppercase tracking-wide text-brand-nav">Step <%= index + 1 %></p>
                    <h3 class="mt-2 text-lg font-semibold text-brand-text"><%= step.title %></h3>
                    <p class="mt-2 text-sm text-brand-text/70"><%= step.body %></p>

                    <div class="mt-4 rounded-xl bg-brand-secondary/10 px-4 py-3">
                        <img
                            src="<%= step.image.src %>"
                            alt="<%= step.image.alt || step.title %>"
                            class="w-full rounded-lg border border-brand-secondary/60"
                        />
                        <% if (step.image.caption) { %>
                            <p class="mt-2 text-sm text-brand-text/70"><%= step.image.caption %></p>
                        <% } %>
                    </div>
                </section>
            <% }) %>
            </div>
        </section>

        <div class="flex flex-wrap justify-between gap-3 border-t border-brand-secondary/60 pt-4">
            <% if (previousEntry) { %>
                <a href="/manuals?section=<%= encodeURIComponent(previousEntry.sectionKey) %>&entry=<%= encodeURIComponent(previousEntry.key) %>" class="rounded-xl border border-brand-secondary bg-white px-4 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30">
                    Previous: <%= previousEntry.title %>
                </a>
            <% } else { %>
                <span class="rounded-xl border border-brand-secondary/60 px-4 py-2 text-sm text-brand-text/50">Beginning of guide set</span>
            <% } %>

            <% if (nextEntry) { %>
                <a href="/manuals?section=<%= encodeURIComponent(nextEntry.sectionKey) %>&entry=<%= encodeURIComponent(nextEntry.key) %>" class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-black transition hover:bg-brand-accent">
                    Next: <%= nextEntry.title %>
                </a>
            <% } %>
        </div>
    </article>
<% } %>
