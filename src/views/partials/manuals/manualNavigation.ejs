<aside class="space-y-5">
    <div>
        <p class="text-sm font-semibold text-brand-text">Manual index</p>
        <p class="mt-1 text-sm text-brand-text/70">Browse by section first, then open the exact guide you want to read.</p>
    </div>

    <% manualLibrary.forEach((section) => { %>
        <section class="space-y-3">
            <div class="flex items-baseline justify-between gap-3">
                <a
                    href="/manuals?section=<%= encodeURIComponent(section.key) %>"
                    class="block rounded-lg py-1 text-sm font-semibold transition <%= selectedSection.key === section.key ? 'text-brand-nav' : 'text-brand-text hover:bg-brand-secondary/20 hover:text-brand-nav' %>"
                >
                    <%= section.title %>
                </a>
            </div>
            <p class="text-xs leading-5 text-brand-text/60"><%= section.description %></p>

            <div class="space-y-1 pl-4">
                <% section.entries.forEach((entry) => { %>
                    <% if (Array.isArray(entry.children) && entry.children.length > 0) { %>
                        <details class="space-y-2" <%= selectedEntry && selectedEntry.key === entry.key ? 'open' : '' %>>
                            <summary class="cursor-pointer list-none rounded-lg px-2 py-1 text-sm font-semibold transition <%= selectedEntry && selectedEntry.key === entry.key ? 'text-brand-nav' : 'text-brand-text hover:bg-brand-secondary/20 hover:text-brand-nav' %>">
                                <span class="flex items-center justify-between gap-3">
                                    <span><%= entry.title %></span>
                                    <span class="text-xs text-brand-text/50">+</span>
                                </span>
                            </summary>
                            <div class="space-y-1 pl-3">
                                <% entry.children.forEach((child) => { %>
                                    <a
                                        href="/manuals?section=<%= encodeURIComponent(section.key) %>&entry=<%= encodeURIComponent(entry.key) %>&child=<%= encodeURIComponent(child.key) %>"
                                        class="block rounded-lg px-2 py-1 text-sm transition <%= selectedGuide && selectedGuide.key === child.key ? 'font-semibold text-brand-nav' : 'text-brand-text/70 hover:bg-brand-secondary/20 hover:text-brand-nav' %>"
                                    >
                                        <span class="block min-w-0"><%= child.title %></span>
                                    </a>
                                <% }) %>
                            </div>
                        </details>
                    <% } else { %>
                        <a
                            href="/manuals?section=<%= encodeURIComponent(section.key) %>&entry=<%= encodeURIComponent(entry.key) %>"
                            class="block rounded-lg px-2 py-1 text-sm transition <%= selectedGuide && selectedGuide.key === entry.key ? 'font-semibold text-brand-nav' : 'text-brand-text/80 hover:bg-brand-secondary/20 hover:text-brand-nav' %>"
                        >
                            <span class="block min-w-0">
                                <%= entry.title %>
                            </span>
                        </a>
                    <% } %>
                <% }) %>
            </div>
        </section>
    <% }) %>
</aside>
