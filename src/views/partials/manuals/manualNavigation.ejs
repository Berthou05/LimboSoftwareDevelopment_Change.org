<aside class="space-y-5">
    <div>
        <p class="text-sm font-semibold text-brand-text">Manual index</p>
        <p class="mt-1 text-sm text-brand-text/70">Browse by section first, then open the exact guide you want to read.</p>
    </div>

    <% manualLibrary.forEach((section) => { %>
        <section class="space-y-3 border-t border-brand-secondary/50 pt-4 first:border-t-0 first:pt-0">
            <div class="flex items-baseline justify-between gap-3">
                <a
                    href="/manuals?section=<%= encodeURIComponent(section.key) %>"
                    class="block text-sm font-semibold transition <%= selectedSection.key === section.key ? 'text-brand-nav' : 'text-brand-text hover:text-brand-nav' %>"
                >
                    <%= section.title %>
                </a>
                <span class="text-xs text-brand-text/50"><%= section.entries.length %></span>
            </div>
            <p class="text-xs leading-5 text-brand-text/60"><%= section.description %></p>

            <div class="space-y-3">
                <% section.entries.forEach((entry) => { %>
                    <% if (Array.isArray(entry.children) && entry.children.length > 0) { %>
                        <div class="space-y-2">
                            <a
                                href="/manuals?section=<%= encodeURIComponent(section.key) %>&entry=<%= encodeURIComponent(entry.key) %>"
                                class="block text-sm font-semibold transition <%= selectedEntry && selectedEntry.key === entry.key ? 'text-brand-nav' : 'text-brand-text hover:text-brand-nav' %>"
                            >
                                <%= entry.title %>
                            </a>
                            <div class="space-y-1 pl-3">
                                <% entry.children.forEach((child) => { %>
                                    <a
                                        href="/manuals?section=<%= encodeURIComponent(section.key) %>&entry=<%= encodeURIComponent(entry.key) %>&child=<%= encodeURIComponent(child.key) %>"
                                        class="flex items-start gap-2 py-0.5 text-sm transition <%= selectedGuide && selectedGuide.key === child.key ? 'font-semibold text-brand-nav' : 'text-brand-text/70 hover:text-brand-nav' %>"
                                    >
                                        <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full <%= selectedGuide && selectedGuide.key === child.key ? 'bg-brand-nav' : 'bg-brand-secondary' %>"></span>
                                        <span class="min-w-0"><%= child.title %></span>
                                    </a>
                                <% }) %>
                            </div>
                        </div>
                    <% } else { %>
                        <a
                            href="/manuals?section=<%= encodeURIComponent(section.key) %>&entry=<%= encodeURIComponent(entry.key) %>"
                            class="flex items-start gap-2 py-0.5 text-sm transition <%= selectedGuide && selectedGuide.key === entry.key ? 'font-semibold text-brand-nav' : 'text-brand-text/80 hover:text-brand-nav' %>"
                        >
                            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full <%= selectedGuide && selectedGuide.key === entry.key ? 'bg-brand-nav' : 'bg-brand-secondary' %>"></span>
                            <span class="min-w-0"><%= entry.title %></span>
                        </a>
                    <% } %>
                <% }) %>
            </div>
        </section>
    <% }) %>
</aside>
