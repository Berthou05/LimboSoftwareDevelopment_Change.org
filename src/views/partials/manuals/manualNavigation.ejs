<aside class="space-y-4 rounded-3xl border border-brand-secondary/60 bg-white p-5">
    <div>
        <p class="text-sm font-semibold text-brand-text">Guide sections</p>
        <p class="mt-1 text-sm text-brand-text/70">Open a module flow, then move across guides with the next and previous links.</p>
    </div>

    <% manualLibrary.forEach((section) => { %>
        <section class="rounded-2xl border <%= selectedSection.key === section.key ? 'border-brand-nav bg-brand-nav/10' : 'border-brand-secondary/60 bg-white' %> p-4">
            <a
                href="/manuals?section=<%= encodeURIComponent(section.key) %>"
                class="block text-base font-semibold text-brand-text transition hover:text-brand-nav"
            >
                <%= section.title %>
            </a>
            <p class="mt-1 text-sm text-brand-text/70"><%= section.description %></p>

            <div class="mt-3 space-y-2">
                <% section.entries.forEach((entry) => { %>
                    <a
                        href="/manuals?section=<%= encodeURIComponent(section.key) %>&entry=<%= encodeURIComponent(entry.key) %>"
                        class="block rounded-xl border px-3 py-2 text-sm transition <%= selectedEntry && selectedEntry.key === entry.key ? 'border-brand-nav bg-brand-nav text-white' : 'border-brand-secondary/60 text-brand-text/80 hover:bg-brand-secondary/30 hover:text-brand-nav' %>"
                    >
                        <%= entry.title %>
                    </a>
                <% }) %>
            </div>
        </section>
    <% }) %>
</aside>
