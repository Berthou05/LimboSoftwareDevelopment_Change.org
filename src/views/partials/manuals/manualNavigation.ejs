<aside class="space-y-6">
    <div>
        <p class="text-sm font-semibold text-brand-text">Guide sections</p>
        <p class="mt-1 text-sm text-brand-text/70">Open a module flow, then move across guides with the next and previous links.</p>
    </div>

    <% manualLibrary.forEach((section) => { %>
        <section class="border-l-2 <%= selectedSection.key === section.key ? 'border-brand-nav pl-4' : 'border-brand-secondary/60 pl-4' %>">
            <a
                href="/manuals?section=<%= encodeURIComponent(section.key) %>"
                class="block text-base font-semibold text-brand-text transition hover:text-brand-nav"
            >
                <%= section.title %>
            </a>
            <p class="mt-1 text-sm text-brand-text/70"><%= section.description %></p>

            <div class="mt-3 space-y-1">
                <% section.entries.forEach((entry) => { %>
                    <a
                        href="/manuals?section=<%= encodeURIComponent(section.key) %>&entry=<%= encodeURIComponent(entry.key) %>"
                        class="block py-1 text-sm transition <%= selectedEntry && selectedEntry.key === entry.key ? 'font-semibold text-brand-nav' : 'text-brand-text/80 hover:text-brand-nav' %>"
                    >
                        <%= entry.title %>
                    </a>
                <% }) %>
            </div>
        </section>
    <% }) %>
</aside>
