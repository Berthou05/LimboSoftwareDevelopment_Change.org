@startuml

|Lead|
start
:Clicks on the "Add" button in the Project Information module;
|System|
:Makes modifiable the inputs of the Project Information module;
|Lead|
:Modifies any input;
:Clicks the "Save" button;
|System|
if(Is the title input empty?) is (yes) then
    |System|
    :“Save” button gets disabled;
    :Shows the message “Some obligatory fields are empty”;
    stop
    note right
        Go to User modifies any input
    end note
else(no)
    if(Is the description input empty?) is (yes) then
        |System|
        :“Save” button gets disabled;
        :Shows the message “Some obligatory fields are empty”;
        stop
        note right
            Go to User modifies any input
        end note
    else(no)
    end if
        if(Is the project status empty?) is (yes) then
            |System|
            :“Save” button gets disabled;
            :Shows the message “Some obligatory fields are empty”;
            stop
            note right
                Go to User modifies any input
            end note
        else(no)
        end if

        if(Is the project start_date empty?) is (yes) then
            |System|
            :“Save” button gets disabled;
            :Shows the message “Some obligatory fields are empty”;
            stop
            note right
                Go to User modifies any input
            end note
        else(no)
        end if

        if(Is the project end_date empty?) is (no) then
            |System|
            if(Is start_date <= end_date?) is (no) then
                |System|
                :“Save” button gets disabled;
                :Shows the message “End date cannot be before start date”;
                stop
                note right
                    Go to User modifies any input
                end note
            else(yes)
            end if
        else(yes)
        end if
    end if
    |System|
    :Accepts the Lead input;
    :Sends modifications to the Project object;
    |Database|
    :Modifies the Project object;
    |System|
    :Gathers Team information through queries;
    |Database|
    :Returns queries response;
    |System|
    :Renders the Team Page with updated information;
    stop


@enduml