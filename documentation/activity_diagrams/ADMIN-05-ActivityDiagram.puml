@startuml
|Administrator|
start
:Opens Accounts Administration;
:Finds the target Account row;
:Opens Role dropdown;
:Selects a new Role;

|System|
:Validates selected Role;
if (Role valid?) is (no) then
  |Administrator|
  :Sees error message on screen\n"Invalid role selected.";
  stop
else(yes)
endif

|System|
:Sends update request\n(account_id, role_id);

|Database|
:Updates AccountRole record;

|System|
if (Database error?) is (yes) then
  |Administrator|
  :Sees error message on screen\n"Role could not be updated. Please try again.";
  :Sees previous Role restored in dropdown;
  stop
else(no)
endif

|Administrator|
:Sees updated Role in the Accounts table;
stop
@enduml