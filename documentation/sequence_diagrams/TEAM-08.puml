@startuml
skinparam style strictuml

actor User as U
boundary "routes" as RO
boundary "vista team.ejs" as V
control "team.controller" as C
entity "Team.model" as TM
entity "Project.model" as PM
database "unitas_system" as BD


activate U
U -> RO: fetch('/teams', {method: 'GET', headers: { 'Accept': 'text/html'}})
deactivate U
    activate RO
    RO -> C: getTeams(request: Express.Request, response: Express.Response)
    deactivate RO
        activate C
        C ->> TM: findAll()
            activate TM
            TM ->> BD: execute('SELECT * FROM teams')
                activate BD
                BD --> TM: teams: Team[]
                deactivate BD
            TM --> C: teams: Team[]
            deactivate TM
        C -> V: response.render('team.ejs', {teams: teams})
        deactivate C
    activate V
    V -> U: HTML response: Render teams list view
    deactivate V

activate U
U -> V: Clicks on a Team row (team_id)
deactivate U
    activate V
    V -> C: getTeamDetails(team_id: number)
    deactivate V
        activate C
        C ->> TM: findById(team_id: number)
            activate TM
            TM ->> BD: execute('SELECT * FROM teams WHERE id=?', [team_id])
                activate BD
                BD --> TM: team: Team
                deactivate BD
            TM --> C: team: Team
            deactivate TM
        C ->> PM: findByTeamId(team_id: number)
            activate PM
            PM ->> BD: execute('SELECT p.* FROM projects p JOIN team_projects tp ON p.id = tp.project_id WHERE tp.team_id=?', [team_id])
                activate BD
                BD --> PM: projects: Project[]
                deactivate BD
            PM --> C: projects: Project[]
            deactivate PM
        C -> V: response.render('team.ejs', {team: team, projects: projects})
        deactivate C
    activate V
    V -> U: HTML response: Render team details and associated projects
    deactivate V

@enduml