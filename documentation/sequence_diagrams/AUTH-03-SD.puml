@startuml
skinparam style strictuml
skinparam sequenceArrowThickness 1.2
skinparam roundcorner 6
autonumber

actor    "User"                   as User
boundary "pages/login.ejs"        as LoginView
boundary "pages/reset.ejs"        as ResetView
boundary "pages/resetConfirm.ejs" as ResetConfirmView
boundary "auth.routes"            as AuthRoutes
control  "auth.controller"        as AuthController
entity   "account.model"          as AccountModel
control  "resendService"          as ResendService
database "unitas_system"          as DB

== Main Flow ==

User -> LoginView : Click "Reset Password"
activate LoginView
LoginView -> AuthRoutes : GET /reset
deactivate LoginView
activate AuthRoutes
AuthRoutes -> AuthController : getReset()
activate AuthController
AuthController --> AuthRoutes : render('pages/reset')
deactivate AuthController
AuthRoutes --> ResetView : HTML
deactivate AuthRoutes
activate ResetView
ResetView --> User : Show email form
deactivate ResetView

User -> ResetView : Submit email
activate ResetView
ResetView -> AuthRoutes : POST /reset
deactivate ResetView
activate AuthRoutes
AuthRoutes -> AuthController : postReset()
activate AuthController
AuthController -> AccountModel : fetchByEmail(email)
activate AccountModel
AccountModel -> DB : Find account by email
activate DB
DB --> AccountModel : account
deactivate DB
AccountModel --> AuthController : account
deactivate AccountModel

AuthController -> AuthController : create 6-digit token\nhash token\nset expiration
AuthController -> AccountModel : saveResetToken(account_id, tokenHash, expiresAt)
activate AccountModel
AccountModel -> DB : Save token hash + expiration
activate DB
DB --> AccountModel : update result
deactivate DB
AccountModel --> AuthController : token saved
deactivate AccountModel

AuthController -> ResendService : sendResetEmail(email, token, 8)
activate ResendService
ResendService --> AuthController : delivered
deactivate ResendService
AuthController -> AuthController : session.resetEmail = email
AuthController --> AuthRoutes : redirect('/reset/confirm') + success
deactivate AuthController
AuthRoutes --> User : HTTP 302 /reset/confirm
deactivate AuthRoutes
User -> AuthRoutes : GET /reset/confirm
activate AuthRoutes
AuthRoutes -> AuthController : getResetConfirm()
activate AuthController
AuthController --> AuthRoutes : render('pages/resetConfirm')
deactivate AuthController
AuthRoutes --> ResetConfirmView : HTML
deactivate AuthRoutes
activate ResetConfirmView
ResetConfirmView --> User : Show code + password form
deactivate ResetConfirmView

User -> ResetConfirmView : Submit token + passwords
activate ResetConfirmView
ResetConfirmView -> AuthRoutes : POST /reset/confirm
deactivate ResetConfirmView
activate AuthRoutes
AuthRoutes -> AuthController : postResetConfirm()
activate AuthController
AuthController -> AccountModel : fetchByEmailAndResetToken(email, tokenHash)
activate AccountModel
AccountModel -> DB : Find account by email + token hash
activate DB
DB --> AccountModel : account
deactivate DB
AccountModel --> AuthController : account
deactivate AccountModel

AuthController -> AuthController : bcrypt.hash(password, 12)
AuthController -> AccountModel : updatePasswordAndClearResetToken(account_id, passwordHash)
activate AccountModel
AccountModel -> DB : Update password and clear token
activate DB
DB --> AccountModel : update result
deactivate DB
AccountModel --> AuthController : password updated
deactivate AccountModel
AuthController -> AuthController : session.resetEmail = null
AuthController --> AuthRoutes : redirect('/') + success
deactivate AuthController
AuthRoutes --> User : HTTP 302 /
deactivate AuthRoutes
User -> AuthRoutes : GET /
activate AuthRoutes
AuthRoutes -> AuthController : getLogin()
activate AuthController
AuthController --> AuthRoutes : render('pages/login')
deactivate AuthController
AuthRoutes --> LoginView : HTML
deactivate AuthRoutes
activate LoginView
LoginView --> User : Show login + success
deactivate LoginView

== Alternatives: POST /reset ==

alt Empty email
    User -> ResetView : Submit empty email
    activate ResetView
    ResetView -> AuthRoutes : POST /reset
    deactivate ResetView
    activate AuthRoutes
    AuthRoutes -> AuthController : postReset()
    activate AuthController
    AuthController --> AuthRoutes : redirect('/reset') + error
    deactivate AuthController
    AuthRoutes --> ResetView : GET /reset
    deactivate AuthRoutes
    activate ResetView
    ResetView --> User : Show email error
    deactivate ResetView
end

alt Account not found
    User -> ResetView : Submit unknown email
    activate ResetView
    ResetView -> AuthRoutes : POST /reset
    deactivate ResetView
    activate AuthRoutes
    AuthRoutes -> AuthController : postReset()
    activate AuthController
    AuthController -> AccountModel : fetchByEmail(email)
    activate AccountModel
    AccountModel -> DB : Find account by email
    activate DB
    DB --> AccountModel : no account
    deactivate DB
    AccountModel --> AuthController : []
    deactivate AccountModel
    AuthController -> AuthController : session.resetEmail = email
    AuthController --> AuthRoutes : render('pages/resetConfirm') + generic success
    deactivate AuthController
    AuthRoutes --> ResetConfirmView : HTML
    deactivate AuthRoutes
    activate ResetConfirmView
    ResetConfirmView --> User : Show code form
    deactivate ResetConfirmView
end

alt Resend not configured
    User -> ResetView : Submit valid email
    activate ResetView
    ResetView -> AuthRoutes : POST /reset
    deactivate ResetView
    activate AuthRoutes
    AuthRoutes -> AuthController : postReset()
    activate AuthController
    AuthController -> AccountModel : fetchByEmail(email)
    activate AccountModel
    AccountModel -> DB : Find account by email
    activate DB
    DB --> AccountModel : account
    deactivate DB
    AccountModel --> AuthController : account
    deactivate AccountModel
    AuthController --> AuthRoutes : redirect('/reset') + error
    deactivate AuthController
    AuthRoutes --> ResetView : GET /reset
    deactivate AuthRoutes
    activate ResetView
    ResetView --> User : Show service error
    deactivate ResetView
end

alt Email send fails
    User -> ResetView : Submit valid email
    activate ResetView
    ResetView -> AuthRoutes : POST /reset
    deactivate ResetView
    activate AuthRoutes
    AuthRoutes -> AuthController : postReset()
    activate AuthController
    AuthController -> AccountModel : fetchByEmail(email)
    activate AccountModel
    AccountModel -> DB : Find account by email
    activate DB
    DB --> AccountModel : account
    deactivate DB
    AccountModel --> AuthController : account
    deactivate AccountModel
    AuthController -> AccountModel : saveResetToken(account_id, tokenHash, expiresAt)
    activate AccountModel
    AccountModel -> DB : Save token hash + expiration
    activate DB
    DB --> AccountModel : update result
    deactivate DB
    AccountModel --> AuthController : token saved
    deactivate AccountModel
    AuthController -> ResendService : sendResetEmail(email, token, 8)
    activate ResendService
    ResendService --> AuthController : failed
    deactivate ResendService
    AuthController -> AccountModel : clearResetToken(account_id)
    activate AccountModel
    AccountModel -> DB : Clear token data
    activate DB
    DB --> AccountModel : update result
    deactivate DB
    AccountModel --> AuthController : token cleared
    deactivate AccountModel
    AuthController --> AuthRoutes : redirect('/reset') + error
    deactivate AuthController
    AuthRoutes --> ResetView : GET /reset
    deactivate AuthRoutes
    activate ResetView
    ResetView --> User : Show send error
    deactivate ResetView
end

== Alternatives: GET /reset/confirm ==

alt Token query present
    User -> AuthRoutes : GET /reset/confirm?token=123456
    activate AuthRoutes
    AuthRoutes -> AuthController : getResetConfirm()
    activate AuthController
    AuthController -> AccountModel : fetchByEmailAndResetToken(null, tokenHash)
    activate AccountModel
    AccountModel -> DB : Find account by token hash
    activate DB
    DB --> AccountModel : accounts[]
    deactivate DB
    AccountModel --> AuthController : accounts[]
    deactivate AccountModel
    AuthController -> AuthController : session.resetEmail = account.email
    AuthController --> AuthRoutes : render('pages/resetConfirm')
    deactivate AuthController
    AuthRoutes --> ResetConfirmView : HTML
    deactivate AuthRoutes
    activate ResetConfirmView
    ResetConfirmView --> User : Show code + password form
    deactivate ResetConfirmView
end

alt No reset context
    User -> AuthRoutes : GET /reset/confirm
    activate AuthRoutes
    AuthRoutes -> AuthController : getResetConfirm()
    activate AuthController
    AuthController --> AuthRoutes : redirect('/reset') + error
    deactivate AuthController
    AuthRoutes --> ResetView : GET /reset
    deactivate AuthRoutes
    activate ResetView
    ResetView --> User : Show "Request a reset code first."
    deactivate ResetView
end

== Alternatives: POST /reset/confirm ==

alt Missing reset session
    User -> ResetConfirmView : Submit form without reset session
    activate ResetConfirmView
    ResetConfirmView -> AuthRoutes : POST /reset/confirm
    deactivate ResetConfirmView
    activate AuthRoutes
    AuthRoutes -> AuthController : postResetConfirm()
    activate AuthController
    AuthController --> AuthRoutes : redirect('/reset') + error
    deactivate AuthController
    AuthRoutes --> ResetView : GET /reset
    deactivate AuthRoutes
    activate ResetView
    ResetView --> User : Show reset request error
    deactivate ResetView
end

alt Missing fields
    User -> ResetConfirmView : Submit incomplete form
    activate ResetConfirmView
    ResetConfirmView -> AuthRoutes : POST /reset/confirm
    deactivate ResetConfirmView
    activate AuthRoutes
    AuthRoutes -> AuthController : postResetConfirm()
    activate AuthController
    AuthController --> AuthRoutes : redirect('/reset/confirm') + error
    deactivate AuthController
    AuthRoutes --> ResetConfirmView : GET /reset/confirm
    deactivate AuthRoutes
    activate ResetConfirmView
    ResetConfirmView --> User : Show missing fields error
    deactivate ResetConfirmView
end

alt Password mismatch or invalid policy
    User -> ResetConfirmView : Submit invalid password
    activate ResetConfirmView
    ResetConfirmView -> AuthRoutes : POST /reset/confirm
    deactivate ResetConfirmView
    activate AuthRoutes
    AuthRoutes -> AuthController : postResetConfirm()
    activate AuthController
    AuthController --> AuthRoutes : redirect('/reset/confirm') + error
    deactivate AuthController
    AuthRoutes --> ResetConfirmView : GET /reset/confirm
    deactivate AuthRoutes
    activate ResetConfirmView
    ResetConfirmView --> User : Show password error
    deactivate ResetConfirmView
end

alt Invalid token
    User -> ResetConfirmView : Submit invalid token
    activate ResetConfirmView
    ResetConfirmView -> AuthRoutes : POST /reset/confirm
    deactivate ResetConfirmView
    activate AuthRoutes
    AuthRoutes -> AuthController : postResetConfirm()
    activate AuthController
    AuthController -> AccountModel : fetchByEmailAndResetToken(email, tokenHash)
    activate AccountModel
    AccountModel -> DB : Find account by email + token hash
    activate DB
    DB --> AccountModel : no account
    deactivate DB
    AccountModel --> AuthController : []
    deactivate AccountModel
    AuthController --> AuthRoutes : redirect('/reset/confirm') + error
    deactivate AuthController
    AuthRoutes --> ResetConfirmView : GET /reset/confirm
    deactivate AuthRoutes
    activate ResetConfirmView
    ResetConfirmView --> User : Show invalid token error
    deactivate ResetConfirmView
end

alt Expired token
    User -> ResetConfirmView : Submit expired token
    activate ResetConfirmView
    ResetConfirmView -> AuthRoutes : POST /reset/confirm
    deactivate ResetConfirmView
    activate AuthRoutes
    AuthRoutes -> AuthController : postResetConfirm()
    activate AuthController
    AuthController -> AccountModel : fetchByEmailAndResetToken(email, tokenHash)
    activate AccountModel
    AccountModel -> DB : Find account by email + token hash
    activate DB
    DB --> AccountModel : expired account
    deactivate DB
    AccountModel --> AuthController : account
    deactivate AccountModel
    AuthController -> AccountModel : clearResetToken(account_id)
    activate AccountModel
    AccountModel -> DB : Clear token data
    activate DB
    DB --> AccountModel : update result
    deactivate DB
    AccountModel --> AuthController : token cleared
    deactivate AccountModel
    AuthController -> AuthController : session.resetEmail = null
    AuthController --> AuthRoutes : redirect('/reset') + error
    deactivate AuthController
    AuthRoutes --> ResetView : GET /reset
    deactivate AuthRoutes
    activate ResetView
    ResetView --> User : Show expired token error
    deactivate ResetView
end

@enduml
