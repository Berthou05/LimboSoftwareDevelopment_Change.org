@startuml
skinparam style strictuml
autonumber

actor "User" as U
boundary "employee-profile.ejs" as V
boundary "employee.routes" as RO
control "employee.controller" as C
control "employee.service" as SV
entity "employee.model" as X
database "unitas_system" as DB

U -> V: Click "Edit profile"
activate V
V -> V: enableEmployeeEditMode()

opt Cancel employee edit
U -> V: Click "Cancel"
V -> V: restoreEmployeeProfile()
end

U -> V: Click "Save"
V -> RO: fetch('/employees/:employeeId',\n{method:'PATCH', headers:{'Content-Type':'application/json'},\nbody:JSON.stringify(employeeForm)})
activate RO
RO -> C: updateEmployee(request, response)
activate C
C -> SV: updateEmployee(employeeId, employeeForm)
activate SV
SV -> SV: validateEmployeeFields(firstName, lastName, timezone)

alt Employee fields invalid
SV --> C: validation error
deactivate SV
C --> RO: response.json({success:false,error:"Invalid employee data"})
deactivate C
RO --> V: HTTP 400 application/json
deactivate RO
V -> V: response.json()
V -> V: showEmployeeUpdateError(error)
else Employee fields valid
SV -> X: updateEmployee(employeeId, employeeForm)
activate X
X -> DB: UPDATE employee\nSET first_name = ?, last_name = ?, timezone = ?, title = ?\nWHERE id = ?
activate DB
DB --> X: updated rows
deactivate DB
X --> SV: update result
deactivate X
SV -> X: findById(employeeId)
activate X
X -> DB: SELECT id, first_name, last_name, timezone, title\nFROM employee\nWHERE id = ?
activate DB
DB --> X: updated employee row
deactivate DB
X --> SV: employee
deactivate X
SV --> C: updated employee data
deactivate SV
C --> RO: response.json({success:true,data:employee})
deactivate C
RO --> V: HTTP 200 application/json
deactivate RO
V -> V: response.json()
V -> V: updateEmployeeModule(data)
end
deactivate V

@enduml
