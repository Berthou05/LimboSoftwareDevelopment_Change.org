@startuml
skinparam style strictuml

actor User as U
boundary "team_view.ejs" as V
boundary "routes" as RO
control "team.controller" as C
entity "Employee.model" as M
database "unitas_system" as DB

autonumber
skinparam Style strictuml

actor User as U
boundary "teamDirectory.ejs" as PV
boundary "team.ejs" as V
boundary "team.routes" as RO
control "team.controller" as C
entity "employee.model" as P
database "unitas_system" as BD

autonumber

activate U
U->PV:Clicks on a team over the team directory page.
deactivate U
    activate PV
    PV->RO: GET team/:team_id
    deactivate PV
        activate RO
        RO->C: getTeamPage(request,response);
        deactivate RO
            activate C
            note right
            The information for the 
            initial page render is 
            obtained.
            end note
            C->V:response.render('pages/team.ejs',{...});
            deactivate C
    activate V
    V->V:loadContent();
    group TEAM-05
    V->RO:fetch('/team/:team_id/members',{method: GET, headers:{body:'application/json'}})
    deactivate V
        activate RO
        RO->C:getTeamMembers(request,response)
        deactivate RO
        activate C
        C->>P:getEmployeeByTeamId(team_id)
            activate P
            P->>BD: execute('SELECT E.employee_id, E.full_name, ET.joined_at, ET.role \nFROM employee as E \nINNER JOIN employeeteam as ET ON E.employee_id=ET.employee_id \nWHERE ET.team_id=? AND ET.left_at IS NULL ORDER BY E.full_name ASC;',[team_id]);
                activate BD
                BD-->P:members
                deactivate BD
            P-->C:members
            deactivate P
        C->V:response.status(200).json({success:true, body:members});
        deactivate C
    activate V
        end group
    
    V->V:generateMembers(members);
    V->U:HTML
    deactivate V

alt Team Members Obtention Failed
        activate C
    group TEAM-05 alt
        C->V:response.status(500).json({success:false, message:error});     
        deactivate C
    activate V
    end group
    
    V->V:showErrorPopup(error);
    V->U:Updated view
    deactivate V
end






@enduml