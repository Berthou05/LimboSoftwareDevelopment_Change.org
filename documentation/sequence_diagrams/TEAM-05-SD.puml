@startuml
skinparam Style strictuml

actor User as U
boundary "teamDirectory.ejs" as PV
boundary "team.ejs" as V
boundary "team.routes" as RO
control "team.controller" as C
entity "employee.model" as P
database "unitas_system" as BD

autonumber

activate U
U->PV:Clicks on a team over the team directory page.
deactivate U
    activate PV
    PV->RO: GET team/:team_id
    deactivate PV
        activate RO
        RO->C: getTeamPage(request,response);
        deactivate RO
            activate C
            note right
            The information for the 
            initial page render is 
            obtained.
            end note
            C->U:response.render('pages/team.ejs',{...});
            deactivate C
    activate U
    U->U:loadContent();
    group TEAM-05
    U->>RO:fetch('/team/:team_id/members',{method: GET, headers:{body:'application/json'}})
        activate RO
        RO->C:getTeamMembers(request,response)
        deactivate RO
        activate C
        C->>P:getEmployeeByTeamId(team_id)
            activate P
            P->>BD: execute('SELECT E.employee_id, E.full_name, ET.joined_at, ET.role \nFROM employee as E \nINNER JOIN employeeteam as ET ON E.employee_id=ET.employee_id \nWHERE ET.team_id=? AND ET.left_at IS NULL ORDER BY E.full_name ASC;',[team_id]);
                activate BD
                BD-->P:members
                deactivate BD
            P-->C:members
            deactivate P
        C-->U:response.status(200).json({success:true, body:members});
        end group
    
    U->U:generateMembers(members);
    U->U:HTML

alt Team Members Obtention Failed
        C-->U:response.status(500).json({success:false, message:error});     
        deactivate C
    
    U->U:showErrorPopup(error);
    U->U:Updated view
    deactivate U
end






@enduml