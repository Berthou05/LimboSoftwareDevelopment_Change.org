@startuml
skinparam style strictuml
skinparam sequenceArrowThickness 1.2
skinparam roundcorner 6
autonumber

actor    "Employee"                     as User
boundary "pages/project.ejs"            as AchievementsView
control  "teamDetails.js (AJAX)"        as Client
boundary "project.routes"               as Routes
control  "project.controller"           as Controller
entity   "project.model"                as ProjectModel
entity   "achievement.model"            as AchievementModel
database "unitas_system"                as DB

note right of Routes
  Target route for PROJ-15:
  router.post('/:project_id/achievements/:achievement_id/remove',
    isAuth, projectController.removeProjectAchievement)
end note

activate User
User -> AchievementsView : Click "Delete" on achievement card
deactivate User
activate AchievementsView
AchievementsView -> Client : openDeleteAchievementPopup(achievement_id)
activate Client
AchievementsView --> User : Show delete confirmation popup
deactivate AchievementsView

activate User
User -> Client : Confirm achievement deletion
deactivate User
Client -> Client : validateDeletePayload(project_id, achievement_id)

alt Invalid delete payload on client
    Client -> AchievementsView : showAchievementValidationError()
    AchievementsView --> User : Inline validation error message
end

Client ->> Routes : fetch('/projects/:project_id/achievements/:achievement_id/remove',\n{ method:'POST', headers:{'Accept':'application/json',\n'Content-Type':'application/x-www-form-urlencoded'},\nbody:'_csrf=...' })
activate Routes
Routes -> Controller : removeProjectAchievement(request, response)
activate Controller
deactivate Routes

Controller -> Controller : request.session.privileges.some(\n  (priv) => priv.privilege_id === 'PROJ-15'\n)

alt Missing privilege PROJ-15
    Controller ->> Routes : res.status(403).json\n({ error: 'You cannot delete project achievements.' })
    activate Routes
    Routes ->> Client : HTTP 403 Forbidden
    deactivate Routes
    Client -> AchievementsView : showAchievementError(error)
    AchievementsView --> User : Privilege error message
end

Controller -> Controller : validateDeletePayload(project_id, achievement_id)

alt Invalid delete payload on server
    Controller ->> Routes : res.status(400).json\n({ error: 'Invalid achievement deletion request.' })
    activate Routes
    Routes ->> Client : HTTP 400 Bad Request
    deactivate Routes
    Client -> AchievementsView : showAchievementError(error)
    AchievementsView --> User : Invalid delete input message
end

Controller ->> ProjectModel : findById(project_id)
activate ProjectModel
ProjectModel ->> DB : execute(\n  'SELECT P.project_id, P.status\n   FROM project AS P\n   WHERE P.project_id = ?',\n  [project_id]\n)
activate DB
DB -->> ProjectModel : projectRows[]
deactivate DB
ProjectModel -->> Controller : projectRows[]
deactivate ProjectModel

alt Project not found
    Controller ->> Routes : res.status(404).json\n({ error: 'The selected project was not found.' })
    activate Routes
    Routes ->> Client : HTTP 404 Not Found
    deactivate Routes
    Client -> AchievementsView : showAchievementError(error)
    AchievementsView --> User : Project not found message
end

Controller ->> AchievementModel : fetchById(achievement_id)
activate AchievementModel
AchievementModel ->> DB : execute(\n  'SELECT A.achievement_id, A.project_id, A.title, A.description,\n          A.achievement_date, A.evidence_link\n   FROM achievement AS A\n   WHERE A.achievement_id = ?\n   LIMIT 1',\n  [achievement_id]\n)
activate DB
DB -->> AchievementModel : achievementRows[]
deactivate DB
AchievementModel -->> Controller : achievementRows[]
deactivate AchievementModel

alt Achievement not found or not linked to project
    Controller ->> Routes : res.status(404).json\n({ error: 'The selected achievement was not found for this project.' })
    activate Routes
    Routes ->> Client : HTTP 404 Not Found
    deactivate Routes
    Client -> AchievementsView : showAchievementError(error)
    AchievementsView --> User : Achievement not found message
end

Controller ->> AchievementModel : delete(achievement_id, project_id)
activate AchievementModel
AchievementModel ->> DB : execute(\n  'DELETE FROM achievement\n   WHERE achievement_id = ?\n   AND project_id = ?',\n  [achievement_id, project_id]\n)
activate DB
DB -->> AchievementModel : delete result
deactivate DB
AchievementModel -->> Controller : achievement deleted
deactivate AchievementModel

Controller ->> AchievementModel : fetchByProject(project_id)
activate AchievementModel
AchievementModel ->> DB : execute(\n  'SELECT A.achievement_id, A.project_id, A.employee_responsible_id,\n          A.title, A.description, A.achievement_date, A.evidence_link,\n          E.full_name\n   FROM achievement AS A\n   LEFT JOIN employee AS E\n     ON E.employee_id = A.employee_responsible_id\n   WHERE A.project_id = ?\n   ORDER BY A.achievement_date DESC, A.title ASC',\n  [project_id]\n)
activate DB
DB -->> AchievementModel : achievementRows[]
deactivate DB
AchievementModel -->> Controller : achievementRows[]
deactivate AchievementModel

Controller ->> Routes : res.status(200).json\n({ success: true,\n  message: 'Achievement deleted successfully.',\n  achievements: achievementRows })
activate Routes
Routes ->> Client : HTTP 200 OK application/json
deactivate Routes
Client -> AchievementsView : updateAchievementsModule(data.achievements)\ncloseDeleteAchievementPopup()
AchievementsView --> User : Updated achievement card list

alt Unexpected error (catch)
    Controller ->> Routes : res.status(500).json\n({ error: 'Error deleting project achievement.' })
    activate Routes
    Routes ->> Client : HTTP 500 Internal Server Error
    deactivate Routes
    Client -> AchievementsView : showAchievementError(error)
    AchievementsView --> User : Generic delete error message
end

deactivate Controller
deactivate Client

@enduml
