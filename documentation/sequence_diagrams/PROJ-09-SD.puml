@startuml
skinparam style strictuml

actor Lead as L
boundary "vista project.ejs" as V
boundary "routes" as RO
control "project.controller" as C
entity "Goal.model" as A
database "unitas_system" as BD
autonumber

activate L
L->>V: Click "Add" button in the Project Goal module
    activate V
    V->V: showGoalPopup();
    V-->L: Show goal popup
    deactivate V

opt Cancel Creation
L->>V: Clicks the "Close" button.
    activate V
    V->V: closePopup();
    deactivate V
end

L->>V: Clicks the "Submit" button
    activate V
    V->V: createAchievement(data)
    V->>RO: fetch('/project/goal/new',{method: PUT, headers:{'Accept': 'application/json'}, body: JSON.stringify(data)})
        activate RO
        RO->C: createGoal(request, response);
        deactivate RO
            activate C
            C->>A: createGoal(project_id, employee_responsible_id, title, description, due_date, status);
                activate A
                A->>BD: execute('INSERT INTO goal() VALUES (UUID(),?,?,?,?,?,?,NOW())',[project_id, employee_responsible_id, title, description, due_date, status])
                    activate BD
                    BD-->A: goal_id
                    deactivate BD
                A-->C: goal_id
                deactivate A
            C->>A: fetchOneGoal(goal_id);
                activate A
                A->>BD: execute('SELECT goal_id, title, description, due_date, status FROM goal WHERE goal_id=?', [goal_id]);
                    activate BD
                    BD-->A: data
                    deactivate BD
                A-->C: data
                deactivate A
            C-->V: response.json({success:true, body:data});
    V->V:closePopup();
    V->V:createGoalModal(data);

    alt Creation failed
            C-->V: response.json({success:false, error:error});
            deactivate C
    V->V:closePopup();
    V->V:showErrorPopoup(error);
    end

    V-->L: Updated view
    deactivate V
deactivate L
@enduml