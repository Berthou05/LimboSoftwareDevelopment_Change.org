@startuml
skinparam style strictuml
skinparam sequenceArrowThickness 1.2
skinparam roundcorner 6
autonumber

actor    "Admin User"                  as Admin
boundary "admin-accounts.ejs"          as AccountsView
control  "adminAccounts.js (AJAX)"     as Client
boundary "admin.routes"                as Routes
control  "admin.controller"            as Controller
entity   "account.model"               as AccountModel
entity   "role.model"                  as RoleModel
entity   "accountRoleAssignment.model" as AccountRoleModel
database "unitas_system"               as DB

activate Admin
Admin ->> AccountsView : Change role dropdown\n(Admin | Lead | Employee)
activate AccountsView
AccountsView --> Client : onRoleChanged(account_id, role_name)
activate Client
Client -> Client : validateRoleSelection(role_name)

alt Invalid role selection on client
    Client --> AccountsView : revertRoleDropdown()\nshowRoleUpdateError('Invalid role')
    AccountsView --> Admin : Validation message
end

Client ->> Routes : fetch('/admin/accounts/:account_id/role',\n{method:'PATCH', headers:{'Accept':'application/json',\n'Content-Type':'application/json'},\nbody:JSON.stringify({role_name, _csrf})})
activate Routes
Routes -> Controller : updateAccountRole(request, response)
activate Controller
deactivate Routes

Controller -> Controller : hasPrivilege('ADMIN-05', request.session.privileges)

alt Missing privilege ADMIN-05
    Controller --> Routes : res.status(403).json\n({ error: 'You do not have permission to update account roles.' })
    activate Routes
    Routes --> Client : HTTP 403 Forbidden
    deactivate Routes
    Client -> AccountsView : revertRoleDropdown()\nshowRoleUpdateError(error)
    AccountsView --> Admin : Permission error
end

Controller ->> AccountRoleModel : countActiveAdminsExcluding(account_id)
activate AccountRoleModel
AccountRoleModel ->> DB : execute(\n  'SELECT COUNT(*) AS admin_count\n   FROM accountrole ar\n   INNER JOIN role r ON r.role_id = ar.role_id\n   WHERE r.name = ?\n   AND ar.account_id <> ?',\n  ['ADMIN', account_id]\n)
activate DB
DB --> AccountRoleModel : adminCount
deactivate DB
AccountRoleModel --> Controller : adminCount
deactivate AccountRoleModel

alt Attempt to remove last Admin
    Controller --> Routes : res.status(409).json\n({ error: 'At least one Admin account is required.' })
    activate Routes
    Routes --> Client : HTTP 409 Conflict
    deactivate Routes
    Client --> AccountsView : revertRoleDropdown()\nshowRoleUpdateError(error)
    AccountsView --> Admin : Business-rule warning
end

Controller ->> AccountRoleModel : updateRole(account_id, role_id)
activate AccountRoleModel
AccountRoleModel ->> DB : execute(\n  'UPDATE accountrole\n   SET role_id = ?\n   WHERE account_id = ?',\n  [role_id, account_id]\n)
activate DB
DB --> AccountRoleModel : update result
deactivate DB
AccountRoleModel --> Controller : roleUpdated
deactivate AccountRoleModel

Controller ->> AccountRoleModel : fetchRoleByAccount(account_id)
activate AccountRoleModel
AccountRoleModel ->> DB : execute(\n  'SELECT ar.account_id, r.role_id, r.name\n   FROM accountrole ar\n   INNER JOIN role r ON r.role_id = ar.role_id\n   WHERE ar.account_id = ?',\n  [account_id]\n)
activate DB
DB --> AccountRoleModel : accountRoleRow
deactivate DB
AccountRoleModel --> Controller : accountRoleRow
deactivate AccountRoleModel

Controller --> Routes : res.status(200).json\n({ success: true,\n  message: 'Role updated successfully.',\n  data: { account_id, role_name } })
activate Routes
Routes --> Client : HTTP 200 OK application/json
deactivate Routes
Client --> AccountsView : updateRoleCell(data)\nshowRoleUpdateSuccess(message)
AccountsView --> Admin : Updated role shown in row

alt Unexpected error (catch)
    Controller ->> Routes : res.status(500).json\n({ error: 'Role could not be updated right now.' })
    activate Routes
    Routes ->> Client : HTTP 500 Internal Server Error
    deactivate Routes
    Client -> AccountsView : revertRoleDropdown()\nshowRoleUpdateError(error)
    AccountsView --> Admin : Generic error message
end

deactivate Admin
deactivate Controller
deactivate Client
deactivate AccountsView

@enduml
