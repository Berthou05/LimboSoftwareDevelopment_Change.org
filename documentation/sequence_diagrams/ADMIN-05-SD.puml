@startuml
skinparam style strictuml
autonumber

actor "Admin" as U
boundary "accounts.ejs" as V
boundary "admin.routes" as RO
control "admin.controller" as C
control "admin.service" as SV
entity "role.model" as R
entity "accountrole.model" as X
database "unitas_system" as DB

U -> V: Change role in account row
activate V
V -> RO: fetch('/admin/accounts/:accountId/role',\n{method:'PATCH', headers:{'Content-Type':'application/json'},\nbody:JSON.stringify({roleId})})
activate RO
RO -> C: assignRole(request, response)
activate C
C -> SV: assignRole(accountId, roleId)
activate SV
SV -> R: findById(roleId)
activate R
R -> DB: SELECT id, name\nFROM role\nWHERE id = ?
activate DB
DB --> R: role row / null
deactivate DB
R --> SV: role / null
deactivate R

alt Role invalid
SV --> C: validation error
deactivate SV
C --> RO: response.json({success:false,error:"Invalid role"})
deactivate C
RO --> V: HTTP 400 application/json
deactivate RO
V -> V: response.json()
V -> V: showRoleAssignmentError(error)
else Role valid
SV -> X: updateRole(accountId, roleId)
activate X
X -> DB: UPDATE accountrole\nSET role_id = ?, updated_at = NOW()\nWHERE account_id = ? AND revoked_at IS NULL
activate DB
DB --> X: updated rows / database error
deactivate DB
X --> SV: update result
deactivate X

alt Update failed
SV --> C: update error
deactivate SV
C --> RO: response.json({success:false,error:"Role could not be updated"})
deactivate C
RO --> V: HTTP 500 application/json
deactivate RO
V -> V: response.json()
V -> V: showRoleAssignmentError(error)
else Update succeeded
SV -> X: findActiveRoleByAccount(accountId)
activate X
X -> DB: SELECT ar.account_id, r.id AS role_id, r.name\nFROM accountrole ar\nJOIN role r ON r.id = ar.role_id\nWHERE ar.account_id = ? AND ar.revoked_at IS NULL
activate DB
DB --> X: updated account role row
deactivate DB
X --> SV: account role
deactivate X
SV --> C: updated row data
deactivate SV
C --> RO: response.json({success:true,data:accountRole})
deactivate C
RO --> V: HTTP 200 application/json
deactivate RO
V -> V: response.json()
V -> V: updateAccountRoleRow(data)
end
deactivate V

@enduml