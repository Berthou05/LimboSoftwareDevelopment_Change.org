@startuml
skinparam style strictuml

actor Lead as L
boundary "project.routes" as RO
boundary "vista projectNew.ejs" as VN
boundary "vista projectDirectory.ejs" as VD
control "project.controller" as C
entity "Project.model" as PM
database "unitas_system" as BD
autonumber

activate L
L -> RO: GET /projects/new
deactivate L
    activate RO
    RO -> C: getNewProjectPage(request, response)
    deactivate RO
        activate C
        C -> VN: response.render('pages/projectNew',\n{ empty projectForm, formErrors: [], formError: '' })
        deactivate C
    activate VN
    VN -> L: HTML form
    deactivate VN

activate L
L -> RO: POST /projects
deactivate L
    activate RO
    RO -> C: createProject(request, response)
    deactivate RO
        activate C
        C -> C: trim body fields\n(name, description, startDate, endDate)
        C -> C: validate required fields\n(name, startDate)

        alt missing required fields
            C -> VN: response.render('pages/projectNew',\n{ projectForm, formErrors })
            deactivate C
            activate VN
            VN -> L: HTML form + validationErrors list
            deactivate VN
        end

        C ->> PM: findByName(projectForm.name)
            activate PM
            PM ->> BD: execute('SELECT project_id, name FROM project WHERE name = ?', [projectForm.name])
                activate BD
                BD --> PM: projects[]
                deactivate BD
            PM --> C: [projects]
            deactivate PM

        alt duplicate name
            C -> VN: response.render('pages/projectNew',\n{ projectForm, formError })
            deactivate C
            activate VN
            VN -> L: HTML form + duplicate error
            deactivate VN
        end

        C -> C: build new Project('', employeeId,\nprojectForm.name, projectForm.description || null,\nProject.Status.IN_PROGRESS,\nprojectForm.startDate || null,\nprojectForm.endDate || null, new Date())
        C ->> PM: save()
            activate PM
            PM ->> BD: execute('INSERT INTO project(project_id,\nemployee_responsible_id, name, description,\nstatus, start_date, end_date, created_at)\nVALUES (UUID(), ?, ?, ?, ?, ?, ?, ?)',\n[employeeId, projectForm.name,\nprojectForm.description || null,\n'IN PROGRESS', projectForm.startDate || null,\nprojectForm.endDate || null, new Date()])
                activate BD
                BD --> PM: success
                deactivate BD
            PM --> C: success
            deactivate PM

        C -> C: request.session.success =\n`Project ${projectForm.name} was created successfully.`
        C -> RO: response.redirect('/projects')
        deactivate C
            activate RO
            RO -> C: getProjects(request, response)
            deactivate RO
                activate C
                C ->> PM: fetchByEmployeeId(employeeId)
                    activate PM
                    PM ->> BD: execute('SELECT ...', [employeeId, employeeId])
                        activate BD
                        BD --> PM: myProjects[]
                        deactivate BD
                    PM --> C: [myProjects]
                    deactivate PM
                C ->> PM: fetchNotByEmployeeId(employeeId)
                    activate PM
                    PM ->> BD: execute('SELECT ...', [employeeId, employeeId])
                        activate BD
                        BD --> PM: otherProjects[]
                        deactivate BD
                    PM --> C: [otherProjects]
                    deactivate PM
                C -> VD: response.render('pages/projectDirectory', { myProjects, otherProjects })
                deactivate C
            activate VD
            VD -> L: HTML project directory
            deactivate VD

@enduml
