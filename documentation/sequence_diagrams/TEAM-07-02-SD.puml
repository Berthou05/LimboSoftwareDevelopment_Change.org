@startuml
skinparam style strictuml
autonumber

actor "Admin" as U
boundary "team-members.ejs" as V
boundary "team.routes" as RO
control "team.controller" as C
entity "employeeteam.model" as X
database "unitas_system" as DB

U -> V: Click "Remove member"
activate V

opt Cancel removal
V -> V: closeRemoveMemberDialog
end

V -> RO: fetch DELETE /teams/:teamId/members/:employeeId
activate RO
RO -> C: removeMember
activate C

C -> X: findActiveMembership
activate X
X -> DB: SELECT id, joined_at\nFROM employeeteam\nWHERE team_id = ? AND employee_id = ? AND left_at IS NULL
activate DB
DB --> X: active membership / null
deactivate DB
X --> C: membership / null
deactivate X

alt Selected employee is not an active member
C --> RO: response.json({success:false,error:"Employee is not an active member"})
deactivate C
RO --> V: HTTP 404 application/json
deactivate RO
V -> V: response.json
V -> V: showMembersError
else Selected employee is active
C -> X: markLeftAt
activate X
X -> DB: UPDATE employeeteam\nSET left_at = NOW()\nWHERE team_id = ? AND employee_id = ? AND left_at IS NULL
activate DB
DB --> X: updated rows
deactivate DB
X --> C: membership updated
deactivate X

C -> X: listActiveMembers
activate X
X -> DB: SELECT et.team_id, e.id AS employee_id, e.first_name, e.last_name, et.role\nFROM employeeteam et\nJOIN employee e ON e.id = et.employee_id\nWHERE et.team_id = ? AND et.left_at IS NULL\nORDER BY e.first_name, e.last_name
activate DB
DB --> X: active member rows
deactivate DB
X --> C: members
deactivate X

C --> RO: response.json({success:true,data:members})
deactivate C
RO --> V: HTTP 200 application/json
deactivate RO
V -> V: response.json
V -> V: updateTeamMembersModule
end

deactivate V
@enduml