@startuml
skinparam style strictuml
skinparam sequenceArrowThickness 1.2
skinparam roundcorner 6
autonumber

actor    "Slack Automation"             as Slack
boundary "dailyentry.routes"            as Routes
control  "dailyentry.controller"        as Controller
entity   "account.model"                as AccountModel
entity   "team.model"                   as TeamModel
entity   "employeeTeamMembership.model" as EmployeeTeamModel
entity   "dailyentry.model"             as DailyEntryModel
entity   "activity.model"               as ActivityModel
entity   "collaboration.model"          as CollaborationModel
control  "ai.wrapper"                   as AIWrapper
entity   "ai.provider"                  as AIProvider
database "unitas_system"                as DB

activate Slack
Slack ->> Routes : POST /daily-entries/slack\n{slack_username, entry_date,\ndone, to_do, blockers,\nslack_standup_URL, slack_teams[]}
activate Routes
Routes -> Controller : submitFromSlack(req, res)
deactivate Routes
activate Controller

Controller -> Controller : validateSlackSignature(req.headers)

alt Invalid signature
    Controller -->> Slack : res.status(401).json\n({ message: 'Invalid Slack signature' })
end

Controller ->> AccountModel : findBySlackUsername(slack_username)
activate AccountModel
AccountModel ->> DB : execute(\n  'SELECT account_id, employee_id, status\n   FROM account\n   WHERE slack_username = ?',\n  [slack_username]\n)
activate DB
DB -->> AccountModel : account | null
deactivate DB
AccountModel -->> Controller : account | null
deactivate AccountModel

alt Account not found or DISABLED
    Controller -->> Slack : res.status(404).json\n({ message: 'Employee account not found' })
end

Controller ->> DailyEntryModel : findByEmployeeAndDate\n(employee_id, entry_date)
activate DailyEntryModel
DailyEntryModel ->> DB : execute(\n  'SELECT entry_id FROM dailyentry\n   WHERE employee_id = ?\n   AND entry_date = ?',\n  [employee_id, entry_date]\n)
activate DB
DB -->> DailyEntryModel : entry | null
deactivate DB
DailyEntryModel -->> Controller : entry | null
deactivate DailyEntryModel

alt Entry already exists for today
    Controller -->> Slack : res.status(409).json\n({ message: 'Daily entry already exists for today' })
end

Controller ->> DailyEntryModel : create(employee_id, entry_date,\nto_do, done, blockers,\nslack_standup_URL)
activate DailyEntryModel
DailyEntryModel ->> DB : execute(\n  'INSERT INTO dailyentry\n   (entry_id, employee_id, entry_date,\n    to_do, done, blockers, slack_standup_URL)\n   VALUES (?, ?, ?, ?, ?, ?, ?)',\n  [entry_id, employee_id, entry_date,\n   to_do, done, blockers, slack_standup_URL]\n)
activate DB
DB -->> DailyEntryModel : entry_id
deactivate DB
DailyEntryModel -->> Controller : entry_id
deactivate DailyEntryModel

Controller -->> Slack : HTTP 202 Accepted
deactivate Slack

loop for each slack_team_name in slack_teams[]

    Controller ->> TeamModel : findActiveByName(slack_team_name)
    activate TeamModel
    TeamModel ->> DB : execute(\n  'SELECT team_id, name, status\n   FROM team\n   WHERE name = ?\n   AND status = ?',\n  [slack_team_name, 'ACTIVE']\n)
    activate DB
    DB -->> TeamModel : team | null
    deactivate DB
    TeamModel -->> Controller : team | null
    deactivate TeamModel

    alt Team not found in catalog
        Controller -> Controller : logUnknownSlackTeam(slack_team_name)
    end

    Controller ->> EmployeeTeamModel : fetchActiveByEmployeeAndTeam\n(employee_id, team_id)\n[when team_id was found]
    activate EmployeeTeamModel
    EmployeeTeamModel ->> DB : execute(\n  'SELECT employee_id, team_id\n   FROM employeeteam\n   WHERE employee_id = ?\n   AND team_id = ?\n   AND left_at IS NULL\n   LIMIT 1',\n  [employee_id, team_id]\n)
    activate DB
    DB -->> EmployeeTeamModel : membership | null
    deactivate DB
    EmployeeTeamModel -->> Controller : membership | null
    deactivate EmployeeTeamModel

    alt Employee already active team member
        Controller -> Controller : skipTeamAutoJoin(team_id)
    end

    alt Employee is not active team member
        Controller ->> EmployeeTeamModel : join(employee_id, team_id,\nNOW(), 'EMPLOYEE')
        activate EmployeeTeamModel
        EmployeeTeamModel ->> DB : execute(\n  'INSERT INTO employeeteam\n   (employee_id, team_id, joined_at, left_at, role)\n   VALUES (?, ?, ?, NULL, ?)',\n  [employee_id, team_id, NOW(), 'EMPLOYEE']\n)
        activate DB
        DB -->> EmployeeTeamModel : joined
        deactivate DB
        EmployeeTeamModel -->> Controller : membership created
        deactivate EmployeeTeamModel
    end

end

Controller ->> AIWrapper : extractActivities\n(entry_id, done, to_do, blockers,\nslack_standup_URL)
activate AIWrapper
AIWrapper ->> AIProvider : POST /completions\n{ model, messages:\n  [{ role: 'user',\n     content: done + to_do + blockers }] }
activate AIProvider
AIProvider -->> AIWrapper : activities[] | error\n(each item: {title, description,\nproject_hint, worked_on_project})
deactivate AIProvider

alt AI extraction failed
    AIWrapper -> AIWrapper : logFailure(entry_id, error)
    note right of AIWrapper
        Daily entry is preserved.
        Only extraction failed.
    end note
end

AIWrapper -->> Controller : activities[]
deactivate AIWrapper

loop for each extracted activity

    Controller ->> ActivityModel : findProjectMatch\n(activity.project_hint)
    activate ActivityModel
    ActivityModel ->> DB : execute(\n  'SELECT project_id\n   FROM project\n   WHERE (name LIKE ? OR ? LIKE CONCAT("%", name, "%"))\n   AND status <> ?\n   LIMIT 1',\n  [activity.project_hint, activity.project_hint,\n   'DISABLED']\n)
    activate DB
    DB -->> ActivityModel : project_id | null
    deactivate DB
    ActivityModel -->> Controller : project_id | null
    deactivate ActivityModel

    alt Project not detected or activity.worked_on_project = false
        Controller -> Controller : keepActivityWithoutProject()
    end

    Controller ->> CollaborationModel : findActiveByProjectAndEmployee\n(project_id, employee_id)\n[when project_id exists and worked_on_project = true]
    activate CollaborationModel
    CollaborationModel ->> DB : execute(\n  'SELECT collaboration_id\n   FROM collaboration\n   WHERE project_id = ?\n   AND employee_id = ?\n   AND ended_at IS NULL\n   LIMIT 1',\n  [project_id, employee_id]\n)
    activate DB
    DB -->> CollaborationModel : collaboration | null
    deactivate DB
    CollaborationModel -->> Controller : collaboration | null
    deactivate CollaborationModel

    alt Employee already active project collaborator
        Controller -> Controller : skipProjectAutoJoin(project_id)
    end

    alt Employee is not active project collaborator
        Controller ->> CollaborationModel : joinProject(project_id, employee_id,\n'Auto-joined from Slack standup.', 'EMPLOYEE')
        activate CollaborationModel
        CollaborationModel ->> DB : execute(\n  'INSERT INTO collaboration\n   (collaboration_id, project_id, employee_id,\n    description, started_at, ended_at, role)\n   VALUES (UUID(), ?, ?, ?, NOW(), NULL, ?)',\n  [project_id, employee_id,\n   'Auto-joined from Slack standup.', 'EMPLOYEE']\n)
        activate DB
        DB -->> CollaborationModel : joined
        deactivate DB
        CollaborationModel -->> Controller : collaboration created
        deactivate CollaborationModel
    end

    Controller ->> ActivityModel : create(entry_id, employee_id,\nproject_id, title, description)
    activate ActivityModel
    ActivityModel ->> DB : execute(\n  'INSERT INTO activity\n   (activity_id, entry_id, employee_id,\n    project_id, title, description)\n   VALUES (?, ?, ?, ?, ?, ?)',\n  [activity_id, entry_id, employee_id,\n   project_id, title, description]\n)
    activate DB
    DB -->> ActivityModel : activity_id
    deactivate DB
    ActivityModel -->> Controller : activity_id
    deactivate ActivityModel

end

deactivate Controller

@enduml
