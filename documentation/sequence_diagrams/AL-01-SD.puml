@startuml
skinparam style strictuml
skinparam sequenceArrowThickness 1.2
skinparam roundcorner 6
autonumber

actor    "Slack Automation"       as Slack
boundary "dailyentry.routes"      as Routes
control  "dailyentry.controller"  as Controller
entity   "account.model"          as AccountModel
entity   "dailyentry.model"       as DailyEntryModel
entity   "activity.model"         as ActivityModel
control  "ai.wrapper"             as AIWrapper
entity   "ai.provider"            as AIProvider
database "unitas_system"          as DB

Slack -> Routes : POST /daily-entries/slack\n{slack_username, entry_date,\ndone, to_do, blockers,\nslack_standup_URL}
activate Routes
Routes -> Controller : submitFromSlack(req, res)
activate Controller
deactivate Routes

Controller -> Controller : validateSlackSignature(req.headers)

alt Invalid signature
    Controller --> Routes : res.status(401).json\n({ message: 'Invalid Slack signature' })
    activate Routes
    Routes --> Slack : HTTP 401 Unauthorized
    deactivate Routes
end

Controller -> AccountModel : findBySlackUsername(slack_username)
activate AccountModel
AccountModel -> DB : execute(\n  'SELECT account_id, employee_id, status\n   FROM account\n   WHERE slack_username = ?',\n  [slack_username]\n)
activate DB
DB --> AccountModel : account | null
deactivate DB
AccountModel --> Controller : account | null
deactivate AccountModel

alt Account not found or DISABLED
    Controller --> Routes : res.status(404).json\n({ message: 'Employee account not found' })
    activate Routes
    Routes --> Slack : HTTP 404 Not Found
    deactivate Routes
end

Controller -> DailyEntryModel : findByEmployeeAndDate\n(employee_id, entry_date)
activate DailyEntryModel
DailyEntryModel -> DB : execute(\n  'SELECT entry_id FROM dailyentry\n   WHERE employee_id = ?\n   AND entry_date = ?',\n  [employee_id, entry_date]\n)
activate DB
DB --> DailyEntryModel : entry | null
deactivate DB
DailyEntryModel --> Controller : entry | null
deactivate DailyEntryModel

alt Entry already exists for today
    Controller --> Routes : res.status(409).json\n({ message: 'Daily entry already exists for today' })
    activate Routes
    Routes --> Slack : HTTP 409 Conflict
    deactivate Routes
end

Controller -> DailyEntryModel : create(employee_id, entry_date,\nto_do, done, blockers,\nslack_standup_URL)
activate DailyEntryModel
DailyEntryModel -> DB : execute(\n  'INSERT INTO dailyentry\n   (entry_id, employee_id, entry_date,\n    to_do, done, blockers, slack_standup_URL)\n   VALUES (?, ?, ?, ?, ?, ?, ?)',\n  [entry_id, employee_id, entry_date,\n   to_do, done, blockers, slack_standup_URL]\n)
activate DB
DB --> DailyEntryModel : entry_id
deactivate DB
DailyEntryModel --> Controller : entry_id
deactivate DailyEntryModel

Controller ->> Routes : res.status(202).json\n({ message: 'Daily entry received',\n  entry_id: entry_id })
activate Routes
Routes ->> Slack : HTTP 202 Accepted
deactivate Routes

Controller ->> AIWrapper : extractActivities\n(entry_id, done, to_do, blockers)
deactivate Controller
activate AIWrapper
AIWrapper ->> AIProvider : POST /completions\n{ model, messages:\n  [{ role: 'user',\n     content: done + to_do + blockers }] }
activate AIProvider
AIProvider --> AIWrapper : activities[] | error
deactivate AIProvider

alt AI extraction failed
    AIWrapper -> AIWrapper : logFailure(entry_id, error)
    note right of AIWrapper
        Daily entry is preserved.
        Only extraction failed.
    end note
    deactivate AIWrapper
end

AIWrapper --> Controller : activities[]
deactivate AIWrapper
activate Controller

loop for each extracted activity

    Controller -> ActivityModel : findProjectMatch\n(activity.project_hint)
    activate ActivityModel
    ActivityModel -> DB : execute(\n  'SELECT project_id FROM project\n   WHERE name LIKE ?\n   AND status <> ?',\n  [activity.project_hint, 'DISABLED']\n)
    activate DB
    DB --> ActivityModel : project_id | null
    deactivate DB
    ActivityModel --> Controller : project_id | null
    deactivate ActivityModel

    Controller -> ActivityModel : create(entry_id, employee_id,\nproject_id, title, description)
    activate ActivityModel
    ActivityModel -> DB : execute(\n  'INSERT INTO activity\n   (activity_id, entry_id, employee_id,\n    project_id, title, description)\n   VALUES (?, ?, ?, ?, ?, ?)',\n  [activity_id, entry_id, employee_id,\n   project_id, title, description]\n)
    activate DB
    DB --> ActivityModel : activity_id
    deactivate DB
    ActivityModel --> Controller : activity_id
    deactivate ActivityModel

end

deactivate Controller

@enduml