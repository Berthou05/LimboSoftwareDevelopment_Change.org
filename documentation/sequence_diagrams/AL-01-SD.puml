@startuml
skinparam style strictuml
autonumber

actor "Slack Automation" as S
boundary "dailyentry.routes" as RO
control "dailyentry.controller" as C
control "dailyentry.service" as SV
entity "account.model" as A
entity "employee.model" as E
entity "dailyentry.model" as D
entity "activity.model" as AC
entity "ai.service" as AI
database "unitas_system" as DB

S -> RO: POST /daily-entries/slack\nJSON payload
activate RO
RO -> C: submitFromSlack(request, response)
activate C
C -> SV: submitFromSlack(payload)
activate SV
SV -> SV: validateRequiredFields(source, slackUserId, date,\ndidToday, doingTomorrow, blockers)

alt Payload invalid
SV --> C: validation error
deactivate SV
C --> RO: 400 invalid payload
deactivate C
RO --> S: 400 {success:false,error:"Invalid payload"}
deactivate RO
else Payload valid
SV -> A: findBySlackUserId(payload.slackUserId)
activate A
A -> DB: SELECT id, slack_user_id\nFROM account\nWHERE slack_user_id = ?
activate DB
DB --> A: account row / null
deactivate DB
A --> SV: account / null
deactivate A

alt Account not found
SV --> C: 404 account not found
deactivate SV
C --> RO: error result
deactivate C
RO --> S: 404 {success:false,error:"Account not found"}
deactivate RO
else Account found
SV -> E: findByAccountId(account.id)
activate E
E -> DB: SELECT id, account_id\nFROM employee\nWHERE account_id = ?
activate DB
DB --> E: employee row / null
deactivate DB
E --> SV: employee / null
deactivate E

alt Employee not found
SV --> C: 404 employee not found
deactivate SV
C --> RO: error result
deactivate C
RO --> S: 404 {success:false,error:"Employee not found"}
deactivate RO
else Employee found
SV -> D: findByEmployeeAndDate(employee.id, payload.date)
activate D
D -> DB: SELECT id\nFROM dailyentry\nWHERE employee_id = ? AND entry_date = ?
activate DB
DB --> D: existing entry / null
deactivate DB
D --> SV: existing entry / null
deactivate D

alt Duplicate daily entry
SV --> C: 409 duplicate entry
deactivate SV
C --> RO: duplicate result
deactivate C
RO --> S: 409 {success:false,error:"Daily entry already exists"}
deactivate RO
else Entry not found
SV -> D: create(employee.id, payload.date,\npayload.didToday, payload.doingTomorrow, payload.blockers)
activate D
D -> DB: INSERT INTO dailyentry(employee_id, entry_date, did_today,\ndoing_tomorrow, blockers, source)\nVALUES (?, ?, ?, ?, ?, 'slack_workflow')
activate DB
DB --> D: inserted dailyentry id
deactivate DB
D --> SV: dailyentry
deactivate D

SV -> AI: generateActivities(didToday, doingTomorrow, blockers)
activate AI
AI --> SV: aiResponse / error
deactivate AI
SV -> SV: validateAiResponse(aiResponse)

alt AI response invalid or AI request failed
SV --> C: partial success with dailyentry
deactivate SV
C --> RO: 202 partial success
deactivate C
RO --> S: 202 {success:true,status:"partial_success",\ndailyEntrySaved:true,activitiesSaved:0}
deactivate RO
else AI response valid
loop For each generated activity
SV -> AC: create(dailyentry.id, activity)
activate AC
AC -> DB: INSERT INTO activity(dailyentry_id, description,\ncategory, confidence_score)\nVALUES (?, ?, ?, ?)
activate DB
DB --> AC: inserted activity id
deactivate DB
AC --> SV: activity saved
deactivate AC
end

SV --> C: success with dailyentry and activities
deactivate SV
C --> RO: 201 created
deactivate C
RO --> S: 201 {success:true,status:"success",\ndailyEntrySaved:true,activitiesSaved:n}
deactivate RO
end
end
end
end

@enduml
