@startuml
skinparam style strictuml
skinparam sequenceArrowThickness 1.2
skinparam roundcorner 6
autonumber

actor    "Slack Automation"        as Slack
boundary "dailyentry.routes"       as Routes
control  "dailyentry.controller"   as Controller
entity   "account.repository"      as AccountRepository
entity   "dailyentry.repository"   as DailyEntryRepository
entity   "activity.repository"     as ActivityRepository
entity   "ai.provider"             as AIProvider
database "unitas_system"           as DB

activate Slack
Slack      ->  Routes     : POST /daily-entries/slack\n{slack_username, entry_date,\ndone, to_do, blockers,\nslack_standup_URL}
activate Routes
Routes     ->  Controller : submitFromSlack(req, res)
activate Controller

Controller ->  Controller : validateSlackSignature(req.headers)

alt Invalid signature
    Controller --> Routes : throw 401
    Routes     --> Slack  : HTTP 401 Unauthorized

else Valid signature

    Controller ->  AccountRepository : findBySlackUsername(slack_username)
    activate AccountRepository
    AccountRepository ->  DB               : SELECT account_id, employee_id, status\nFROM account\nWHERE slack_username = ?
    activate DB
    DB                --> AccountRepository : account | null
    deactivate DB
    AccountRepository --> Controller        : account | null
    deactivate AccountRepository

    alt Account not found or DISABLED
        Controller --> Routes : throw 404
        Routes     --> Slack  : HTTP 404 Not Found

    else Account active

        Controller ->  DailyEntryRepository : findByEmployeeAndDate\n(employee_id, entry_date)
        activate DailyEntryRepository
        DailyEntryRepository ->  DB                  : SELECT entry_id FROM dailyentry\nWHERE employee_id = ?\nAND entry_date = ?
        activate DB
        DB                   --> DailyEntryRepository : entry | null
        deactivate DB
        DailyEntryRepository --> Controller            : entry | null
        deactivate DailyEntryRepository

        alt Entry already exists for today
            Controller --> Routes : throw 409
            Routes     --> Slack  : HTTP 409 Conflict

        else No duplicate

            Controller ->  DailyEntryRepository : create(employee_id, entry_date,\nto_do, done, blockers,\nslack_standup_URL)
            activate DailyEntryRepository
            DailyEntryRepository ->  DB                  : INSERT INTO dailyentry\n(entry_id, employee_id, entry_date,\nto_do, done, blockers,\nslack_standup_URL)
            activate DB
            DB                   --> DailyEntryRepository : entry_id
            deactivate DB
            DailyEntryRepository --> Controller            : entry_id
            deactivate DailyEntryRepository

            Controller --> Routes : 202 Accepted {entry_id}
            Routes     --> Slack  : HTTP 202 Accepted

            Controller ->> AIProvider : extractActivities\n(entry_id, done, to_do, blockers)
            activate AIProvider
            AIProvider --> Controller : activities[] | error
            deactivate AIProvider

            alt AI extraction failed
                Controller -> Controller : logFailure(entry_id, error)
                note right of Controller
                    Daily entry is preserved.
                    Only extraction failed.
                end note

            else Activities extracted

                loop for each extracted activity
                    Controller ->  ActivityRepository : findProjectMatch\n(activity.project_hint)
                    activate ActivityRepository
                    ActivityRepository ->  DB                 : SELECT project_id FROM project\nWHERE name LIKE ?\nAND status <> 'DISABLED'
                    activate DB
                    DB                 --> ActivityRepository  : project_id | null
                    deactivate DB
                    ActivityRepository --> Controller          : project_id | null
                    deactivate ActivityRepository

                    Controller ->  ActivityRepository : create(entry_id, employee_id,\nproject_id, title, description)
                    activate ActivityRepository
                    ActivityRepository ->  DB                 : INSERT INTO activity\n(activity_id, entry_id,\nemployee_id, project_id,\ntitle, description)
                    activate DB
                    DB                 --> ActivityRepository  : activity_id
                    deactivate DB
                    ActivityRepository --> Controller          : activity_id
                    deactivate ActivityRepository
                end

            end
        end
    end
end

deactivate Controller
deactivate Routes
deactivate Slack

@enduml