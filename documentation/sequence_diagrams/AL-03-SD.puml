@startuml
skinparam style strictuml
skinparam sequenceArrowThickness 1.2
skinparam roundcorner 6
autonumber

actor    "User"                    as User
boundary "activityLog.ejs"         as View
boundary "activityLog.routes"      as Routes
control  "activityLog.controller"  as Controller
control  "activityLog.service"     as Service
entity   "activity.model"          as Model
database "unitas_system"           as DB

note over View
    Reusable module embedded in:
    Home, Team, Project, Employee pages.
    Receives scope and identifiers
    from the parent page context.
end note

activate User
User ->  View : page containing\nActivity Log module loads
activate View

View ->  View : readPageContext()\nextract scope, identifiers\n(employee_id | team_id | project_id)

View ->> Routes : fetch('/activity-log'\n + '?scope={scope}'\n + '&{identifier_key}={id}'\n + '&range=today')
activate Routes
Routes ->  Controller : getActivityLog(req, res)
activate Controller
Controller ->  Service    : getActivityLog\n(scope, identifiers, range)
activate Service

Service ->  Service : validateScope(scope)
Service ->  Service : validateIdentifiers(scope, identifiers)
Service ->  Service : validateRange(range)

alt Invalid scope, identifiers or range
    Service    --> Controller : throw 400
    Controller --> Routes     : res.status(400)\n.json({ error: 'Invalid parameters' })
    Routes     --> View       : 400 { error }
    View       ->  View       : renderError\n('Invalid parameters')

else Valid parameters

    Service -> Service : resolveDateRange(range)\n→ { rangeStart, rangeEnd }

    alt scope == employee
        Service ->  Model : findByEmployee\n(employee_id, rangeStart, rangeEnd)
        activate Model
        Model   ->  DB    : SELECT a.activity_id, a.title,\na.description, a.completed_at,\np.name AS project_name\nFROM activity a\nLEFT JOIN project p\nON a.project_id = p.project_id\nWHERE a.employee_id = ?\nAND a.completed_at BETWEEN ? AND ?\nORDER BY a.completed_at DESC
        activate DB
        DB      --> Model   : rows
        deactivate DB
        Model   --> Service : activities[]
        deactivate Model

    else scope == team
        Service ->  Model : findByTeam\n(team_id, rangeStart, rangeEnd)
        activate Model
        Model   ->  DB    : SELECT a.activity_id, a.title,\na.description, a.completed_at,\ne.full_name AS employee_name,\np.name AS project_name\nFROM activity a\nJOIN employeeteam et\nON a.employee_id = et.employee_id\nLEFT JOIN project p\nON a.project_id = p.project_id\nJOIN employee e\nON a.employee_id = e.employee_id\nWHERE et.team_id = ?\nAND et.left_at IS NULL\nAND a.completed_at BETWEEN ? AND ?\nORDER BY a.completed_at DESC
        activate DB
        DB      --> Model   : rows
        deactivate DB
        Model   --> Service : activities[]
        deactivate Model

    else scope == project
        Service ->  Model : findByProject\n(project_id, rangeStart, rangeEnd)
        activate Model
        Model   ->  DB    : SELECT a.activity_id, a.title,\na.description, a.completed_at,\ne.full_name AS employee_name\nFROM activity a\nJOIN employee e\nON a.employee_id = e.employee_id\nWHERE a.project_id = ?\nAND a.completed_at BETWEEN ? AND ?\nORDER BY a.completed_at DESC
        activate DB
        DB      --> Model   : rows
        deactivate DB
        Model   --> Service : activities[]
        deactivate Model
    end

    alt No activities found
        Service    --> Controller : return { activities: [] }
        Controller --> Routes     : res.json({ activities: [] })
        Routes     --> View       : 200 { activities: [] }
        View       ->  View       : renderActivityLog([])\nshow empty state

    else Activities found
        Service    ->  Service    : formatActivityEntries(activities)
        Service    --> Controller : return { activities }
        Controller --> Routes     : res.json({ activities })
        Routes     --> View       : 200 { activities }
        View       ->  View       : renderActivityLog(activities)
    end

end

deactivate Service
deactivate Controller
deactivate Routes

opt User changes date filter\n(Today | Week | Month | Quarter | All)
    User ->  View : clicks filter button
    View ->  View : setActiveFilter(range)
    View ->> Routes : fetch('/activity-log'\n + '?scope={scope}'\n + '&{identifier_key}={id}'\n + '&range={newRange}')
    activate Routes
    Routes ->  Controller : getActivityLog(req, res)
    activate Controller
    Controller ->  Service : getActivityLog\n(scope, identifiers, newRange)
    activate Service
    Service ->  Service : resolveDateRange(newRange)
    Service ->  Model   : findBy[Scope]\n(identifiers, rangeStart, rangeEnd)
    activate Model
    Model   ->  DB      : SELECT ...\nWHERE ...\nAND completed_at BETWEEN ? AND ?
    activate DB
    DB      --> Model   : rows
    deactivate DB
    Model   --> Service : activities[]
    deactivate Model
    Service --> Controller : return { activities }
    deactivate Service
    Controller --> Routes  : res.json({ activities })
    deactivate Controller
    Routes  --> View       : 200 { activities }
    deactivate Routes
    View    ->  View       : renderActivityLog(activities)
end

deactivate View
deactivate User

@enduml