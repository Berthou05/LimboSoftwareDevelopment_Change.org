@startuml
skinparam style strictuml

actor User as U
boundary "team.ejs" as V
boundary "team.routes" as RO
control "team.controller" as C
entity "team.model" as T
database "unitas_system" as BD

autonumber

activate U

U -> V: Hover/Click over "Team Information" button
activate V
V -> V: showTeamInfo()
V ->> RO: fetch('/team/info/${team_id}', {\n method:'GET',\n headers:{'Accept':'application/json'}\n})
deactivate V

activate RO
RO -> C: getTeamInfo(request, response)
deactivate RO

activate C
C -> T: getTeamInfo(team_id)
activate T
T -> BD: execute("SELECT * FROM team WHERE team_id = ?", [team_id])
activate BD
BD --> T: info
deactivate BD
T --> C: info
deactivate T
C --> V: response.json({ body: info })
deactivate C

activate V
V -> V: createInfoPopover(info)
V --> U: Updated view
deactivate V

opt Close Information
    U -> V: Clicks or hovers outside "Team Information"
    activate V
    V -> V: closePopover()
    V --> U: Updated view
    deactivate V
end

deactivate U

@enduml