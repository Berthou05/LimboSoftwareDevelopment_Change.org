@startuml
skinparam style strictuml

actor "Admin" as U
boundary "roles.ejs" as V
boundary "routes" as RO
control "role.controller" as C
entity "Privilege.model" as M
database "unitas_system" as BD

autonumber

== Initialization ==

activate U
U -> V: Navigates to the Roles section
deactivate U
activate V
V -> RO: fetch('/roles/administration', {method: GET})
deactivate V

activate RO
RO -> C: getRolesTable(request, response)
deactivate RO

activate C
C -> M: fetchAllPrivileges()
activate M
M -> BD: execute('SELECT * FROM privilege')
activate BD
BD --> M: privileges_data
deactivate BD
M --> C: privileges_data
deactivate M

C -> V: render('roles.ejs', {data: privileges_data})
activate V
V -> V: renderRolesTable()
V -> V: displayToggleSwitches()
V -> U: Show Roles Administration table
deactivate V

== Assign/Toggle Privilege ==

activate U
U -> V: Toggles a specific Privilege switch
deactivate U
activate V
V -> V: captureChange(privilege_id, newState)
V -> RO: fetch('/roles/update-privilege', {method: POST, body: JSON.stringify(data)})
deactivate V

activate RO
RO -> C: updateRolePrivilege(request, response)
deactivate RO

activate C
C -> M: updatePrivilegeRelationship(role_id, privilege_id, newState)
activate M
M -> BD: execute('REPLACE INTO role_privilege (role_id, privilege_id) VALUES (?, ?)', [r_id, p_id])
activate BD

alt Update Successful? (yes)
    BD --> M: success
    M --> C: success
    C -> V: response.json({success: true})
    activate V
    V -> V: confirmRecordUpdate()
    V -> V: displaySuccessNotification()
    V -> V: refreshToggleState()
    V -> U: Privilege updated successfully
    deactivate V
    
else Update Successful? (no)
    BD --> M: error (Conflict/Connection)
    deactivate BD
    M --> C: error
    deactivate M
    C -> V: response.json({success: false, error: error})
    activate V
    V -> V: displayErrorMessage(error)
    V -> V: revertToggleSwitch()
    V -> U: Shows error and reverts switch
    deactivate V
end

deactivate C

@enduml