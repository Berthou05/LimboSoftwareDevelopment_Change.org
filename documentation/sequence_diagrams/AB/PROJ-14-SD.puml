@startuml
skinparam style strictuml
autonumber

actor "User" as U
boundary "project-achievements.ejs" as V
boundary "project.routes" as RO
control "project.controller" as C
control "project.service" as SV
entity "projectachievement.model" as X
database "unitas_system" as DB

U -> V: Click "Edit achievement"
activate V
V -> V: enableAchievementEditMode(achievementId)

opt Cancel achievement edit
U -> V: Click "Cancel"
V -> V: restoreAchievementRow(achievementId)
end

U -> V: Click "Save"
V -> RO: fetch('/projects/:projectId/achievements/:achievementId',\n{method:'PATCH', headers:{'Content-Type':'application/json'},\nbody:JSON.stringify(achievementForm)})
activate RO
RO -> C: updateAchievement(request, response)
activate C
C -> SV: updateAchievement(projectId, achievementId, achievementForm)
activate SV
SV -> SV: validateAchievementFields(title, description, achievementDate)

alt Achievement fields invalid
SV --> C: validation error
deactivate SV
C --> RO: response.json({success:false,error:"Invalid achievement data"})
deactivate C
RO --> V: HTTP 400 application/json
deactivate RO
V -> V: response.json()
V -> V: showAchievementUpdateError(error)
else Achievement fields valid
SV -> X: updateAchievement(projectId, achievementId, achievementForm)
activate X
X -> DB: UPDATE projectachievement\nSET title = ?, description = ?, achievement_date = ?\nWHERE id = ? AND project_id = ?
activate DB
DB --> X: updated rows
deactivate DB
X --> SV: update result
deactivate X
SV -> X: findById(projectId, achievementId)
activate X
X -> DB: SELECT id, project_id, title, description, achievement_date\nFROM projectachievement\nWHERE id = ? AND project_id = ?
activate DB
DB --> X: updated achievement row
deactivate DB
X --> SV: achievement
deactivate X
SV --> C: updated achievement data
deactivate SV
C --> RO: response.json({success:true,data:achievement})
deactivate C
RO --> V: HTTP 200 application/json
deactivate RO
V -> V: response.json()
V -> V: updateAchievementsModule(data)
end
deactivate V

@enduml
