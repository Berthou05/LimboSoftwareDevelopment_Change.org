@startuml
skinparam style strictuml

actor User as U
boundary "projects.ejs" as V
boundary "routes" as RO
control "project.controller" as C
entity "Project.model" as M
database "unitas_system" as DB

autonumber

== Visualize Project Details ==

activate U
U -> V: Select a project from the list
deactivate U

activate V
V -> V: captureProjectId(id)
V -> RO: fetch('/projects/details/:id', {method: GET})
deactivate V

activate RO
RO -> C: getProjectDetails(request, response)
deactivate RO

activate C
C -> M: fetchProjectById(project_id)
activate M

M -> DB: execute('SELECT name, description, team FROM project WHERE id = ?', [project_id])
activate DB

alt Register exists? (yes)
    DB --> M: project_data
    M --> C: project_data
    
    C -> V: response.json({success: true, body: project_data})
    activate V
    V -> V: processFormatData(project_data)
    V -> V: renderDetailsInterface()
    V -> U: Visualize project's information
    deactivate V
    
else Register exists? (no)
    DB --> M: null
    deactivate DB
    M --> C: error (not found)
    deactivate M
    
    C -> V: response.json({success: false, error: 'Register not found'})
    activate V
    V -> V: showErrorMessage()
    V -> V: returnToListOfProjects()
    V -> U: Redirected to project list
    deactivate V
end

deactivate C

@enduml