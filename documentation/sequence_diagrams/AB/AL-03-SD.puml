@startuml
skinparam style strictuml
autonumber

actor "User" as U
boundary "activity-log.ejs" as V
boundary "activity.routes" as RO
control "activity.controller" as C
control "activity.service" as SV
entity "activity.model" as X
database "unitas_system" as DB

U -> V: Open Activity Log and apply filters
activate V
V -> RO: fetch('/activities?scope=employee&from=2026-03-01&to=2026-03-23&type=all')
activate RO
RO -> C: getActivityLog(request, response)
activate C
C -> SV: getActivityLog(filters)
activate SV
SV -> SV: validateFilters(scope, from, to, type)

alt Filters invalid
SV --> C: validation error
deactivate SV
C --> RO: response.json({success:false,error:"Invalid filters"})
deactivate C
RO --> V: HTTP 400 application/json
deactivate RO
V -> V: response.json()
V -> V: showActivityLogError(error)
else Filters valid
SV -> X: findByFilters(filters)
activate X
X -> DB: SELECT id, occurred_at, actor_name, action, scope_type, scope_id\nFROM activity\nWHERE scope_type = ? AND occurred_at BETWEEN ? AND ?\nORDER BY occurred_at DESC
activate DB
DB --> X: matching activity rows
deactivate DB
X --> SV: activities
deactivate X
SV --> C: activity log data
deactivate SV
C --> RO: response.json({success:true,data:activities})
deactivate C
RO --> V: HTTP 200 application/json
deactivate RO
V -> V: response.json()

alt No activities found
V -> V: renderEmptyActivityLogState(data)
else Activities found
V -> V: updateActivityLogModule(data)
end
end
deactivate V

opt Re-filter Activity Log
U -> V: Change date range or type
activate V
V -> RO: fetch('/activities?scope=employee&from=2026-03-10&to=2026-03-23&type=comment')
activate RO
RO -> C: getActivityLog(request, response)
activate C
C -> SV: getActivityLog(updatedFilters)
activate SV
SV -> SV: validateFilters(updatedFilters)
SV -> X: findByFilters(updatedFilters)
activate X
X -> DB: SELECT id, occurred_at, actor_name, action, scope_type, scope_id\nFROM activity\nWHERE scope_type = ? AND occurred_at BETWEEN ? AND ?\nORDER BY occurred_at DESC
activate DB
DB --> X: filtered activity rows
deactivate DB
X --> SV: filtered activities
deactivate X
SV --> C: filtered data
deactivate SV
C --> RO: response.json({success:true,data:activities})
deactivate C
RO --> V: HTTP 200 application/json
deactivate RO
V -> V: response.json()
V -> V: updateActivityLogModule(data)
deactivate V
end

@enduml
