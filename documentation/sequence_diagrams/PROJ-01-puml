@startuml
skinparam style strictuml

actor Lead as U
boundary "routes" as RO
boundary "vista projectNew.ejs" as V
control "project.controller" as C
entity "Project.model" as PM
database "unitas_system" as BD

activate U
U -> RO:GET /projects/new
deactivate U
    activate RO
    RO -> C:new(request, response)
    deactivate RO
        activate C
        C -> V:response.render('projects/new.ejs')
        deactivate C
    activate V
    V -> U:HTML form
    deactivate V

activate U
U -> RO:POST /projects
deactivate U
    activate RO
    RO -> C:create(request, response)
    deactivate RO
        activate C
        C -> C:validate(request.body)
        
        alt missing required (name, dates)
            C -> V:response.render('projects/new.ejs', {errors: errors})
            deactivate C
                activate V
                V -> U:HTML + Error messages
                deactivate V
        
        else valid
            C ->> PM:findByName(name)
                activate PM
                PM ->> BD:execute('SELECT * FROM projects WHERE name=?', [name])
                    activate BD
                    BD --> PM:row/null
                    deactivate BD
                PM --> C:exists/null
                deactivate PM
            
            alt name exists
                C -> V:response.render('projects/new.ejs', {error: "Project already exists"})
                deactivate C
                    activate V
                    V -> U:HTML + Error message
                    deactivate V
            
            else new
                C -> C:setDefaults(status, created_at)
                
                C ->> PM:insert(data)
                    activate PM
                    PM ->> BD:execute('INSERT INTO projects (name, start_date, end_date, ...) VALUES (?, ?, ?, ...)', [data])
                        activate BD
                        
                        alt success
                            BD --> PM:project_id
                            deactivate BD
                            PM --> C:id
                            deactivate PM
                            
                            C -> RO:response.redirect('/projects/' + id)
                            deactivate C
                                activate RO
                                RO -> C:show(request, response)
                                deactivate RO
                                    activate C
                                    C ->> PM:findById(id)
                                        activate PM
                                        PM ->> BD:execute('SELECT * FROM projects WHERE id=?', [id])
                                            activate BD
                                            BD --> PM:row
                                            deactivate BD
                                        PM --> C:project
                                        deactivate PM
                                    C -> V:response.render('projects/show.ejs', {project: project, success: "Project created successfully"})
                                    deactivate C
                                        activate V
                                        V -> U:HTML + Success message
                                        deactivate V
                        
                        else fail
                            BD --> PM:error
                            deactivate BD
                            PM --> C:error
                            deactivate PM
                            
                            C -> V:response.render('projects/new.ejs', {error: "Could not save project"})
                            deactivate C
                                activate V
                                V -> U:HTML + Error message
                                deactivate V
                        end
            end
        end

activate U

@enduml