@startuml
skinparam style strictuml

actor Lead as U
boundary "routes" as RO
boundary "vista projectNew.ejs" as V
control "project.controller" as C
entity "Project.model" as PM
database "unitas_system" as BD

activate U
U -> RO:GET /projects/new
deactivate U
    activate RO
    RO -> C:new(request, response)
    deactivate RO
        activate C
        C -> V:response.render('projects/new.ejs')
        deactivate C
    activate V
    V -> U:HTML form
    deactivate V

activate U
U -> RO:POST /projects
deactivate U
    activate RO
    RO -> C:create(request, response)
    deactivate RO
        activate C
        C -> C:validate(request.body)
        
        alt missing required (name, dates)
            C -> V:response.render('projects/new.ejs', {errors: errors})
            deactivate C
                activate V
                V -> U:HTML + Error messages
                deactivate V
        

        else valid
            C ->> PM:findByName(name)
                activate PM
                PM ->> BD:SELECT * FROM project WHERE name=?
                    activate BD
                    BD --> PM:row/null
                    deactivate BD
                PM --> C:exists/null
                deactivate PM
            
            alt name exists
                C -> V:response.render('projects/new.ejs', {error: "Project already exists"})
                deactivate C
                    activate V
                    V -> U:HTML + Error message
                    deactivate V
            
            else new
                C -> C:generate project_id
                C -> C:set default status, created_at
                C ->> PM:insert({project_id, name, description, start_date, end_date, status, created_at})
                    activate PM
                    PM ->> BD:INSERT INTO project (project_id, name, description, start_date, end_date, status, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)
                        activate BD
                        BD --> PM:project_id
                        deactivate BD
                    PM --> C:project_id
                    deactivate PM
                C -> V:response.render('projects/show.ejs', {project_id, success: "Project created successfully"})
                deactivate C
                    activate V
                    V -> U:HTML + Success message
                    deactivate V
            end
        end

activate U

@enduml