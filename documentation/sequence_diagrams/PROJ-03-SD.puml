@startuml
skinparam style strictuml

actor User as U
boundary "project_details.ejs" as V
boundary "routes" as RO
control "project.controller" as C
entity "Project.model" as M
database "unitas_system" as BD

autonumber

== Delete Project ==

activate U
U -> V: Clicks "Delete Project" button
deactivate U

activate V
V -> V: displayConfirmationModal()
V -> U: Show confirmation modal
deactivate V

alt Confirms deletion? (no)
    activate U
    U -> V: Clicks "Cancel" / Closes modal
    deactivate U
    activate V
    V -> V: closeConfirmationModal()
    V -> U: Displays Project Details page (no changes)
    deactivate V

else Confirms deletion? (yes)
    activate U
    U -> V: Clicks "Confirm" button
    deactivate U
    activate V
    V -> V: captureProjectId(id)
    V -> RO: fetch('/project/delete/:id', {method: DELETE})
    deactivate V

    activate RO
    RO -> C: deleteProject(request, response)
    deactivate RO

    activate C
    C -> M: deleteProjectById(project_id)
    activate M
    M -> BD: execute('DELETE FROM project WHERE id = ?', [project_id])
    activate BD
    
    alt Database Success? (yes)
        BD --> M: success_status
        M --> C: success_status
        C -> V: response.json({success: true})
        activate V
        V -> V: redirectToDashboard()
        V -> V: displaySuccessNotification("Project Deleted Successfully")
        V -> U: Redirects and shows success message
        deactivate V
        
    else Database Success? (no)
        BD --> M: error_log
        deactivate BD
        M --> C: error_log
        deactivate M
        C -> V: response.json({success: false, error: 'Could not delete project'})
        activate V
        V -> V: displayErrorMessage("Error: Could not delete project")
        V -> U: Displays error notification
        deactivate V
    end
end

deactivate C

@enduml