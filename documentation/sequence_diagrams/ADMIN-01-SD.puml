@startuml
skinparam style strictuml
autonumber

actor "Admin" as U
boundary "roles.ejs" as V
boundary "admin.routes" as RO
control "admin.controller" as C
entity "role.model" as X
database "unitas_system" as DB

U -> V: Open Roles module
activate V
V -> RO: fetch('/admin/roles')
activate RO
RO -> C: getRoles(request, response)
activate C
C -> X: findAll()
activate X
X -> DB: SELECT id, name, description\nFROM role\nORDER BY name ASC
activate DB
DB --> X: role rows
deactivate DB
X --> C: roles
deactivate X
C --> RO: response.json({success:true,data:roles})
deactivate C
RO --> V: HTTP 200 application/json
deactivate RO
V -> V: response.json()

alt No roles returned
V -> V: renderRolesModule({items:[],empty:true})
else Roles returned
V -> V: renderRolesModule(data)
end
deactivate V

@enduml