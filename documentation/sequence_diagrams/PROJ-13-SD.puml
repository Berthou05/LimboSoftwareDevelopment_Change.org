@startuml
skinparam style strictuml

actor Lead as L
boundary "vista project.ejs" as V
boundary "routes" as RO
control "project.controller" as C
entity "Achievement.model" as A
database "unitas_system" as BD
autonumber

activate L
L->>V: Click "Add" button in the Project Achievement module
    activate V
    V->V: showAchievementPopup();
    V-->L: Updated view
    deactivate V

opt Cancel Creation
L->>V: Clicks the "Close" button.
    activate V
    V->V: closePopup();
    V-->L: Updated view
    deactivate V
end

L->>V: Clicks the "Submit" button
    activate V
    V->V: createAchievement(data)
    V->>RO: fetch('/project/achievement/new',{method: PUT, headers:{'Accept': 'application/json'}, body: JSON.stringify(data)})
        activate RO
        RO->C: createAchievement(request, response);
        deactivate RO
            activate C
            C->>A: createAchievement(project_id, employee_responsible_id, title, description, achievement_date, evidence_link);
                activate A
                A->>BD: execute('INSERT INTO achievement(achievement_id, project_id, employee_responsible_id, title, description, achievement_date, evidence_link) VALUES (UUID(),?,?,?,?,?,?) ',[project_id, employee_responsible_id, title, description, achievement_date, evidence_link])
                    activate BD
                    BD-->A: achievement_id
                    deactivate BD
                A-->C: achievement_id
                deactivate A
            C->A: fetchOneAchievement(achievement_id);
                activate A
                A->>BD: execute('SELECT achievement_id, title, description, achievement_date, evidence_link FROM achievement WHERE achievement_id=?', [achievement_id]);
                    activate BD
                    BD-->A: data
                    deactivate BD
                A-->C: data
                deactivate A
            C-->V: response.json({success:true, body:data});
    V->V:closePopup();
    V->V:createAchievementModal(data);
    V->V:showSuccessPopup("Achievement created successfully");
    V-->L:Updated view

    alt Creation failed
            C-->V: response.json({success:false, error:error});
            deactivate C
    V->V:closePopup();
    V->V:showErrorPopoup(error);
    V-->L: Updated view
    deactivate V
    end
deactivate L


@enduml