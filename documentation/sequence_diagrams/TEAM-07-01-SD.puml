@startuml
skinparam style strictuml
skinparam sequenceArrowThickness 1.2
skinparam roundcorner 6
autonumber

actor    "Employee"                  as User
boundary "teamDirectory/joinButton.ejs" as JoinButton
control  "teamDetails.js (AJAX)"     as Client
boundary "team.routes"               as Routes
control  "team.controller"           as Controller
entity   "employeeTeamMembership.model" as EmployeeTeam
database "unitas_system"             as DB

activate User
User -> JoinButton : Click "Leave Team"\n(same action toggles membership)
deactivate User
activate JoinButton
JoinButton -> Client : submitToggleMembership()
activate Client

Client -> Routes : fetch('/teams/:team_id/toggle-membership',\n{method:'POST', headers:{'Accept':'application/json',\n'Content-Type':'application/x-www-form-urlencoded'},\nbody:'_csrf=...'})
activate Routes
Routes -> Controller : toggleTeamMembership(request, response)
activate Controller
deactivate Routes

Controller -> Controller : targetEmployeeId = request.session.employeeId

alt Missing authenticated employee
    Controller ->> Routes : res.status(401).json\n({ error: 'You must be logged in to update team membership.' })
    activate Routes
    Routes ->> Client : HTTP 401 Unauthorized
    deactivate Routes
    Client -> JoinButton : showMembershipError(error)
    JoinButton --> User : Authentication error message
end

Controller -> EmployeeTeam : fetchByEmployeeAndTeam\n(targetEmployeeId, team_id)
activate EmployeeTeam
EmployeeTeam -> DB : execute(\n  'SELECT *\n   FROM employeeteam\n   WHERE employee_id = ?\n   AND team_id = ?',\n  [targetEmployeeId, team_id]\n)
activate DB
DB --> EmployeeTeam : memberships[]
deactivate DB
EmployeeTeam --> Controller : memberships[]
deactivate EmployeeTeam

alt Membership does not exist
    Controller -> EmployeeTeam : join(targetEmployeeId, team_id)
    activate EmployeeTeam
    EmployeeTeam -> DB : execute(\n  'INSERT INTO employeeteam\n   (employee_id, team_id, joined_at, left_at, role)\n   VALUES (?, ?, ?, ?, ?)',\n  [targetEmployeeId, team_id,\n   NOW(), NULL, 'EMPLOYEE']\n)
    activate DB
    DB --> EmployeeTeam : insert result
    deactivate DB
    EmployeeTeam --> Controller : joined
    deactivate EmployeeTeam
end

alt Existing membership is inactive (left_at not null)
    Controller -> EmployeeTeam : update(targetEmployeeId, team_id,\n{joined_at: NOW(), left_at: null,\n role: previousRole || 'EMPLOYEE'})
    activate EmployeeTeam
    EmployeeTeam -> DB : execute(\n  'UPDATE employeeteam\n   SET joined_at = ?, left_at = ?, role = ?\n   WHERE employee_id = ? AND team_id = ?',\n  [NOW(), NULL, previousRole || 'EMPLOYEE',\n   targetEmployeeId, team_id]\n)
    activate DB
    DB --> EmployeeTeam : update result
    deactivate DB
    EmployeeTeam --> Controller : rejoined
    deactivate EmployeeTeam
end

alt Existing membership is active
    Controller -> EmployeeTeam : leave(targetEmployeeId, team_id)
    activate EmployeeTeam
    EmployeeTeam -> DB : execute(\n  'UPDATE employeeteam\n   SET left_at = ?\n   WHERE employee_id = ?\n   AND team_id = ?',\n  [NOW(), targetEmployeeId, team_id]\n)
    activate DB
    DB --> EmployeeTeam : update result
    deactivate DB
    EmployeeTeam --> Controller : left
    deactivate EmployeeTeam
end

Controller ->> Routes : res.status(200).json\n({ success: true,\n  message: 'You left the team.' | 'You joined the team.' })
activate Routes
Routes ->> Client : HTTP 200 OK application/json
deactivate Routes
Client -> JoinButton : updateJoinButtonFromMembershipState()\nupdateTeamParticipantsModule()
JoinButton --> User : Team membership view refreshed

alt Unexpected error (catch)
    Controller ->> Routes : res.status(500).json\n({ error: 'Error updating membership for team {team_id}.' })
    activate Routes
    Routes ->> Client : HTTP 500 Internal Server Error
    deactivate Routes
    Client -> JoinButton : showMembershipError(error)
    JoinButton --> User : Generic membership error
end

deactivate Controller
deactivate Client
deactivate JoinButton

@enduml
