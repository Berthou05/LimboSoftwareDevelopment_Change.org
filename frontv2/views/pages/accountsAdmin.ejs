<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="font-heading text-xl font-bold">Accounts Administration</h2>
    <button
      type="button"
      class="rounded-xl border border-brand-primary px-3 py-2 text-sm font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white"
    >
      Create Account
    </button>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-brand-secondary/70 text-sm">
      <thead>
        <tr class="text-left text-brand-text/70">
          <th class="px-3 py-2">Account</th>
          <th class="px-3 py-2">Employee</th>
          <th class="px-3 py-2">Role</th>
          <th class="px-3 py-2">Status</th>
          <th class="px-3 py-2">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-brand-secondary/60">
        <% accounts.forEach((account) => { %>
          <tr>
            <td class="px-3 py-2">
              <p class="font-semibold"><%= account.email %></p>
              <p class="text-xs text-brand-text/70"><%= account.slackUsername %></p>
            </td>
            <td class="px-3 py-2"><%= account.employee?.fullName %></td>
            <td class="px-3 py-2">
              <form action="/admin/accounts/<%= account.id %>/role" method="POST" class="flex items-center gap-2">
                <select
                  name="roleId"
                  class="rounded-lg border border-brand-secondary px-2 py-1 text-sm"
                >
                  <% roles.forEach((role) => { %>
                    <option value="<%= role.id %>" <%= role.id === account.roleId ? 'selected' : '' %>><%= role.name %></option>
                  <% }) %>
                </select>
                <button type="submit" class="rounded-lg bg-brand-primary px-2 py-1 text-xs font-semibold text-white">Save</button>
              </form>
            </td>
            <td class="px-3 py-2">
              <form action="/admin/accounts/<%= account.id %>/status" method="POST" class="flex items-center gap-2">
                <select
                  name="status"
                  class="rounded-lg border border-brand-secondary px-2 py-1 text-sm"
                >
                  <option value="ACTIVE" <%= account.status === 'ACTIVE' ? 'selected' : '' %>>ACTIVE</option>
                  <option value="DISABLED" <%= account.status === 'DISABLED' ? 'selected' : '' %>>DISABLED</option>
                </select>
                <button type="submit" class="rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold">Update</button>
              </form>
            </td>
            <td class="px-3 py-2 text-xs text-brand-text/70">Time filter placeholder</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
