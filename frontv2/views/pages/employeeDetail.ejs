<%
  const activityByDay = {};
  (employee.activityLog || []).forEach((item) => {
    const dayKey = new Date(item.completedAt || item.createdAt).toISOString().slice(0, 10);
    if (!activityByDay[dayKey]) {
      activityByDay[dayKey] = [];
    }
    activityByDay[dayKey].push(item);
  });
  const activityDays = Object.keys(activityByDay).sort((a, b) => new Date(b) - new Date(a));
%>

<div class="grid gap-6 xl:grid-cols-[2fr_1fr]">
  <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <div class="flex flex-wrap items-center gap-4">
      <img
        src="<%= employee.avatar %>"
        alt="<%= employee.fullName %>"
        class="h-16 w-16 rounded-full border border-brand-secondary object-cover"
      />
      <div class="flex-1">
        <h1 class="font-heading text-3xl font-bold text-brand-text"><%= employee.fullName %></h1>
        <p class="text-sm text-brand-text/70"><%= employee.title %> - <%= employee.timezone %></p>
      </div>
      <% if (isOwnProfile) { %>
        <span class="rounded-full bg-brand-primary/10 px-3 py-1 text-xs font-semibold text-brand-primary">Own Profile</span>
      <% } %>
    </div>
    <p class="mt-4 text-sm leading-6 text-brand-text/80"><%= employee.bio %></p>
    <p class="mt-4 inline-flex rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
      Employee Information
    </p>
  </section>

  <section class="space-y-4">
    <div class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
      <div class="flex items-start justify-between gap-4">
        <p class="font-heading text-lg font-bold leading-6 text-brand-text"><%= currentDateLabel %></p>
        <span class="rounded-lg border border-brand-secondary px-3 py-2 text-sm font-bold text-brand-text">
          <%= quickReport.quarterLabel %>
        </span>
      </div>
    </div>

    <form action="/reports/generate" method="POST" class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
      <input type="hidden" name="contentType" value="<%= quickReport.contentType %>" />
      <input type="hidden" name="subjectId" value="<%= quickReport.subjectId %>" />
      <input type="hidden" name="periodStart" value="<%= quickReport.periodStart %>" />
      <input type="hidden" name="periodEnd" value="<%= quickReport.periodEnd %>" />
      <input type="hidden" name="redirectTo" value="/employees/<%= employee.id %>" />
      <button
        type="submit"
        class="w-full rounded-xl border border-brand-primary bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
      >
        Generate Report
      </button>
    </form>
  </section>
</div>

<div class="mt-6 grid gap-6 xl:grid-cols-[2fr_1fr]">
  <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h2 class="font-heading text-2xl font-bold text-brand-text">Your Activity</h2>
      <div class="flex flex-wrap gap-2">
        <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">Today</button>
        <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">3 days</button>
        <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">5 days</button>
        <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">Start Date</button>
        <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">End Date</button>
      </div>
    </div>

    <button
      type="button"
      class="mt-4 inline-flex rounded-xl border border-brand-secondary bg-brand-bg px-4 py-2 text-sm font-semibold text-brand-text transition hover:bg-brand-secondary/30"
    >
      Add Daily Entry
    </button>

    <div class="mt-5 space-y-4">
      <% if (!activityDays.length) { %>
        <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
          No activity yet.
        </p>
      <% } %>

      <% activityDays.forEach((day) => { %>
        <p class="inline-flex rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
          <%= new Date(day).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" }) %>
        </p>
        <% activityByDay[day].forEach((item) => { %>
          <article class="rounded-xl border border-brand-secondary/70 p-4">
            <div class="flex items-start gap-3">
              <div class="mt-1 h-5 w-5 rounded-full border border-brand-secondary"></div>
              <div class="flex-1">
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <h3 class="font-heading text-base font-bold text-brand-text"><%= item.title %></h3>
                  <span class="text-xs text-brand-text/60">
                    <%= new Date(item.completedAt || item.createdAt).toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" }) %>
                  </span>
                </div>
                <p class="mt-2 text-sm text-brand-text/80"><%= item.description || item.content %></p>
              </div>
            </div>
          </article>
        <% }) %>
      <% }) %>
    </div>
  </section>

  <section class="space-y-6">
    <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
      <h2 class="font-heading text-2xl font-bold text-brand-text">Your Teams</h2>
      <div class="mt-4 space-y-3">
        <% if (!employee.teamObjects.length) { %>
          <p class="text-sm text-brand-text/70">No teams assigned.</p>
        <% } %>
        <% employee.teamObjects.forEach((team) => { %>
          <% const teamMembership = (team.members || []).find((member) => member.employeeId === employee.id); %>
          <a href="/teams/<%= team.id %>" class="flex items-center gap-3 rounded-xl border border-brand-secondary p-3 transition hover:bg-brand-bg">
            <div class="h-8 w-8 rounded-full border border-brand-secondary bg-brand-bg"></div>
            <div class="flex-1">
              <p class="text-sm font-semibold text-brand-text"><%= team.name %> - <%= teamMembership?.role || "Member" %></p>
              <p class="text-xs text-brand-text/60">
                <%= teamMembership?.startDate ? new Date(teamMembership.startDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) : "Date unavailable" %>
              </p>
            </div>
          </a>
        <% }) %>
      </div>
    </article>

    <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
      <h2 class="font-heading text-2xl font-bold text-brand-text">Your Projects</h2>
      <div class="mt-4 space-y-3">
        <% if (!employee.projectObjects.length) { %>
          <p class="text-sm text-brand-text/70">No projects assigned.</p>
        <% } %>
        <% employee.projectObjects.forEach((project) => { %>
          <a href="/projects/<%= project.id %>" class="flex items-center gap-3 rounded-xl border border-brand-secondary p-3 transition hover:bg-brand-bg">
            <div class="h-8 w-8 rounded-full border border-brand-secondary bg-brand-bg"></div>
            <div class="flex-1">
              <p class="text-sm font-semibold text-brand-text"><%= project.name %> - Participant</p>
              <p class="text-xs text-brand-text/60">
                <%= project.startDate ? new Date(project.startDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) : "Date unavailable" %>
              </p>
            </div>
          </a>
        <% }) %>
      </div>
    </article>

    <a
      href="/employees"
      class="inline-flex rounded-xl border border-brand-secondary px-3 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30"
    >
      Back to employees
    </a>
  </section>
</div>
