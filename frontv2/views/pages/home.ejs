<%- include("../partials/pageHeader", { title: `Welcome, ${employee.fullName}`, subtitle: pageSubtitle }) %>

<div class="grid gap-6 xl:grid-cols-2">
  <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <h2 class="font-heading text-xl font-bold">Latest Activity</h2>
    <p class="mb-4 text-sm text-brand-text/70">Activities from your latest daily entries.</p>
    <%- include("../partials/activityList", { items: latestActivity }) %>
  </section>

  <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <h2 class="font-heading text-xl font-bold">Team Activity</h2>
    <p class="mb-4 text-sm text-brand-text/70">Most recent team member activities.</p>
    <%- include("../partials/activityList", { items: teamActivity }) %>
  </section>
</div>

<section class="mt-6 rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <h2 class="font-heading text-xl font-bold">Your Projects</h2>
  <p class="mb-4 text-sm text-brand-text/70">Project highlights and achievements from latest updates.</p>
  <div class="space-y-3">
    <% projectPanels.forEach((project) => { %>
      <details class="rounded-xl border border-brand-secondary/70 bg-brand-bg p-4">
        <summary class="cursor-pointer list-none">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <h3 class="font-heading font-bold"><%= project.name %></h3>
            <span class="rounded-full bg-brand-primary/10 px-3 py-1 text-xs font-semibold text-brand-primary">
              <%= project.status %>
            </span>
          </div>
        </summary>

        <div class="mt-4 grid gap-4 md:grid-cols-2">
          <article>
            <h4 class="font-heading text-sm font-bold uppercase tracking-wide text-brand-text/70">Project Highlights</h4>
            <div class="mt-2 space-y-2">
              <% project.highlights.forEach((highlight) => { %>
                <div class="rounded-lg border border-brand-secondary bg-white p-3 text-sm">
                  <p class="font-semibold"><%= highlight.title %></p>
                  <p class="mt-1 text-brand-text/80"><%= highlight.content %></p>
                </div>
              <% }) %>
            </div>
          </article>
          <article>
            <h4 class="font-heading text-sm font-bold uppercase tracking-wide text-brand-text/70">Project Achievements</h4>
            <div class="mt-2 space-y-2">
              <% project.achievements.forEach((achievement) => { %>
                <div class="rounded-lg border border-brand-secondary bg-white p-3 text-sm">
                  <p class="font-semibold"><%= achievement.title %></p>
                  <p class="mt-1 text-brand-text/80"><%= achievement.description %></p>
                </div>
              <% }) %>
            </div>
          </article>
        </div>
      </details>
    <% }) %>
  </div>
</section>
