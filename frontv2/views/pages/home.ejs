<%
  const latestByDay = {};
  (latestActivity || []).forEach((item) => {
    const dayKey = new Date(item.completedAt || item.createdAt).toISOString().slice(0, 10);
    if (!latestByDay[dayKey]) {
      latestByDay[dayKey] = [];
    }
    latestByDay[dayKey].push(item);
  });
  const latestDays = Object.keys(latestByDay).sort((a, b) => new Date(b) - new Date(a));

  const teamByDay = {};
  (teamActivity || []).forEach((item) => {
    const dayKey = new Date(item.completedAt || item.createdAt).toISOString().slice(0, 10);
    if (!teamByDay[dayKey]) {
      teamByDay[dayKey] = [];
    }
    teamByDay[dayKey].push(item);
  });
  const teamDays = Object.keys(teamByDay).sort((a, b) => new Date(b) - new Date(a));

  const primaryProject = (projectPanels || [])[0] || null;
%>

<div class="space-y-6">
  <div class="grid gap-6 xl:grid-cols-[2fr_1fr]">
    <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
      <div class="flex items-center gap-4">
        <div class="h-12 w-12 rounded-full border border-brand-secondary bg-brand-bg"></div>
        <h1 class="font-heading text-4xl font-bold text-brand-text">Welcome, <%= employee.fullName.split(" ")[0] %></h1>
      </div>
    </section>

    <section class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
      <div class="flex items-start justify-between gap-4">
        <p class="font-heading text-lg font-bold leading-6 text-brand-text"><%= currentDateLabel %></p>
        <span class="rounded-lg border border-brand-secondary px-3 py-2 text-sm font-bold text-brand-text">
          <%= currentQuarterLabel %>
        </span>
      </div>
    </section>
  </div>

  <div class="grid gap-6 xl:grid-cols-[2fr_1fr]">
    <section class="space-y-6">
      <article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
        <h2 class="font-heading text-3xl font-bold text-brand-text">Your Latest Activity</h2>

        <button
          type="button"
          class="mt-4 inline-flex rounded-xl border border-brand-secondary bg-brand-bg px-4 py-2 text-sm font-semibold text-brand-text transition hover:bg-brand-secondary/30"
        >
          Add Daily Entry
        </button>

        <div class="mt-4 space-y-4">
          <% if (!latestDays.length) { %>
            <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
              No recent activity.
            </p>
          <% } %>

          <% latestDays.forEach((day) => { %>
            <p class="inline-flex rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
              <%= new Date(day).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" }) %>
            </p>
            <% latestByDay[day].forEach((item) => { %>
              <article class="rounded-xl border border-brand-secondary/70 p-4">
                <div class="flex items-start gap-3">
                  <div class="mt-1 h-5 w-5 rounded-full border border-brand-secondary"></div>
                  <div class="flex-1">
                    <h3 class="font-heading text-base font-bold text-brand-text"><%= item.title %></h3>
                    <p class="mt-2 text-sm text-brand-text/80"><%= item.description || item.content %></p>
                  </div>
                </div>
              </article>
            <% }) %>
          <% }) %>
        </div>
      </article>

      <article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="font-heading text-3xl font-bold text-brand-text">Team Activity</h2>
          <div class="flex flex-wrap gap-2">
            <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">Today</button>
            <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">3 days</button>
            <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">5 days</button>
            <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">Start Date</button>
            <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">End Date</button>
          </div>
        </div>

        <div class="mt-4 space-y-4">
          <% if (!teamDays.length) { %>
            <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
              No team activity available.
            </p>
          <% } %>

          <% teamDays.forEach((day) => { %>
            <p class="inline-flex rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
              <%= new Date(day).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" }) %>
            </p>
            <% teamByDay[day].forEach((item) => { %>
              <article class="rounded-xl border border-brand-secondary/70 p-4">
                <div class="flex items-start gap-3">
                  <div class="mt-1 h-5 w-5 rounded-full border border-brand-secondary"></div>
                  <div class="flex-1">
                    <h3 class="font-heading text-base font-bold text-brand-text"><%= item.title %></h3>
                    <p class="mt-2 text-sm text-brand-text/80"><%= item.description || item.content %></p>
                  </div>
                </div>
              </article>
            <% }) %>
          <% }) %>
        </div>
      </article>
    </section>

    <section class="space-y-6">
      <details open class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
        <summary class="cursor-pointer list-none font-heading text-2xl font-bold text-brand-text">
          Your Projects
        </summary>
        <div class="mt-4 space-y-3">
          <% if (!(projectPanels || []).length) { %>
            <p class="text-sm text-brand-text/70">No projects assigned.</p>
          <% } %>
          <% (projectPanels || []).forEach((project) => { %>
            <a href="/projects/<%= project.id %>" class="flex items-center gap-3 rounded-xl border border-brand-secondary p-3 transition hover:bg-brand-bg">
              <div class="h-8 w-8 rounded-full border border-brand-secondary bg-brand-bg"></div>
              <div class="flex-1">
                <p class="text-sm font-semibold text-brand-text"><%= project.name %> - <%= project.status %></p>
                <p class="text-xs text-brand-text/60">
                  <%= project.startDate ? new Date(project.startDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) : "Date unavailable" %>
                </p>
              </div>
            </a>
          <% }) %>
        </div>
      </details>

      <details open class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
        <summary class="cursor-pointer list-none font-heading text-2xl font-bold text-brand-text">
          Project Highlights
        </summary>
        <div class="mt-4 space-y-3">
          <% if (!primaryProject || !primaryProject.highlights.length) { %>
            <p class="text-sm text-brand-text/70">No highlights available.</p>
          <% } %>
          <% (primaryProject?.highlights || []).forEach((highlight) => { %>
            <div class="rounded-xl border border-brand-secondary p-3">
              <p class="text-sm font-semibold text-brand-text"><%= highlight.title %></p>
              <p class="mt-1 text-sm text-brand-text/80"><%= highlight.content %></p>
            </div>
          <% }) %>
        </div>
      </details>

      <details open class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
        <summary class="cursor-pointer list-none font-heading text-2xl font-bold text-brand-text">
          Project Achievements
        </summary>
        <div class="mt-4 space-y-3">
          <% if (!primaryProject || !primaryProject.achievements.length) { %>
            <p class="text-sm text-brand-text/70">No achievements available.</p>
          <% } %>
          <% (primaryProject?.achievements || []).forEach((achievement) => { %>
            <div class="rounded-xl border border-brand-secondary p-3">
              <span class="inline-flex rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold text-brand-text/70">
                <%= achievement.achievementDate ? new Date(achievement.achievementDate).toLocaleDateString("en-US", { day: "2-digit", month: "short" }) : "N/A" %>
              </span>
              <p class="mt-2 text-sm font-semibold text-brand-text"><%= achievement.title %></p>
              <p class="mt-1 text-sm text-brand-text/80"><%= achievement.description %></p>
            </div>
          <% }) %>
        </div>
      </details>
    </section>
  </div>
</div>
