<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<section class="max-w-3xl rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <h2 class="font-heading text-xl font-bold">Account Information</h2>
  <form action="/account" method="POST" class="mt-4 grid gap-4 sm:grid-cols-2">
    <label class="block text-sm sm:col-span-2">
      <span class="mb-1 block text-brand-text/70">Email</span>
      <input
        type="email"
        name="email"
        value="<%= account.email %>"
        required
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
    </label>

    <label class="block text-sm">
      <span class="mb-1 block text-brand-text/70">Slack username</span>
      <input
        type="text"
        name="slackUsername"
        value="<%= account.slackUsername %>"
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
    </label>

    <label class="block text-sm">
      <span class="mb-1 block text-brand-text/70">Image URL</span>
      <input
        type="url"
        name="image"
        value="<%= account.image %>"
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
    </label>

    <label class="block text-sm sm:col-span-2">
      <span class="mb-1 block text-brand-text/70">New password (optional)</span>
      <input
        type="password"
        name="password"
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
    </label>

    <div class="sm:col-span-2">
      <button
        type="submit"
        class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
      >
        Save
      </button>
    </div>
  </form>
</section>
