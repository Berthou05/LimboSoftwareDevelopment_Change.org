<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<section class="max-w-3xl rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <h2 class="font-heading text-xl font-bold">Account Information</h2>
  <form action="/account" method="POST" class="mt-4 grid gap-4 sm:grid-cols-2">
    <label class="block text-sm sm:col-span-2">
      <span class="mb-1 block text-brand-text/70">Email</span>
      <input
        type="email"
        name="email"
        value="<%= account.email %>"
        required
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
    </label>

    <label class="block text-sm">
      <span class="mb-1 block text-brand-text/70">Slack username</span>
      <input
        type="text"
        name="slackUsername"
        value="<%= account.slackUsername %>"
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
    </label>

    <label class="block text-sm">
      <span class="mb-1 block text-brand-text/70">Profile Image</span>
      <input
        id="accountImageFile"
        type="file"
        accept="image/*"
        class="w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
      />
      <input id="accountImageValue" type="hidden" name="image" value="<%= account.image %>" />
      <p id="accountImageFilename" class="mt-1 text-xs text-brand-text/65">No file selected</p>
    </label>

    <div class="flex items-center justify-center rounded-xl border border-brand-secondary bg-brand-bg p-3">
      <img
        id="accountImagePreview"
        src="<%= account.image %>"
        alt="Account preview"
        class="h-20 w-20 rounded-full border border-brand-secondary object-cover"
      />
    </div>

    <div class="rounded-xl border border-brand-secondary bg-brand-bg p-4 text-sm sm:col-span-2">
      <p class="font-semibold text-brand-text">Password</p>
      <p class="mt-1 text-brand-text/70">
        Password changes are not available in this screen.
      </p>
      <a
        href="/recover"
        class="mt-3 inline-flex rounded-xl border border-brand-primary px-3 py-2 text-xs font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white"
      >
        Request Password Change
      </a>
    </div>

    <div class="sm:col-span-2">
      <button
        type="submit"
        class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
      >
        Save
      </button>
    </div>
  </form>
</section>
