<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head", { title }) %>
  <body class="min-h-screen bg-brand-bg text-brand-text">
    <% if (isAuthPage) { %>
      <main class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 py-10">
        <div class="pointer-events-none absolute -top-24 left-0 h-96 w-96 rounded-full bg-brand-primary/20 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-16 right-0 h-80 w-80 rounded-full bg-brand-accent/20 blur-3xl"></div>
        <section class="relative z-10 w-full max-w-lg rounded-3xl border border-brand-secondary/60 bg-white/90 p-8 shadow-xl backdrop-blur">
          <%- include("partials/flash", { flash }) %>
          <%- body %>
        </section>
      </main>
    <% } else { %>
      <div class="flex min-h-screen">
        <%- include("partials/sidebar", { navItems, activeRoute, currentUser }) %>
        <main class="min-h-screen flex-1">
          <%- include("partials/topbar", { currentUser, todayLabel }) %>
          <section class="px-6 pb-10 pt-6 sm:px-8 lg:px-10">
            <%- include("partials/flash", { flash }) %>
            <%- body %>
          </section>
        </main>
      </div>
    <% } %>

    <script src="/js/main.js"></script>
  </body>
</html>
