<aside class="hidden w-72 flex-col border-r border-brand-secondary/60 bg-white/90 px-4 py-6 lg:flex">
  <div class="px-3">
    <p class="font-heading text-2xl font-extrabold text-brand-primary">Unitas</p>
    <p class="mt-1 text-sm text-brand-text/70">System Prototype</p>
  </div>

  <nav class="mt-8 space-y-1">
    <% navItems.forEach((item) => { const active = activeRoute === item.href || (item.href !== "/home" &&
      activeRoute.startsWith(item.href)); %>
      <a
        href="<%= item.href %>"
        class="block rounded-xl px-3 py-2 text-sm font-medium transition <%= active ? 'bg-brand-primary text-white shadow-md' : 'text-brand-text/80 hover:bg-brand-secondary/30' %>"
      >
        <%= item.label %>
      </a>
    <% }); %>
  </nav>

  <div class="mt-auto rounded-2xl border border-brand-secondary/60 bg-brand-bg p-3">
    <p class="text-xs uppercase tracking-wider text-brand-text/60">Signed in</p>
    <p class="mt-1 font-heading text-sm font-semibold"><%= currentUser?.name || "User" %></p>
    <p class="text-xs text-brand-text/70"><%= currentUser?.roleName || "Employee" %></p>
    <form action="/logout" method="POST" class="mt-3">
      <button
        type="submit"
        class="w-full rounded-xl border border-brand-accent px-3 py-2 text-sm font-semibold text-brand-accent transition hover:bg-brand-accent hover:text-white"
      >
        Sign out
      </button>
    </form>
  </div>
</aside>
