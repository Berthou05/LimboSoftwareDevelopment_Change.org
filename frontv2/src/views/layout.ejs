<%# Template: layout.ejs
   Purpose: Global shell for all pages (auth and app layout).
   Expected locals: isAuthPage, navItems, activeRoute, currentUser, todayLabel, flash, title, body.
   Data flow: module controllers provide page locals, then this layout wraps them with global UI.
%>

<!DOCTYPE html>
<html lang="en">
  <%
    // Defensive defaults prevent rendering crashes while new pages/controllers are being built.
    const pageIsAuth = typeof isAuthPage !== "undefined" ? isAuthPage : false;
    const layoutNavItems = typeof navItems !== "undefined" ? navItems : [];
    const layoutActiveRoute = typeof activeRoute !== "undefined" ? activeRoute : "";
    const layoutCurrentUser = typeof currentUser !== "undefined" ? currentUser : null;
    const layoutTodayLabel = typeof todayLabel !== "undefined" ? todayLabel : "";
    const layoutFlash = typeof flash !== "undefined" ? flash : null;
    const pageTitle = typeof title !== "undefined" ? title : "Unitas";
  %>
  <%- include("partials/head", { title: pageTitle }) %>
  <body class="min-h-screen bg-brand-bg text-brand-text">
    <% if (pageIsAuth) { %>
      <%# Auth pages intentionally avoid sidebar/topbar to keep login/recover/reset focused. %>
      <main class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 py-10">
        <div class="pointer-events-none absolute -top-24 left-0 h-96 w-96 rounded-full bg-brand-primary/20 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-16 right-0 h-80 w-80 rounded-full bg-brand-accent/20 blur-3xl"></div>
        <section class="relative z-10 w-full max-w-lg rounded-3xl border border-brand-secondary/60 bg-white/90 p-8 shadow-xl backdrop-blur">
          <%- include("partials/flash", { flash: layoutFlash }) %>
          <%- body %>
        </section>
      </main>
    <% } else { %>
      
      <%# App pages render persistent navigation and insert the module page in `body`. %>

      <div class="flex min-h-screen">
        <%- include("partials/sidebar", { navItems: layoutNavItems, activeRoute: layoutActiveRoute, currentUser: layoutCurrentUser }) %>
        <main class="min-h-screen flex-1 min-w-0 w-full">
          <%- include("partials/topbar", { currentUser: layoutCurrentUser, todayLabel: layoutTodayLabel }) %>
          <section class="w-full max-w-full px-4 pb-10 pt-6 sm:px-6 lg:px-10">
            <%- include("partials/flash", { flash: layoutFlash }) %>
            <%- body %>
          </section>
        </main>
      </div>
    <% } %>

    <%# main.js wires behavior for account menu, reports widgets, and account image preview. %>
    <script src="/js/main.js"></script>
  </body>
</html>
