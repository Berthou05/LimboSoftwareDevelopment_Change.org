<%# Template: pages/teams.ejs
   Purpose: Team directory/list screen.
   Expected locals: pageTitle, pageSubtitle, myTeams, otherTeams, query.
   Data source: teams.controller filters in backend and re-renders with the same `query`.
%>

<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<form action="/teams" method="GET" class="mb-5 flex flex-wrap gap-2">
  <input
    type="text"
    name="q"
    value="<%= query %>"
    placeholder="Search teams..."
    class="w-full max-w-md rounded-xl border border-brand-secondary px-3 py-2 text-sm outline-none ring-brand-primary/30 focus:ring"
  />
  <button
    type="submit"
    class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
  >
    Search
  </button>
</form>

<%# My Teams section %>
<% if (myTeams.length) { %>
  <h2 class="mb-3 font-heading text-xl font-bold text-brand-text">My Teams</h2>
  <div class="grid gap-4 lg:grid-cols-2 mb-8">
    <% myTeams.forEach((team) => { %>
      <article class="rounded-2xl border-2 border-brand-primary/30 bg-white p-4 shadow-panel">
        <div class="flex items-center gap-3">
          <img src="<%= team.image %>" alt="<%= team.name %>" class="h-14 w-14 rounded-xl object-cover" />
          <div>
            <h3 class="font-heading text-lg font-bold"><%= team.name %></h3>
            <p class="text-sm text-brand-text/70">Lead: <%= team.lead?.fullName %></p>
          </div>
        </div>
        <p class="mt-3 text-sm text-brand-text/80"><%= team.description %></p>
        <a
          href="/teams/<%= team.id %>"
          class="mt-4 inline-flex rounded-xl border border-brand-primary px-3 py-2 text-sm font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white"
        >
          Open team
        </a>
      </article>
    <% }) %>
  </div>
<% } %>

<%# Other Teams section %>
<% if (otherTeams.length) { %>
  <h2 class="mb-3 font-heading text-xl font-bold text-brand-text/70">Other Teams</h2>
  <div class="grid gap-4 lg:grid-cols-2">
    <% otherTeams.forEach((team) => { %>
      <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
        <div class="flex items-center gap-3">
          <img src="<%= team.image %>" alt="<%= team.name %>" class="h-14 w-14 rounded-xl object-cover" />
          <div>
            <h3 class="font-heading text-lg font-bold"><%= team.name %></h3>
            <p class="text-sm text-brand-text/70">Lead: <%= team.lead?.fullName %></p>
          </div>
        </div>
        <p class="mt-3 text-sm text-brand-text/80"><%= team.description %></p>
        <a
          href="/teams/<%= team.id %>"
          class="mt-4 inline-flex rounded-xl border border-brand-primary px-3 py-2 text-sm font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white"
        >
          Open team
        </a>
      </article>
    <% }) %>
  </div>
<% } %>

<% if (!myTeams.length && !otherTeams.length) { %>
  <p class="text-sm text-brand-text/60">No teams found.</p>
<% } %>



