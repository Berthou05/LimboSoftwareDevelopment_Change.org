<%# Template: pages/reports.ejs
   Purpose: Report listing and report generation workspace.
   Expected locals: reports, reportSubjects, defaultReportType, defaultSubjectId, quickReport, currentDateLabel.
   Data source: reports.controller provides report list + subject catalog inputs.
   Client behavior: main.js upgrades this form with search suggestions and date-range calendar.
%>

<%
  // Convert split subject arrays into a catalog keyed by content type for client-side search.
  const subjectCatalog = {
    EMPLOYEE: reportSubjects.employees || [],
    TEAM: reportSubjects.teams || [],
    PROJECT: reportSubjects.projects || [],
  };
  const typeLabel = {
    EMPLOYEE: "Employee",
    TEAM: "Team",
    PROJECT: "Project",
  };
%>

<div class="space-y-6">
  <div class="grid gap-6 xl:grid-cols-[2fr_1fr]">
    <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
      <h1 class="font-heading text-4xl font-bold text-brand-text">Reports</h1>
    </section>

    <section class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
      <div class="flex items-start justify-between gap-4">
        <p class="font-heading text-lg font-bold leading-6 text-brand-text"><%= currentDateLabel %></p>
        <span id="reportsQuarterBadge" class="rounded-lg border border-brand-secondary px-3 py-2 text-sm font-bold text-brand-text">
          <%= quickReport.quarterLabel %>
        </span>
      </div>
    </section>
  </div>

  <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <p class="text-xs font-semibold uppercase tracking-wide text-brand-text/60">Report Generator</p>

    <%# `data-report-generator="enhanced"` enables rich JS behavior in main.js (search + calendar). %>
    <form action="/reports/generate" method="POST" class="mt-4 grid gap-4 lg:grid-cols-[1fr_1.4fr_1.4fr_auto]" data-report-generator="enhanced" data-current-year="<%= new Date(quickReport.periodStart).getFullYear() %>">
      <input type="hidden" name="redirectTo" value="/reports" />

      <label class="block text-sm">
        <span class="mb-2 block font-semibold text-brand-text/70">Select content type:</span>
        <select
          id="reportContentType"
          name="contentType"
          class="report-type w-full rounded-xl border border-brand-secondary px-3 py-2 outline-none ring-brand-primary/30 focus:ring"
          data-default="<%= defaultReportType || 'PROJECT' %>"
        >
          <option value="EMPLOYEE">Employee</option>
          <option value="TEAM">Team</option>
          <option value="PROJECT">Project</option>
        </select>
      </label>

      <label class="relative block text-sm">
        <span class="mb-2 block font-semibold text-brand-text/70">Search specific content:</span>
        <div class="flex items-center rounded-xl border border-brand-secondary bg-white px-3">
          <svg class="h-4 w-4 text-brand-text/60" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.5"></circle>
            <path d="M13.5 13.5L18 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
          </svg>
          <input
            id="reportSubjectSearch"
            type="search"
            placeholder="Search employee, team, or project..."
            class="w-full border-none bg-transparent px-2 py-2 outline-none"
            autocomplete="off"
          />
          <%# Hidden subjectId stores the canonical entity ID; text input is only for user-friendly search. %>
          <input id="reportSubjectId" type="hidden" name="subjectId" value="" required />
        </div>
        <div id="reportSubjectResults" class="absolute z-30 mt-1 hidden w-full rounded-xl border border-brand-secondary bg-white p-1 shadow-panel"></div>
      </label>

      <div class="relative block text-sm">
        <span class="mb-2 block font-semibold text-brand-text/70">Date Range</span>
        <div data-date-trigger class="grid cursor-pointer gap-2 sm:grid-cols-2">
          <div class="rounded-xl border border-brand-secondary bg-white px-3 py-2">
            <p class="text-xs font-semibold text-brand-text/60">Start Date</p>
            <input data-start-display type="text" readonly class="mt-1 w-full bg-transparent text-sm font-semibold outline-none" value="" />
          </div>
          <div class="rounded-xl border border-brand-secondary bg-white px-3 py-2">
            <p class="text-xs font-semibold text-brand-text/60">End Date</p>
            <input data-end-display type="text" readonly class="mt-1 w-full bg-transparent text-sm font-semibold outline-none" value="" />
          </div>
        </div>

        <%# Hidden date values are submitted to backend; visible fields are read-only presentation. %>
        <input data-start-value type="hidden" name="periodStart" value="<%= quickReport.periodStart %>" required />
        <input data-end-value type="hidden" name="periodEnd" value="<%= quickReport.periodEnd %>" required />

        <div data-date-popover class="absolute right-0 z-40 mt-2 hidden w-[min(44rem,95vw)] rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
          <div class="flex items-center justify-between gap-2">
            <button type="button" data-calendar-nav="prev" class="rounded-lg border border-brand-secondary px-2 py-1 text-sm font-bold text-brand-text/70 transition hover:bg-brand-secondary/20">
              &lt;
            </button>
            <div class="grid flex-1 grid-cols-2 gap-2 text-center">
              <p data-calendar-label="left" class="font-heading text-sm font-bold text-brand-text"></p>
              <p data-calendar-label="right" class="font-heading text-sm font-bold text-brand-text"></p>
            </div>
            <button type="button" data-calendar-nav="next" class="rounded-lg border border-brand-secondary px-2 py-1 text-sm font-bold text-brand-text/70 transition hover:bg-brand-secondary/20">
              &gt;
            </button>
          </div>

          <div class="mt-3 grid gap-3 md:grid-cols-2">
            <div data-calendar-month="left" class="rounded-xl border border-brand-secondary p-2"></div>
            <div data-calendar-month="right" class="rounded-xl border border-brand-secondary p-2"></div>
          </div>

          <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-brand-secondary pt-3">
            <div class="flex gap-2">
              <button type="button" data-quarter="1" class="rounded-lg border border-brand-secondary px-3 py-1 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20">Q1</button>
              <button type="button" data-quarter="2" class="rounded-lg border border-brand-secondary px-3 py-1 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20">Q2</button>
              <button type="button" data-quarter="3" class="rounded-lg border border-brand-secondary px-3 py-1 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20">Q3</button>
              <button type="button" data-quarter="4" class="rounded-lg border border-brand-secondary px-3 py-1 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/20">Q4</button>
            </div>
            <button type="button" data-date-apply class="rounded-xl border border-brand-primary bg-brand-primary px-4 py-1.5 text-sm font-semibold text-white transition hover:bg-brand-accent">
              Apply
            </button>
          </div>
        </div>
      </div>

      <button
        type="submit"
        class="self-end rounded-xl border border-brand-primary bg-brand-primary px-5 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
      >
        Generate Report
      </button>
    </form>
  </section>

  <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h2 class="font-heading text-xl font-bold text-brand-text"><%= reports.length %> results found</h2>
      <a href="/reports" class="rounded-xl border border-brand-secondary px-3 py-1.5 text-sm font-semibold text-brand-text/70 transition hover:bg-brand-secondary/30">
        Refresh
      </a>
    </div>

    <div class="mt-4 space-y-3">
      <% if (!reports.length) { %>
        <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
          No reports generated yet.
        </p>
      <% } %>

      <% reports.forEach((report) => { %>
        <article class="rounded-xl border border-brand-secondary p-3">
          <div class="flex flex-wrap items-center gap-3">
            <p class="min-w-[130px] font-heading text-base font-bold text-brand-text">Report <%= report.id.toUpperCase() %></p>
            <p class="text-sm font-semibold text-brand-text/70">Content type:</p>
            <span class="rounded-lg border border-brand-secondary px-3 py-1 text-xs font-semibold">
              <%= typeLabel[report.contentType] || report.contentType %>
            </span>
            <span class="rounded-lg border border-brand-secondary px-3 py-1 text-xs font-semibold"><%= report.subjectLabel %></span>
            <p class="text-sm font-semibold text-brand-text/70">Date Range:</p>
            <span class="rounded-lg border border-brand-secondary px-3 py-1 text-xs font-semibold">
              <%= new Date(report.periodStart).toLocaleDateString("en-US", { day: "2-digit", month: "short" }) %>
            </span>
            <span class="rounded-lg border border-brand-secondary px-3 py-1 text-xs font-semibold">
              <%= new Date(report.periodEnd).toLocaleDateString("en-US", { day: "2-digit", month: "short" }) %>
            </span>
            <a
              href="<%= report.fileUrl %>"
              class="ml-auto inline-flex h-10 w-10 items-center justify-center rounded-xl border border-brand-primary text-brand-primary transition hover:bg-brand-primary hover:text-white"
              aria-label="Download report"
            >
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none">
                <path d="M10 3V12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
                <path d="M6.5 9.5L10 13L13.5 9.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M4 16H16" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
              </svg>
            </a>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
</div>

<%# JSON payload consumed by initEnhancedReportsSubjectSearch(); keeps search logic in one JS source. %>
<script id="report-subject-catalog" type="application/json"><%- JSON.stringify(subjectCatalog) %></script>



