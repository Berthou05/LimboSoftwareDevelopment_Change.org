<%# Template: pages/employees.ejs
   Purpose: Employee directory/list screen.
   Expected locals: pageTitle, pageSubtitle, employees, query.
   Data source: employees.controller filters in backend and re-renders with the same `query`.
%>

<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<form action="/employees" method="GET" class="mb-5 flex flex-wrap gap-2">
  <input
    type="text"
    name="q"
    value="<%= query %>"
    placeholder="Search employees..."
    class="w-full max-w-md rounded-xl border border-brand-secondary px-3 py-2 text-sm outline-none ring-brand-primary/30 focus:ring"
  />
  <button
    type="submit"
    class="rounded-xl bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-accent"
  >
    Search
  </button>
</form>

<%# Card loop: each entry links to /employees/:id where detailed context is built. %>
<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
  <% employees.forEach((employee) => { %>
    <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
      <div class="flex items-center gap-3">
        <img src="<%= employee.avatar %>" alt="<%= employee.fullName %>" class="h-12 w-12 rounded-full border border-brand-secondary object-cover" />
        <div>
          <h3 class="font-heading text-lg font-bold"><%= employee.fullName %></h3>
          <p class="text-sm text-brand-text/70"><%= employee.title %></p>
        </div>
      </div>
      <p class="mt-3 text-sm text-brand-text/80"><%= employee.bio %></p>
      <a
        href="/employees/<%= employee.id %>"
        class="mt-4 inline-flex rounded-xl border border-brand-primary px-3 py-2 text-sm font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white"
      >
        Open profile
      </a>
    </article>
  <% }) %>
</div>



