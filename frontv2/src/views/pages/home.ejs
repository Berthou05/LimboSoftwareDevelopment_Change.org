<%# Template: pages/home.ejs
    Purpose: Home dashboard for the signed-in user.
    Expected locals: employee, latestActivitySections, teamActivitySections, projectPanels,
        primaryProject.
    Data source: home.controller prepares grouped activity sections so this view only renders UI.
%>

<div class="grid gap-4 sm:gap-6 lg:grid-cols-[2fr_1fr]">
    <section class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel sm:p-5 lg:col-span-2">
        <div class="flex items-center gap-3 sm:gap-4">
            <div class="h-10 w-10 shrink-0 rounded-full border border-brand-secondary bg-brand-bg sm:h-12 sm:w-12"></div>
            <h1 class="font-heading text-xl font-bold text-brand-text sm:text-2xl lg:text-4xl">
                Welcome, <%= employee.fullName.split(' ')[0] %>
            </h1>
        </div>
    </section>

    <section class="space-y-4 sm:space-y-6">
            <%# Report generator section for quick report access from home - full layout with type selector and search. %>
            <%- include('../partials/reportGenerator', { redirectTo: '/home', defaultReportType, defaultSubjectId, reportSubjects, latestReports, quickReport, layout: 'full' }) %>

            <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel sm:p-5">
                <h2 class="font-heading text-xl font-bold text-brand-text sm:text-2xl lg:text-3xl">Your Latest Activity</h2>

                <button
                    type="button"
                    class="mt-4 inline-flex rounded-xl border border-brand-secondary bg-brand-bg px-4 py-2 text-sm font-semibold text-brand-text transition hover:bg-brand-secondary/30"
                >
                    Add Daily Entry
                </button>

                <div class="mt-4 space-y-4">
                    <% if (!(latestActivitySections || []).length) { %>
                        <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
                            No recent activity.
                        </p>
                    <% } %>

                    <%# Sections are already grouped and sorted in controller. %>
                    <% (latestActivitySections || []).forEach((section) => { %>
                        <p class="inline-flex rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
                            <%= section.dayLabel %>
                        </p>
                        <% section.items.forEach((item) => { %>
                            <article class="rounded-xl border border-brand-secondary/70 p-4">
                                <div class="flex items-start gap-3">
                                    <div class="mt-1 h-5 w-5 rounded-full border border-brand-secondary"></div>
                                    <div class="flex-1">
                                        <h3 class="font-heading text-base font-bold text-brand-text"><%= item.title %></h3>
                                        <p class="mt-2 text-sm text-brand-text/80"><%= item.description || item.content %></p>
                                    </div>
                                </div>
                            </article>
                        <% }) %>
                    <% }) %>
                </div>
            </article>
        </section>

        <section class="space-y-6">
            <%# Team Activity - contributions style feed %>
            <div class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
                <h2 class="font-heading text-xl font-bold text-brand-text">Team Activity</h2>
                <p class="mt-1 text-xs text-brand-text/50">Recent contributions from your team</p>
                
                <div class="mt-4 max-h-80 overflow-y-auto space-y-1">
                    <% if (!(teamActivitySections || []).length) { %>
                        <p class="py-4 text-center text-sm text-brand-text/50">No team activity yet.</p>
                    <% } %>
                    <% (teamActivitySections || []).forEach((section) => { %>
                        <p class="sticky top-0 bg-white py-1 text-[10px] font-semibold uppercase tracking-wider text-brand-text/40"><%= section.dayLabel %></p>
                        <% section.items.forEach((item) => { %>
                            <div class="flex items-start gap-2 rounded-lg px-2 py-2 transition hover:bg-brand-bg/50">
                                <div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-primary/20 text-[9px] font-bold text-brand-primary">
                                    <%= item.authorInitials || '?' %>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-[11px] font-semibold text-brand-text/70"><%= item.authorName || 'Unknown' %></p>
                                    <p class="text-xs text-brand-text truncate"><%= item.title %></p>
                                </div>
                                <span class="shrink-0 text-[10px] text-brand-text/40"><%= item.completedAt ? new Date(item.completedAt).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) : '' %></span>
                            </div>
                        <% }) %>
                    <% }) %>
                </div>
            </div>

            <%# Your Projects with nested highlights and achievements per project %>
            <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
                <h2 class="font-heading text-2xl font-bold text-brand-text">Your Projects</h2>
                <div class="mt-4 space-y-4">
                    <% if (!(projectPanels || []).length) { %>
                        <p class="text-sm text-brand-text/70">No projects assigned.</p>
                    <% } %>
                    <% (projectPanels || []).forEach((project) => { %>
                        <details class="group rounded-xl border border-brand-secondary">
                            <summary class="flex cursor-pointer items-center gap-3 p-3 transition hover:bg-brand-bg/50">
                                <svg class="h-4 w-4 shrink-0 text-brand-text/50 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                </svg>
                                <div class="h-8 w-8 shrink-0 rounded-full border border-brand-secondary bg-brand-bg"></div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-brand-text truncate"><%= project.name %> - <%= project.status %></p>
                                    <p class="text-xs text-brand-text/60">
                                        <%= project.startDate ? new Date(project.startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Date unavailable' %>
                                    </p>
                                </div>
                                <a href="/projects/<%= project.id %>" class="shrink-0 rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold text-brand-text/70 transition hover:bg-brand-secondary/30" onclick="event.stopPropagation();">
                                    View
                                </a>
                            </summary>
                            <%
                                const projectFeedItems = [
                                    ...(project.goals || []).map((goal) => ({
                                        type: 'Goal',
                                        title: goal.title,
                                        body: goal.description,
                                        dateValue: goal.dueDate || null,
                                        dateLabel: goal.dueDate ? new Date(goal.dueDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'No due date',
                                        auxLabel: goal.status || 'UNKNOWN',
                                        icon: 'G',
                                        tone: 'border-amber-200 bg-amber-50 text-amber-700',
                                    })),
                                    ...(project.achievements || []).map((achievement) => ({
                                        type: 'Achievement',
                                        title: achievement.title,
                                        body: achievement.description,
                                        dateValue: achievement.achievementDate || null,
                                        dateLabel: achievement.achievementDate ? new Date(achievement.achievementDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'No date',
                                        auxLabel: 'Delivered',
                                        icon: 'A',
                                        tone: 'border-emerald-200 bg-emerald-50 text-emerald-700',
                                    })),
                                    ...(project.highlights || []).map((highlight) => ({
                                        type: 'Highlight',
                                        title: highlight.title,
                                        body: highlight.content,
                                        dateValue: highlight.createdAt || null,
                                        dateLabel: highlight.createdAt ? new Date(highlight.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'No date',
                                        auxLabel: 'Update',
                                        icon: 'H',
                                        tone: 'border-sky-200 bg-sky-50 text-sky-700',
                                    })),
                                ].sort((leftItem, rightItem) => new Date(rightItem.dateValue || 0) - new Date(leftItem.dateValue || 0));
                            %>

                            <div class="border-t border-brand-secondary p-3">
                                <p class="text-xs text-brand-text/60"><%= project.description || 'No description available.' %></p>

                                <div class="mt-3 flex flex-wrap gap-2">
                                    <span class="rounded-full border border-brand-secondary px-2 py-1 text-[10px] font-semibold text-brand-text/60"><%= (project.goals || []).length %> goals</span>
                                    <span class="rounded-full border border-brand-secondary px-2 py-1 text-[10px] font-semibold text-brand-text/60"><%= (project.achievements || []).length %> achievements</span>
                                    <span class="rounded-full border border-brand-secondary px-2 py-1 text-[10px] font-semibold text-brand-text/60"><%= (project.highlights || []).length %> highlights</span>
                                </div>

                                <div class="mt-4 max-h-80 space-y-2 overflow-y-auto pr-1">
                                    <% if (!projectFeedItems.length) { %>
                                        <p class="rounded-lg border border-dashed border-brand-secondary p-3 text-sm text-brand-text/60">
                                            No goals, achievements, or highlights yet.
                                        </p>
                                    <% } %>

                                    <% projectFeedItems.forEach((item) => { %>
                                        <article class="flex items-start gap-3 rounded-xl border border-brand-secondary/70 bg-white p-3">
                                            <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full border text-[11px] font-bold <%= item.tone %>">
                                                <%= item.icon %>
                                            </div>
                                            <div class="min-w-0 flex-1">
                                                <div class="flex flex-wrap items-center gap-2">
                                                    <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide <%= item.tone %>"><%= item.type %></span>
                                                    <span class="text-[10px] font-semibold uppercase tracking-wide text-brand-text/45"><%= item.auxLabel %></span>
                                                    <span class="ml-auto text-[10px] text-brand-text/45"><%= item.dateLabel %></span>
                                                </div>
                                                <p class="mt-1 text-sm font-semibold text-brand-text"><%= item.title %></p>
                                                <p class="mt-1 text-sm text-brand-text/70"><%= item.body %></p>
                                            </div>
                                        </article>
                                    <% }) %>
                                </div>
                            </div>
                        </details>
                    <% }) %>
                </div>
            </article>
        </section>
    </div>
