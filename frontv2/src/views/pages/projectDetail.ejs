<%# Template: pages/projectDetail.ejs
    Purpose: Project detail with participation action and timeline panels.
    Expected locals: project, isParticipant, quickReport, currentDateLabel, activitySections,
        creationDate, participantRows.
    Data source: projects.controller pre-computes timeline grouping and participant/team rows.
%>

<div class="grid gap-6 lg:grid-cols-[2fr_1fr]">
    <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
        <h1 class="font-heading text-2xl font-bold text-brand-text sm:text-3xl"><%= project.name %></h1></h1>
        <p class="mt-3 text-sm text-brand-text/80">Owned by: <%= project.responsible?.fullName || 'Unknown' %></p>
        
        <div class="mt-8 grid gap-4 md:grid-cols-2">
            <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-brand-text/60">Description</p>
                <p class="mt-2 text-sm text-brand-text/80"><%= project.description %></p>
            </div>
            <div class="space-y-3 text-sm">
                <p><span class="font-semibold text-brand-text/70">Creation Date:</span> <%= creationDate ? new Date(creationDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A' %></p>
                <p><span class="font-semibold text-brand-text/70">Start Date:</span> <%= project.startDate ? new Date(project.startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A' %></p>
                <p><span class="font-semibold text-brand-text/70">End Date:</span> <%= project.endDate ? new Date(project.endDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A' %></p>
                <p><span class="font-semibold text-brand-text/70">Status:</span> <%= project.status || 'N/A' %></p>
            </div>
        </div>
    </section>

    <section>
        <%# Report generator replaces the date display and quick report button. %>
        <%- include('../partials/reportGenerator', { redirectTo: '/projects/' + project.id, defaultReportType, defaultSubjectId, reportSubjects, latestReports, quickReport }) %>
    </section>
</div>

<div class="mt-4 grid gap-6 lg:grid-cols-[2fr_1fr]">
    <section class="space-y-6">
        <article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <h2 class="font-heading text-2xl font-bold text-brand-text">Project Activity</h2>
                <div class="flex flex-wrap gap-2">
                    <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">Today</button>
                    <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">3 days</button>
                    <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">5 days</button>
                    <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">Start Date</button>
                    <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">End Date</button>
                </div>
            </div>

            <div class="mt-5 max-h-[520px] space-y-4 overflow-auto pr-1">
                <% if (!(activitySections || []).length) { %>
                    <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
                        No activity yet.
                    </p>
                <% } %>

                <%# Data is grouped by day and includes preformatted item time labels. %>
                <% (activitySections || []).forEach((section) => { %>
                    <p class="inline-flex rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
                        <%= section.dayLabel %>
                    </p>
                    <% section.items.forEach((item) => { %>
                        <article class="rounded-xl border border-brand-secondary/70 p-4">
                            <div class="flex items-start gap-3">
                                <div class="mt-1 h-5 w-5 rounded-full border border-brand-secondary"></div>
                                <div class="flex-1">
                                    <div class="flex flex-wrap items-center justify-between gap-2">
                                        <h3 class="font-heading text-base font-bold text-brand-text"><%= item.title %></h3>
                                        <span class="text-xs text-brand-text/60"><%= item.activityTimeLabel %></span>
                                    </div>
                                    <p class="mt-2 text-sm text-brand-text/80"><%= item.description || item.content %></p>
                                </div>
                            </div>
                        </article>
                    <% }) %>
                <% }) %>
            </div>
        </article>

        <article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
            <h2 class="font-heading text-2xl font-bold text-brand-text">Achievements</h2>
            <div class="mt-4 space-y-3">
                <% if (!project.achievements.length) { %>
                    <p class="text-sm text-brand-text/70">No achievements yet.</p>
                <% } %>
                <% project.achievements.forEach((achievement) => { %>
                    <div class="rounded-xl border border-brand-secondary p-4">
                        <div class="flex items-start justify-between gap-2">
                            <h3 class="font-heading text-base font-bold text-brand-text"><%= achievement.title %></h3>
                            <span class="rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold text-brand-text/70">
                                <%= achievement.achievementDate ? new Date(achievement.achievementDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %>
                            </span>
                        </div>
                        <p class="mt-2 text-sm text-brand-text/80"><%= achievement.description %></p>
                        <p class="mt-2 text-sm">
                            <a href="<%= achievement.evidenceLink || '#' %>" class="font-semibold text-brand-primary hover:underline">Link</a>
                        </p>
                    </div>
                <% }) %>
            </div>
        </article>

        <article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
            <h2 class="font-heading text-2xl font-bold text-brand-text">Goals</h2>
            <div class="mt-4 space-y-3">
                <% if (!project.goals.length) { %>
                    <p class="text-sm text-brand-text/70">No goals yet.</p>
                <% } %>
                <% project.goals.forEach((goal) => { %>
                    <div class="rounded-xl border border-brand-secondary p-4">
                        <div class="flex items-start justify-between gap-2">
                            <h3 class="font-heading text-base font-bold text-brand-text"><%= goal.title %></h3>
                            <span class="rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold text-brand-text/70">
                                <%= goal.dueDate ? new Date(goal.dueDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %>
                            </span>
                        </div>
                        <p class="mt-2 text-sm text-brand-text/80"><%= goal.description %></p>
                        <div class="mt-2 flex items-center justify-between gap-2 text-sm">
                            <a href="#" class="font-semibold text-brand-primary hover:underline">Link</a>
                            <span class="text-xs font-semibold uppercase tracking-wide text-brand-text/70"><%= goal.status || 'UNKNOWN' %></span>
                        </div>
                    </div>
                <% }) %>
            </div>
        </article>
    </section>

    <section class="space-y-4">
        <%# Leave/Join Project button %>
        <div class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <form action="/projects/<%= project.id %>/toggle-membership" method="POST">
                <button
                    type="submit"
                    class="w-full rounded-xl border px-4 py-2 text-sm font-semibold transition <%= isParticipant ? 'border-brand-accent text-brand-accent hover:bg-brand-accent hover:text-white' : 'border-brand-secondary text-brand-text/80 hover:bg-brand-secondary/30' %>"
                >
                    <%= isParticipant ? 'Leave Project' : 'Join Project' %>
                </button>
            </form>
        </div>

        <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <h2 class="font-heading text-2xl font-bold text-brand-text">Project Highlights</h2>
            <div class="mt-4 space-y-3">
                <% if (!project.highlights.length) { %>
                    <p class="text-sm text-brand-text/70">No highlights yet.</p>
                <% } %>
                <% project.highlights.forEach((highlight) => { %>
                    <div class="rounded-xl border border-brand-secondary p-3">
                        <p class="text-xs text-brand-text/60"><%= highlight.createdAt ? new Date(highlight.createdAt).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %></p>
                        <p class="mt-1 text-sm font-semibold text-brand-text"><%= highlight.title %></p>
                        <p class="mt-1 text-sm text-brand-text/80"><%= highlight.content %></p>
                    </div>
                <% }) %>
            </div>
        </article>

        <details open class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <summary class="cursor-pointer list-none font-heading text-2xl font-bold text-brand-text">
                Teams Involved
            </summary>
            <div class="mt-4 space-y-3">
                <% if (!project.teamsDetailed.length) { %>
                    <p class="text-sm text-brand-text/70">No teams assigned.</p>
                <% } %>
                <% project.teamsDetailed.forEach((team) => { %>
                    <a href="/teams/<%= team.id %>" class="flex items-center gap-3 rounded-xl border border-brand-secondary p-3 transition hover:bg-brand-bg">
                        <div class="h-8 w-8 rounded-full border border-brand-secondary bg-brand-bg"></div>
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-brand-text"><%= team.name %></p>
                            <p class="text-xs text-brand-text/60"><%= team.members?.length || 0 %> members</p>
                        </div>
                    </a>
                <% }) %>
            </div>
        </details>

        <details open class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <summary class="cursor-pointer list-none font-heading text-2xl font-bold text-brand-text">
                Project Members
            </summary>
            <div class="mt-4 space-y-3">
                <% if (!(participantRows || []).length) { %>
                    <p class="text-sm text-brand-text/70">No participants assigned.</p>
                <% } %>
                <% (participantRows || []).forEach((row) => { %>
                    <a href="/employees/<%= row.participant.id %>" class="flex items-center gap-3 rounded-xl border border-brand-secondary p-3 transition hover:bg-brand-bg">
                        <div class="h-8 w-8 rounded-full border border-brand-secondary bg-brand-bg"></div>
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-brand-text">
                                <%= row.participant.fullName %> - <%= row.teamName %> - <%= row.roleName %>
                            </p>
                            <p class="text-xs text-brand-text/60"><%= row.startDateLabel %></p>
                        </div>
                    </a>
                <% }) %>
            </div>
        </details>

        <a
            href="/projects"
            class="inline-flex rounded-xl border border-brand-secondary px-3 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30"
        >
            Back to projects
        </a>
    </section>
</div>
