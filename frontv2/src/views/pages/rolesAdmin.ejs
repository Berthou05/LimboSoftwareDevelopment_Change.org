<%# Template: pages/rolesAdmin.ejs
   Purpose: Admin panel for role privilege toggles.
   Expected locals: roles, privilegesCatalog.
   Matrix layout: each row is a privilege, each column is a role, each cell toggles assignment.
%>

<%- include("../partials/pageHeader", { title: pageTitle, subtitle: pageSubtitle }) %>

<section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="font-heading text-xl font-bold">Roles Administration</h2>
    <button
      type="button"
      class="rounded-xl border border-brand-primary px-3 py-2 text-sm font-semibold text-brand-primary transition hover:bg-brand-primary hover:text-white"
    >
      Create Role
    </button>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-brand-secondary/70 text-sm">
      <thead>
        <tr class="text-left text-brand-text/70">
          <th class="px-3 py-2">Privilege</th>
          <% roles.forEach((role) => { %>
            <th class="px-3 py-2"><%= role.name %></th>
          <% }) %>
        </tr>
      </thead>
      <tbody class="divide-y divide-brand-secondary/60">
        <%# Row loop: one row per privilege from repository catalog. %>
        <% privilegesCatalog.forEach((privilege) => { %>
          <tr>
            <td class="px-3 py-3">
              <p class="font-semibold"><%= privilege.code %></p>
              <p class="text-xs text-brand-text/70"><%= privilege.name %></p>
            </td>
            <%# Cell loop: ON/OFF indicates whether the current role contains this privilege code. %>
            <% roles.forEach((role) => { const enabled = role.privilegeCodes.includes(privilege.code); %>
              <td class="px-3 py-3">
                <form action="/admin/roles/<%= role.id %>/<%= privilege.code %>/toggle" method="POST">
                  <button
                    type="submit"
                    class="inline-flex min-w-20 justify-center rounded-full px-3 py-1 text-xs font-semibold transition <%= enabled ? 'bg-brand-primary text-white' : 'bg-brand-secondary/50 text-brand-text/70 hover:bg-brand-secondary' %>"
                  >
                    <%= enabled ? "ON" : "OFF" %>
                  </button>
                </form>
              </td>
            <% }) %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>



