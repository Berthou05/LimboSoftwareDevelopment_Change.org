<%# Template: pages/teamDetail.ejs
    Purpose: Team detail with membership actions and grouped activity log.
    Expected locals: team, isMember, quickReport, currentDateLabel, activitySections.
    Data source: teams.controller pre-groups activity items for rendering.
%>

<div class="grid gap-6 lg:grid-cols-[2fr_1fr]">
    <section class="space-y-6">
        <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
            <div class="flex flex-wrap items-center gap-4">
                <img src="<%= team.image %>" alt="<%= team.name %>" class="h-16 w-16 shrink-0 rounded-full border border-brand-secondary object-cover" />
                <div class="flex-1 min-w-0">
                    <h1 class="font-heading text-2xl font-bold text-brand-text sm:text-3xl"><%= team.name %></h1>
                    <p class="text-sm text-brand-text/70"><%= team.description %></p>
                </div>
            </div>
            <p class="mt-3 text-sm text-brand-text/80">Created by: <%= team.lead?.fullName || 'Unknown' %></p>
            <p class="mt-4 inline-flex rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
                Team Information
            </p>
        </section>

        <%# Team Projects - Primary component %>
        <article class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
            <h2 class="font-heading text-2xl font-bold text-brand-text">Team Projects</h2>
            <p class="mt-1 text-sm text-brand-text/60">Projects this team is working on</p>
            <div class="mt-5 space-y-4">
                <% if (!team.projectsDetailed.length) { %>
                    <p class="text-sm text-brand-text/70">No projects assigned.</p>
                <% } %>
                <% team.projectsDetailed.forEach((project) => { %>
                    <details class="group rounded-xl border border-brand-secondary">
                        <summary class="flex cursor-pointer items-center gap-3 p-3 transition hover:bg-brand-bg/50">
                            <svg class="h-4 w-4 shrink-0 text-brand-text/50 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                            </svg>
                            <div class="h-10 w-10 shrink-0 rounded-full border border-brand-secondary bg-brand-bg"></div>
                            <div class="flex-1 min-w-0">
                                <p class="font-semibold text-brand-text group-hover:text-brand-primary truncate"><%= project.name %></p>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="inline-flex rounded-full border border-brand-secondary px-2 py-0.5 text-[10px] font-semibold text-brand-text/60"><%= project.status %></span>
                                    <span class="text-xs text-brand-text/50">
                                        Started: <%= project.startDate ? new Date(project.startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A' %>
                                    </span>
                                </div>
                            </div>
                            <a href="/projects/<%= project.id %>" class="shrink-0 rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold text-brand-text/70 transition hover:bg-brand-secondary/30" onclick="event.stopPropagation();">
                                View
                            </a>
                        </summary>
                        
                        <%
                            const projectFeedItems = [
                                ...(project.goals || []).map((goal) => ({
                                    type: 'Goal',
                                    title: goal.title,
                                    body: goal.description,
                                    dateValue: goal.dueDate || null,
                                    dateLabel: goal.dueDate ? new Date(goal.dueDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'No due date',
                                    auxLabel: goal.status || 'UNKNOWN',
                                    icon: 'G',
                                    tone: 'border-amber-200 bg-amber-50 text-amber-700',
                                })),
                                ...(project.achievements || []).map((achievement) => ({
                                    type: 'Achievement',
                                    title: achievement.title,
                                    body: achievement.description,
                                    dateValue: achievement.achievementDate || null,
                                    dateLabel: achievement.achievementDate ? new Date(achievement.achievementDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'No date',
                                    auxLabel: 'Delivered',
                                    icon: 'A',
                                    tone: 'border-emerald-200 bg-emerald-50 text-emerald-700',
                                })),
                                ...(project.highlights || []).map((highlight) => ({
                                    type: 'Highlight',
                                    title: highlight.title,
                                    body: highlight.content,
                                    dateValue: highlight.createdAt || null,
                                    dateLabel: highlight.createdAt ? new Date(highlight.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'No date',
                                    auxLabel: 'Update',
                                    icon: 'H',
                                    tone: 'border-sky-200 bg-sky-50 text-sky-700',
                                })),
                            ].sort((leftItem, rightItem) => new Date(rightItem.dateValue || 0) - new Date(leftItem.dateValue || 0));
                        %>

                        <div class="border-t border-brand-secondary p-3">
                            <p class="text-xs text-brand-text/60"><%= project.description || 'No description available.' %></p>

                            <div class="mt-3 flex flex-wrap gap-2">
                                <span class="rounded-full border border-brand-secondary px-2 py-1 text-[10px] font-semibold text-brand-text/60"><%= (project.goals || []).length %> goals</span>
                                <span class="rounded-full border border-brand-secondary px-2 py-1 text-[10px] font-semibold text-brand-text/60"><%= (project.achievements || []).length %> achievements</span>
                                <span class="rounded-full border border-brand-secondary px-2 py-1 text-[10px] font-semibold text-brand-text/60"><%= (project.highlights || []).length %> highlights</span>
                            </div>

                            <div class="mt-4 max-h-80 space-y-2 overflow-y-auto pr-1">
                                <% if (!projectFeedItems.length) { %>
                                    <p class="rounded-lg border border-dashed border-brand-secondary p-3 text-sm text-brand-text/60">
                                        No goals, achievements, or highlights yet.
                                    </p>
                                <% } %>

                                <% projectFeedItems.forEach((item) => { %>
                                    <article class="flex items-start gap-3 rounded-xl border border-brand-secondary/70 bg-white p-3">
                                        <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full border text-[11px] font-bold <%= item.tone %>">
                                            <%= item.icon %>
                                        </div>
                                        <div class="min-w-0 flex-1">
                                            <div class="flex flex-wrap items-center gap-2">
                                                <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide <%= item.tone %>"><%= item.type %></span>
                                                <span class="text-[10px] font-semibold uppercase tracking-wide text-brand-text/45"><%= item.auxLabel %></span>
                                                <span class="ml-auto text-[10px] text-brand-text/45"><%= item.dateLabel %></span>
                                            </div>
                                            <p class="mt-1 text-sm font-semibold text-brand-text"><%= item.title %></p>
                                            <p class="mt-1 text-sm text-brand-text/70"><%= item.body %></p>
                                        </div>
                                    </article>
                                <% }) %>
                            </div>
                        </div>
                    </details>
                <% }) %>
            </div>
        </article>
    </section>

    <section class="space-y-4">
        <%# Leave/Join Team %>
        <div class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <form action="/teams/<%= team.id %>/toggle-membership" method="POST">
                <button
                    type="submit"
                    class="w-full rounded-xl border px-4 py-2 text-sm font-semibold transition <%= isMember ? 'border-brand-accent text-brand-accent hover:bg-brand-accent hover:text-white' : 'border-brand-secondary text-brand-text/80 hover:bg-brand-secondary/30' %>"
                >
                    <%= isMember ? 'Leave Team' : 'Join Team' %>
                </button>
            </form>
        </div>
        
        <%# Report generator replaces the date display and quick report button. %>
        <%- include('../partials/reportGenerator', { redirectTo: '/teams/' + team.id, defaultReportType, defaultSubjectId, reportSubjects, latestReports, quickReport }) %>

        

        <%# Team Participants - Sidebar %>
        <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <div class="flex items-center justify-between mb-3">
                <h2 class="font-heading text-xl font-bold text-brand-text">Team Participants</h2>
                <button id="showAddMember" type="button" class="inline-flex items-center gap-1 rounded-lg border border-brand-primary px-2 py-1 text-xs font-semibold text-brand-primary bg-white hover:bg-brand-primary hover:text-white transition">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                    Add
                </button>
            </div>
            <div class="mt-3 max-h-48 overflow-y-auto space-y-2 mb-4">
                <% if (!team.membersDetailed.length) { %>
                    <p class="text-sm text-brand-text/70">No participants assigned.</p>
                <% } %>
                <% team.membersDetailed.forEach((member) => { %>
                    <div class="flex items-center gap-2 rounded-lg p-2 transition hover:bg-brand-bg/50 group">
                        <a href="/employees/<%= member.employee?.id %>" class="flex items-center gap-2 flex-1 min-w-0">
                            <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-primary/10 text-[10px] font-bold text-brand-primary">
                                <%= member.employee?.fullName ? member.employee.fullName.split(' ').map(n => n[0]).join('') : '?' %>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-xs font-semibold text-brand-text truncate"><%= member.employee?.fullName || 'Unknown' %></p>
                                <p class="text-[10px] text-brand-text/50 truncate"><%= member.role %></p>
                            </div>
                        </a>
                        <form class="remove-member-form ml-2" action="/teams/<%= team.id %>/toggle-membership" method="POST" style="display:inline;">
                            <input type="hidden" name="employeeId" value="<%= member.employee?.id %>" />
                            <button type="submit" class="remove-member-btn text-xs text-red-500 border border-red-200 rounded px-2 py-1 ml-1 opacity-0 group-hover:opacity-100 transition" title="Remove from team">Remove</button>
                        </form>
                    </div>
                <% }) %>
            </div>
            <div id="addMemberPanel" class="hidden mt-2">
                <form action="/teams/<%= team.id %>/toggle-membership" method="POST" autocomplete="off" class="relative">
                    <label for="addMemberSearch" class="block mb-2 text-sm font-semibold text-brand-text">Add member to team:</label>
                    <div class="flex items-center rounded-xl border border-brand-secondary bg-white px-3">
                        <svg class="h-4 w-4 shrink-0 text-brand-text/50" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.5"></circle>
                            <path d="M13.5 13.5L18 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                        </svg>
                        <input id="addMemberSearch" name="addMemberSearch" type="search" placeholder="Search for an employee..." class="add-member-search w-full border-none bg-transparent px-3 py-2 text-sm outline-none" autocomplete="off" />
                        <input type="hidden" name="employeeId" class="add-member-id" required />
                    </div>
                    <div class="add-member-results absolute z-30 mt-1 hidden w-full rounded-xl border border-brand-secondary bg-white p-1 shadow-panel"></div>
                    <button type="submit" class="mt-2 w-full rounded-xl border border-brand-primary text-brand-primary px-4 py-2 text-sm font-semibold hover:bg-brand-primary hover:text-white transition">Add to Team</button>
                </form>
                <script type="application/json" class="add-member-catalog"><%- JSON.stringify(allEmployees.filter(emp => !team.members.some(m => m.employeeId === emp.id)).map(emp => ({ id: emp.id, label: emp.fullName }))) %></script>
            </div>
        </article>

        <%# Team Activity - Compact sidebar view %>
        <div class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <div class="flex items-center justify-between gap-2">
                <h2 class="font-heading text-xl font-bold text-brand-text">Activity</h2>
                <select class="rounded-lg border border-brand-secondary px-2 py-1 text-xs font-semibold text-brand-text/70 outline-none" id="activityDateFilter">
                    <option value="today">Today</option>
                    <option value="3days">Last 3 days</option>
                    <option value="week">This week</option>
                    <option value="all" selected>All</option>
                </select>
            </div>
            
            <div class="mt-4 max-h-72 overflow-y-auto space-y-1">
                <% if (!(activitySections || []).length) { %>
                    <p class="py-4 text-center text-sm text-brand-text/50">No activity yet.</p>
                <% } %>
                <% (activitySections || []).forEach((section, sectionIndex) => { %>
                    <p class="sticky top-0 bg-white py-1 text-[10px] font-semibold uppercase tracking-wider text-brand-text/40"><%= section.dayLabel %></p>
                    <% section.items.forEach((item) => { %>
                        <div class="flex items-start gap-2 rounded-lg px-2 py-2 transition hover:bg-brand-bg/50" data-activity-section="<%= sectionIndex %>">
                            <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-primary/10 text-[9px] font-bold text-brand-primary">
                                <%= item.authorInitials || '?' %>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-[10px] text-brand-text/50"><%= item.authorName || 'Unknown' %></p>
                                <p class="text-xs font-medium text-brand-text truncate"><%= item.title %></p>
                                <p class="text-[10px] text-brand-text/50 truncate"><%= item.description || '' %></p>
                            </div>
                            <span class="shrink-0 text-[10px] text-brand-text/40"><%= item.activityTimeLabel || '' %></span>
                        </div>
                    <% }) %>
                <% }) %>
            </div>
        </div>

        <a
            href="/teams"
            class="inline-flex rounded-xl border border-brand-secondary px-3 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30"
        >
            Back to teams
        </a>
    </section>
</div>
