<%# Template: pages/teamDetail.ejs
    Purpose: Team detail with membership actions and grouped activity log.
    Expected locals: team, isMember, quickReport, currentDateLabel, activitySections.
    Data source: teams.controller pre-groups activity items for rendering.
%>

<div class="grid gap-6 xl:grid-cols-[2fr_1fr]">
    <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
        <div class="flex flex-wrap items-center gap-4">
            <img src="<%= team.image %>" alt="<%= team.name %>" class="h-16 w-16 rounded-full border border-brand-secondary object-cover" />
            <div class="flex-1">
                <h1 class="font-heading text-3xl font-bold text-brand-text"><%= team.name %></h1>
                <p class="text-sm text-brand-text/70"><%= team.description %></p>
            </div>
        </div>
        <p class="mt-3 text-sm text-brand-text/80">Created by: <%= team.lead?.fullName || 'Unknown' %></p>
        <p class="mt-4 inline-flex rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
            Team Information
        </p>
    </section>

    <section class="space-y-4">
        <%# Report generator replaces the date display and quick report button. %>
        <%- include('../partials/reportGenerator', { redirectTo: '/teams/' + team.id, defaultReportType, defaultSubjectId, reportSubjects, latestReports, quickReport }) %>

        <div class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <%# Same endpoint toggles membership in both directions; label explains current state. %>
            <form action="/teams/<%= team.id %>/toggle-membership" method="POST">
                <button
                    type="submit"
                    class="w-full rounded-xl border px-4 py-2 text-sm font-semibold transition <%= isMember ? 'border-brand-accent text-brand-accent hover:bg-brand-accent hover:text-white' : 'border-brand-secondary text-brand-text/80 hover:bg-brand-secondary/30' %>"
                >
                    <%= isMember ? 'Leave Team' : 'Join Team' %>
                </button>
            </form>
        </div>
    </section>
</div>

<div class="mt-6 grid gap-6 xl:grid-cols-[2fr_1fr]">
    <section class="rounded-2xl border border-brand-secondary bg-white p-5 shadow-panel">
        <div class="flex flex-wrap items-center justify-between gap-3">
            <h2 class="font-heading text-2xl font-bold text-brand-text">Team Activity</h2>
            <div class="flex flex-wrap gap-2">
                <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">Today</button>
                <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">3 days</button>
                <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">5 days</button>
                <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">Start Date</button>
                <button type="button" class="rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">End Date</button>
            </div>
        </div>

        <div class="mt-5 space-y-4">
            <% if (!(activitySections || []).length) { %>
                <p class="rounded-xl border border-dashed border-brand-secondary p-4 text-sm text-brand-text/70">
                    No activity yet.
                </p>
            <% } %>

            <%# Grouping and time labels are prepared in controller for consistency with other pages. %>
            <% (activitySections || []).forEach((section) => { %>
                <p class="inline-flex rounded-full border border-brand-secondary px-3 py-1 text-xs font-semibold text-brand-text/70">
                    <%= section.dayLabel %>
                </p>
                <% section.items.forEach((item) => { %>
                    <article class="rounded-xl border border-brand-secondary/70 p-4">
                        <div class="flex items-start gap-3">
                            <div class="mt-1 h-5 w-5 rounded-full border border-brand-secondary"></div>
                            <div class="flex-1">
                                <div class="flex flex-wrap items-center justify-between gap-2">
                                    <h3 class="font-heading text-base font-bold text-brand-text"><%= item.title %></h3>
                                    <span class="text-xs text-brand-text/60"><%= item.activityTimeLabel %></span>
                                </div>
                                <p class="mt-2 text-sm text-brand-text/80"><%= item.description || item.content %></p>
                            </div>
                        </div>
                    </article>
                <% }) %>
            <% }) %>
        </div>
    </section>

    <section class="space-y-6">
        <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <h2 class="font-heading text-2xl font-bold text-brand-text">Team Participants</h2>
            <div class="mt-4 space-y-3">
                <% if (!team.membersDetailed.length) { %>
                    <p class="text-sm text-brand-text/70">No participants assigned.</p>
                <% } %>
                <% team.membersDetailed.forEach((member) => { %>
                    <a href="/employees/<%= member.employee?.id %>" class="flex items-center gap-3 rounded-xl border border-brand-secondary p-3 transition hover:bg-brand-bg">
                        <div class="h-8 w-8 rounded-full border border-brand-secondary bg-brand-bg"></div>
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-brand-text"><%= member.employee?.fullName || 'Unknown' %> - <%= member.role %></p>
                            <p class="text-xs text-brand-text/60">
                                <%= member.startDate ? new Date(member.startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Date unavailable' %>
                            </p>
                        </div>
                    </a>
                <% }) %>
            </div>
        </article>

        <article class="rounded-2xl border border-brand-secondary bg-white p-4 shadow-panel">
            <h2 class="font-heading text-2xl font-bold text-brand-text">Team Projects</h2>
            <div class="mt-4 space-y-3">
                <% if (!team.projectsDetailed.length) { %>
                    <p class="text-sm text-brand-text/70">No projects assigned.</p>
                <% } %>
                <% team.projectsDetailed.forEach((project) => { %>
                    <a href="/projects/<%= project.id %>" class="flex items-center gap-3 rounded-xl border border-brand-secondary p-3 transition hover:bg-brand-bg">
                        <div class="h-8 w-8 rounded-full border border-brand-secondary bg-brand-bg"></div>
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-brand-text"><%= project.name %> - <%= project.status %></p>
                            <p class="text-xs text-brand-text/60">
                                <%= project.startDate ? new Date(project.startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Date unavailable' %>
                            </p>
                        </div>
                    </a>
                <% }) %>
            </div>
        </article>

        <a
            href="/teams"
            class="inline-flex rounded-xl border border-brand-secondary px-3 py-2 text-sm font-semibold text-brand-text/80 transition hover:bg-brand-secondary/30"
        >
            Back to teams
        </a>
    </section>
</div>
