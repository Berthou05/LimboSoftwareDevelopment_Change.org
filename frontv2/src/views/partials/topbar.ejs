<%# Template: partials/topbar.ejs
   Purpose: Top app bar with search, date label, and account menu.
   Expected locals: currentUser, todayLabel.
   JS integration: `data-account-menu*` attributes are used by initTopbarAccountMenu() in main.js.
%>

<header class="sticky top-0 z-20 border-b border-brand-secondary/60 bg-brand-bg/90 px-6 py-4 backdrop-blur sm:px-8 lg:px-10">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <%# This search is intentionally global in UI, but currently submits to /employees for prototype scope. %>
    <form action="/employees" method="GET" class="flex w-full max-w-lg items-center gap-2 rounded-xl border border-brand-secondary bg-white px-3 py-2 shadow-sm">
      <input
        type="text"
        name="q"
        placeholder="Search employee, team, or project..."
        class="w-full border-none bg-transparent text-sm outline-none"
      />
      <button
        type="submit"
        class="rounded-lg bg-brand-primary px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white"
      >
        Search
      </button>
    </form>

    <div class="flex items-center gap-3">
      <div class="rounded-xl border border-brand-secondary bg-white px-3 py-2 text-sm">
        <%= todayLabel %>
      </div>
      <div class="relative" data-account-menu>
        <button
          type="button"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-primary font-heading font-bold text-white"
          data-account-menu-toggle
          aria-label="Open account menu"
          aria-expanded="false"
        >
          <%# Initial fallback avoids blank avatar before user images are implemented in topbar. %>
          <%= currentUser?.name ? currentUser.name.charAt(0).toUpperCase() : "U" %>
        </button>

        <div
          class="absolute right-0 z-40 mt-2 hidden min-w-52 rounded-xl border border-brand-secondary bg-white p-2 shadow-panel"
          data-account-menu-panel
        >
          <div class="mb-2 border-b border-brand-secondary/70 px-2 pb-2">
            <p class="text-sm font-semibold text-brand-text"><%= currentUser?.name || "User" %></p>
            <p class="text-xs text-brand-text/70"><%= currentUser?.roleName || "Employee" %></p>
          </div>

          <a
            href="/account"
            class="block rounded-lg px-2 py-2 text-sm font-medium text-brand-text/90 transition hover:bg-brand-secondary/30"
          >
            Account
          </a>

          <form action="/logout" method="POST" class="mt-1">
            <button
              type="submit"
              class="w-full rounded-lg border border-brand-accent px-2 py-2 text-left text-sm font-semibold text-brand-accent transition hover:bg-brand-accent hover:text-white"
            >
              Sign out
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</header>
