<%# Template: partials/activityList.ejs
   Purpose: Reusable activity timeline card list.
   Expected locals: items (array).
   Fallback fields (`description || content`, `completedAt || createdAt`) keep this partial reusable.
%>

<div class="space-y-3">
  <% if (!items || items.length === 0) { %>
    <p class="rounded-xl border border-dashed border-brand-secondary/80 p-4 text-sm text-brand-text/70">
      No activity yet.
    </p>
  <% } %>

  <% (items || []).forEach((item) => { %>
    <article class="rounded-xl border border-brand-secondary/70 bg-white p-4 shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <h4 class="font-heading text-sm font-bold"><%= item.title %></h4>
        <span class="text-xs text-brand-text/60"><%= new Date(item.completedAt || item.createdAt).toLocaleString() %></span>
      </div>
      <p class="mt-2 text-sm text-brand-text/80"><%= item.description || item.content %></p>
    </article>
  <% }); %>
</div>


